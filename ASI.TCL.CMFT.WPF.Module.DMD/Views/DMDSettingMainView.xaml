<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.DMD.Views.DMDSettingMainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataTypes="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.DataTypes"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:triggerActions="clr-namespace:ASI.TCL.CMFT.WPF.TriggerActions;assembly=ASI.TCL.CMFT.WPF"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:DMDSettingMainViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="2700"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="8*" />
        </Grid.ColumnDefinitions>

        <!--#region 操作功能-->
        <GroupBox
            Grid.Column="0"
            Margin="5,5,0,5"
            Header="操作功能">
            <Grid>
                <Grid.Resources>
                    <Style BasedOn="{StaticResource StepRadioButton}" TargetType="{x:Type RadioButton}">
                        <Setter Property="Command" Value="{Binding NavigateCommand}" />
                    </Style>
                    <Style BasedOn="{StaticResource MainTitleTextBox}" TargetType="{x:Type TextBlock}" />
                </Grid.Resources>
                <UniformGrid VerticalAlignment="Top" Style="{StaticResource UniformGridMargin5}">
                    <RadioButton
                        CommandParameter="{x:Static datas:NavigatePath.DMDPreRecordedMessageSettings}"
                        Content="預錄訊息"
                        IsChecked="True" />
                    <RadioButton CommandParameter="{x:Static datas:NavigatePath.DMDScheduleTemplateSettings}" Content="排程樣板" />
                    <RadioButton CommandParameter="{x:Static datas:NavigatePath.DMDScheduleSettings}" Content="排程設定" />
                    <RadioButton CommandParameter="{x:Static datas:NavigatePath.DMDTrainMessageSettings}" Content="列車訊息" />
                    <RadioButton CommandParameter="{x:Static datas:NavigatePath.DMDDisplayModeSettings}" Content="顯示模式" />
                </UniformGrid>
                <TextBlock Text="點矩陣設定" />
            </Grid>
        </GroupBox>
        <!--#endregion-->

        <GroupBox
            Grid.Column="1"
            Margin="5"
            Header="設定">
            <UniformGrid Columns="1">
                <ContentControl prism:RegionManager.RegionName="{x:Static datas:RegionNames.DMDSettingsRegion}" />
            </UniformGrid>
        </GroupBox>

    </Grid>
</UserControl>
