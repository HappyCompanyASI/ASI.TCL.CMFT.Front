<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.DMD.Views.DMDTrainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:applications="clr-namespace:ASI.TCL.CMFT.WPF.Applications;assembly=ASI.TCL.CMFT.WPF"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Converters"
    xmlns:converters1="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataTypes="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.DataTypes"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Datas"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:triggerActions="clr-namespace:ASI.TCL.CMFT.WPF.TriggerActions;assembly=ASI.TCL.CMFT.WPF"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:DMDTrainViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="7*" />
        </Grid.ColumnDefinitions>

        <!--#region 操作流程-->
        <GroupBox
            Grid.RowSpan="3"
            Grid.Column="0"
            Margin="0,5"
            Header="操作流程"
            IsHitTestVisible="False">
            <Grid>
                <Grid.Resources>
                    <Style BasedOn="{StaticResource StepRadioButton}" TargetType="{x:Type ToggleButton}" />
                    <Style BasedOn="{StaticResource MainTitleTextBox}" TargetType="{x:Type TextBlock}" />
                </Grid.Resources>
                <UniformGrid VerticalAlignment="Top" Style="{StaticResource UniformGridMargin5}">
                    <ToggleButton Content="1.目標選擇" IsChecked="{Binding CurrentStep, Converter={converters:StepToIsCheckedConverter}, ConverterParameter={x:Static dataTypes:eStep.Step1}}" />
                    <ToggleButton Content="2.方式及內容選擇" IsChecked="{Binding CurrentStep, Converter={converters:StepToIsCheckedConverter}, ConverterParameter={x:Static dataTypes:eStep.Step2}}" />
                    <ToggleButton Content="3.開始播送" IsChecked="{Binding CurrentStep, Converter={converters:StepToIsCheckedConverter}, ConverterParameter={x:Static dataTypes:eStep.Step3}}" />
                </UniformGrid>
                <TextBlock Text="列車PID" />
            </Grid>
        </GroupBox>
        <!--#endregion-->

        <UniformGrid Grid.Column="1" Columns="1">

            <!--#region 1.目標選擇-->
            <Grid
                d:Visibility="Visible"
                Style="{StaticResource GridMargin5}"
                Visibility="{Binding CurrentStep, Converter={converters1:EqualityToVisibilityConverter}, ConverterParameter={x:Static dataTypes:eStep.Step1}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="7*" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <GroupBox Grid.Column="0" Header="目標">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <ListBox
                            x:Name="TargetGroupListBox"
                            Grid.Column="0"
                            ItemContainerStyle="{StaticResource StretchListBoxItem}"
                            ItemTemplate="{StaticResource SYSTrainGroup}"
                            ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                            ItemsSource="{x:Static datas:DesignTimeDatas.SYSTrainGroups}"
                            SelectedIndex="0"
                            SelectionMode="Single"
                            Style="{StaticResource MaterialDesignListBox}">
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="SelectionChanged">
                                    <triggerActions:DoNothingTriggerAction
                                        OperationID="1"
                                        Source="{Binding ItemsSource, ElementName=SelectedTargetListBox}"
                                        Target="{Binding SelectedItems, ElementName=TargetListBox}"
                                        TargetOperation="Add" />
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                        </ListBox>
                        <ListBox
                            x:Name="TargetListBox"
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            d:ItemsSource="{x:Static datas:DesignTimeDatas.SYSTrains}"
                            ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                            ItemsSource="{Binding SelectedItem.Trains, ElementName=TargetGroupListBox}"
                            SelectionMode="Multiple">
                            <ListBox.ItemContainerStyle>
                                <Style BasedOn="{StaticResource StretchListBoxItem}" TargetType="ListBoxItem">
                                    <!--  要設定ListBoxItem的不是RadioButton的IsEnabled  -->
                                    <Setter Property="IsEnabled" Value="{Binding IsSelected, RelativeSource={RelativeSource Self}, Converter={converters1:BoolNegationConverter}}" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton Style="{StaticResource SelecterRadioButton}">
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger EventName="Checked">
                                                <triggerActions:DoNothingTriggerAction
                                                    OperationID="2"
                                                    Source="{Binding SelectedItems, ElementName=TargetListBox}"
                                                    Target="{Binding ItemsSource, ElementName=SelectedTargetListBox}"
                                                    TargetOperation="Add" />
                                            </b:EventTrigger>
                                        </b:Interaction.Triggers>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding TrainNumber}" />
                                        </StackPanel>
                                    </RadioButton>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </GroupBox>
                <GroupBox Grid.Column="1" Header="已選擇目標">
                    <ListBox
                        x:Name="SelectedTargetListBox"
                        d:ItemsSource="{x:Static datas:DesignTimeDatas.SYSTrains}"
                        ItemContainerStyle="{StaticResource StretchListBoxItem}"
                        ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                        ItemsSource="{Binding SelectedTargets}"
                        SelectionMode="Multiple">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <RadioButton
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorLevel=1, AncestorType=UserControl, Mode=FindAncestor}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource SelecterRadioButton}">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="Checked">
                                            <triggerActions:DoNothingTriggerAction
                                                OperationID="3"
                                                Source="{Binding SelectedItems, ElementName=SelectedTargetListBox}"
                                                Target="{Binding SelectedItems, ElementName=TargetListBox}"
                                                TargetOperation="Remove" />
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TrainNumber}" />
                                    </StackPanel>
                                </RadioButton>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>
                <UniformGrid Grid.Column="2" Columns="1">
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Top"
                        Command="{x:Static applications:WPFApplicationCommands.NavigateCommand}"
                        CommandParameter="{x:Static datas:NavigatePath.DMDMain}"
                        Content="取消"
                        Style="{StaticResource NaviStepButton}" />
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Bottom"
                        Command="{Binding StepChangeCommand}"
                        CommandParameter="{x:Static dataTypes:eStep.Step2}"
                        Content="下一步"
                        Style="{StaticResource StepButton}" />
                </UniformGrid>
            </Grid>
            <!--#endregion-->

            <!--#region 2.方式及內容選擇-->
            <Grid
                d:Visibility="Visible"
                Style="{StaticResource GridMargin5}"
                Visibility="{Binding CurrentStep, Converter={converters1:EqualityToVisibilityConverter}, ConverterParameter={x:Static dataTypes:eStep.Step2}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="7*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <GroupBox
                    Grid.Column="0"
                    Header="已選擇目標"
                    IsHitTestVisible="False">
                    <ListBox
                        d:ItemsSource="{x:Static datas:DesignTimeDatas.SYSTrains}"
                        Background="{StaticResource ReadOnlyColor}"
                        IsHitTestVisible="False"
                        ItemContainerStyle="{StaticResource StretchListBoxItem}"
                        ItemTemplate="{StaticResource SYSTrain}"
                        ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                        ItemsSource="{Binding SelectedTargets}" />
                </GroupBox>
                <GroupBox Grid.Column="1" Header="方式及內容">
                    <TabControl x:Name="SendTypeTab" SelectedIndex="{Binding DataContext.SelectedTabIndex, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}">
                        <TabItem Header="預錄訊息">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1.5*" />
                                </Grid.ColumnDefinitions>

                                <ListBox
                                    x:Name="ContentGroupListBox"
                                    Grid.Column="0"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemTemplate="{StaticResource DMDMessageGroup}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                                    ItemsSource="{x:Static datas:DesignTimeDatas.DMDMessageGroups}"
                                    SelectedIndex="0"
                                    SelectionMode="Single" />

                                <ListBox
                                    x:Name="ContentListBox"
                                    Grid.Column="1"
                                    d:ItemsSource="{x:Static datas:DesignTimeDatas.DMDPreRecordMessages}"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemTemplate="{StaticResource DMDPreRecordMessage}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                                    ItemsSource="{Binding SelectedItem.Messages, ElementName=ContentGroupListBox}"
                                    SelectedItem="{Binding SelectedMessage}"
                                    SelectionMode="Single" />

                                <GroupBox
                                    Grid.Column="2"
                                    Margin="10,5"
                                    d:DataContext="{x:Static datas:DesignTimeDatas.DMDPreRecordMessages}"
                                    DataContext="{Binding SelectedItem, ElementName=ContentListBox}"
                                    Header="播放內容">
                                    <Grid Style="{StaticResource PanelMargin3}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="1*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button
                                            Grid.Row="0"
                                            Height="60"
                                            Command="{Binding DataContext.DseleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Content="{Binding MessageName}"
                                            FontSize="{StaticResource ButtonFontSize_Large}"
                                            FontWeight="Bold"
                                            Style="{StaticResource WPF.Button}" />
                                        <TextBox
                                            Grid.Row="1"
                                            VerticalAlignment="Stretch"
                                            IsHitTestVisible="False"
                                            Text="{Binding MessageContent}"
                                            TextWrapping="Wrap" />

                                        <UniformGrid
                                            Grid.Row="2"
                                            Columns="4"
                                            Style="{StaticResource UniformGridMargin0}">
                                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="類型" />
                                            <!--<RadioButton
                                                x:Name="GovernmentDecreeRadioButton"
                                                Padding="12,4"
                                                HorizontalAlignment="Stretch"
                                                Content="政令"
                                                FontSize="{StaticResource ButtonFontSize_Large}"
                                                FontWeight="Bold"
                                                Style="{StaticResource WPF.RadioButton.ButtonLike}" />-->
                                            <RadioButton
                                                x:Name="NormalRadioButton"
                                                Padding="8,4"
                                                HorizontalAlignment="Stretch"
                                                Content="一般"
                                                FontSize="{StaticResource ButtonFontSize_Large}"
                                                FontWeight="Bold"
                                                IsChecked="{Binding DataContext.SelectedType, Converter={converters1:EnumToBooleanConverter}, ConverterParameter={x:Static dataTypes:eMessageType.Normal}, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Style="{StaticResource WPF.RadioButton.ButtonLike}" />
                                            <RadioButton
                                                x:Name="EmergencyRadioButton"
                                                Padding="8,4"
                                                HorizontalAlignment="Stretch"
                                                Content="緊急"
                                                FontSize="{StaticResource ButtonFontSize_Large}"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource CMFT.Brush.Red.Dark}"
                                                IsChecked="{Binding DataContext.SelectedType, Converter={converters1:EnumToBooleanConverter}, ConverterParameter={x:Static dataTypes:eMessageType.Urgent}, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Style="{StaticResource WPF.RadioButton.ButtonLike}" />
                                        </UniformGrid>
                                        <UniformGrid
                                            Grid.Row="3"
                                            HorizontalAlignment="Stretch"
                                            Columns="2"
                                            Style="{StaticResource PanelMargin5}">
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="播放次數" />
                                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                    <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="[" />
                                                    <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="1~10" />
                                                    <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="]" />
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBox x:Name="PlayCountTextBox" HorizontalContentAlignment="Center">
                                                <TextBox.Style>
                                                    <Style BasedOn="{StaticResource CMFT.Field.TextBox}" TargetType="TextBox">
                                                        <Setter Property="Text" Value="{Binding DataContext.PlayCount, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked, ElementName=EmergencyRadioButton, Mode=TwoWay}" Value="True">
                                                                <Setter Property="Text" Value="∞" />
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>

                                        </UniformGrid>
                                    </Grid>
                                </GroupBox>
                            </Grid>

                        </TabItem>
                        <TabItem Header="即時訊息">

                            <GroupBox
                                Margin="80,20"
                                DataContext="{Binding SelectedItem, ElementName=ContentListBox}"
                                Header="訊息內容">

                                <Grid Margin="10,5" Style="{StaticResource PanelMargin5}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBox
                                        x:Name="Instant_MessageContentTextBox"
                                        Grid.Row="0"
                                        Height="250"
                                        VerticalAlignment="Stretch"
                                        VerticalContentAlignment="Top"
                                        materialDesign:HintAssist.Hint="請輸入即時訊息內容..."
                                        materialDesign:HintAssist.IsFloating="False"
                                        MaxLength="60"
                                        Text="{Binding DataContext.InstantMessage, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        TextWrapping="Wrap" />


                                    <UniformGrid
                                        Grid.Row="1"
                                        Columns="6"
                                        Style="{StaticResource UniformGridMargin0}">
                                        <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="類型" />
                                        <!--<RadioButton
                                            x:Name="Instant_GovernmentDecreeRadioButton"
                                            Padding="12,4"
                                            HorizontalAlignment="Stretch"
                                            Content="政令"
                                            FontSize="{StaticResource ButtonFontSize_Large}"
                                            FontWeight="Bold"
                                            Style="{StaticResource WPF.RadioButton.ButtonLike}" />-->
                                        <RadioButton
                                            x:Name="Instant_NormalRadioButton"
                                            Padding="8,4"
                                            HorizontalAlignment="Stretch"
                                            Content="一般"
                                            FontSize="{StaticResource ButtonFontSize_Large}"
                                            FontWeight="Bold"
                                            IsChecked="{Binding DataContext.SelectedType, Converter={converters1:EnumToBooleanConverter}, ConverterParameter={x:Static dataTypes:eMessageType.Normal}, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Style="{StaticResource WPF.RadioButton.ButtonLike}" />
                                        <RadioButton
                                            x:Name="Instant_EmergencyRadioButton"
                                            Padding="8,4"
                                            HorizontalAlignment="Stretch"
                                            Content="緊急"
                                            FontSize="{StaticResource ButtonFontSize_Large}"
                                            FontWeight="Bold"
                                            Foreground="{StaticResource CMFT.Brush.Red.Dark}"
                                            IsChecked="{Binding DataContext.SelectedType, Converter={converters1:EnumToBooleanConverter}, ConverterParameter={x:Static dataTypes:eMessageType.Urgent}, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Style="{StaticResource WPF.RadioButton.ButtonLike}" />
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="播放次數" />
                                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="[" />
                                                <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="1~10" />
                                                <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="]" />
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBox x:Name="Instant_PlayCountTextBox" HorizontalContentAlignment="Center">
                                            <TextBox.Style>
                                                <Style BasedOn="{StaticResource CMFT.Field.TextBox}" TargetType="TextBox">
                                                    <Setter Property="Text" Value="{Binding DataContext.PlayCount, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=Instant_EmergencyRadioButton, Mode=TwoWay}" Value="True">
                                                            <Setter Property="Text" Value="∞" />
                                                            <Setter Property="IsEnabled" Value="False" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </UniformGrid>

                                </Grid>
                            </GroupBox>

                        </TabItem>
                    </TabControl>
                </GroupBox>
                <UniformGrid Grid.Column="2" Columns="1">
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Top"
                        Command="{Binding StepChangeCommand}"
                        CommandParameter="{x:Static dataTypes:eStep.Step1}"
                        Content="上一步"
                        Style="{StaticResource StepButton}" />
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Bottom"
                        Command="{Binding StepChangeCommand}"
                        CommandParameter="{x:Static dataTypes:eStep.Step3}"
                        Content="播放"
                        Style="{StaticResource StepButton}" />
                </UniformGrid>
            </Grid>
            <!--#endregion-->

            <!--#region 3.開始撥放-->
            <Grid
                d:Visibility="Visible"
                Style="{StaticResource GridMargin5}"
                Visibility="{Binding CurrentStep, Converter={converters1:EqualityToVisibilityConverter}, ConverterParameter={x:Static dataTypes:eStep.Step3}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="7*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <GroupBox
                    Grid.Column="0"
                    Header="已選擇目標"
                    IsHitTestVisible="False">
                    <ListBox
                        d:ItemsSource="{x:Static datas:DesignTimeDatas.SYSTrains}"
                        Background="{StaticResource ReadOnlyColor}"
                        IsHitTestVisible="False"
                        ItemContainerStyle="{StaticResource StretchListBoxItem}"
                        ItemTemplate="{StaticResource SYSTrain}"
                        ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                        ItemsSource="{Binding SelectedTargets}" />
                </GroupBox>
                <GroupBox Grid.Column="1" Header="開始播送">
                    <TabControl d:SelectedIndex="1" SelectedIndex="{Binding SelectedIndex, ElementName=SendTypeTab}">
                        <!--  預錄  -->
                        <TabItem Visibility="Collapsed">
                            <GroupBox
                                Margin="10,5"
                                d:DataContext="{x:Static datas:DesignTimeDatas.DMDPreRecordMessages}"
                                DataContext="{Binding SelectedItem, ElementName=ContentListBox}"
                                Header="訊息內容">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid
                                        Grid.Row="0"
                                        Margin="60,10"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource PanelMargin3}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="1*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock
                                            Grid.Row="0"
                                            Margin="10"
                                            FontSize="24"
                                            FontWeight="Bold"
                                            Text="{Binding MessageName}" />
                                        <TextBox
                                            Grid.Row="1"
                                            VerticalAlignment="Stretch"
                                            IsHitTestVisible="False"
                                            Text="{Binding MessageContent}"
                                            TextWrapping="Wrap" />

                                        <UniformGrid
                                            Grid.Row="2"
                                            Columns="6"
                                            Style="{StaticResource PanelMargin5}">
                                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="類型" />
                                            <!--<RadioButton
                                                Padding="12,4"
                                                HorizontalAlignment="Stretch"
                                                Content="政令"
                                                FontSize="{StaticResource ButtonFontSize_Large}"
                                                FontWeight="Bold"
                                                IsChecked="{Binding IsChecked, ElementName=GovernmentDecreeRadioButton}"
                                                Style="{StaticResource WPF.RadioButton.ButtonLike}" />-->
                                            <RadioButton
                                                Padding="8,4"
                                                HorizontalAlignment="Stretch"
                                                Content="一般"
                                                FontSize="{StaticResource ButtonFontSize_Large}"
                                                FontWeight="Bold"
                                                IsChecked="{Binding IsChecked, ElementName=NormalRadioButton}"
                                                Style="{StaticResource WPF.RadioButton.ButtonLike}" />
                                            <RadioButton
                                                Padding="8,4"
                                                HorizontalAlignment="Stretch"
                                                Content="緊急"
                                                FontSize="{StaticResource ButtonFontSize_Large}"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource CMFT.Brush.Red.Dark}"
                                                IsChecked="{Binding IsChecked, ElementName=EmergencyRadioButton}"
                                                Style="{StaticResource WPF.RadioButton.ButtonLike}" />

                                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="播放次數" />
                                            <TextBox HorizontalContentAlignment="Center" Text="{Binding Text, ElementName=PlayCountTextBox}" />
                                        </UniformGrid>



                                    </Grid>
                                    <Button
                                        Grid.Row="1"
                                        Margin="50,20"
                                        Padding="14,8"
                                        Content="停止播放"
                                        FontSize="22"
                                        FontWeight="Bold"
                                        Style="{StaticResource WPF.Button}"
                                        Visibility="{Binding IsChecked, ElementName=EmergencyRadioButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Button.Triggers>
                                            <EventTrigger RoutedEvent="Button.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                                        <ColorAnimation
                                                            Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                                                            From="Gray"
                                                            To="Red"
                                                            Duration="0:0:0.5" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Button.Triggers>
                                    </Button>
                                </Grid>

                            </GroupBox>
                        </TabItem>
                        <!--  即時  -->
                        <TabItem Visibility="Collapsed">
                            <GroupBox
                                Margin="10,5"
                                DataContext="{Binding SelectedItem, ElementName=ContentListBox}"
                                Header="播放內容">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="1*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid
                                        Grid.Row="0"
                                        Margin="60,10"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource PanelMargin3}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="1*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBox
                                            Grid.Row="1"
                                            VerticalAlignment="Stretch"
                                            IsHitTestVisible="False"
                                            Text="{Binding Text, ElementName=Instant_MessageContentTextBox}"
                                            TextWrapping="Wrap" />

                                        <UniformGrid
                                            Grid.Row="2"
                                            Columns="6"
                                            Style="{StaticResource PanelMargin5}">
                                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="類型" />
                                            <!--<RadioButton
                                                Padding="12,4"
                                                HorizontalAlignment="Stretch"
                                                Content="政令"
                                                FontSize="{StaticResource ButtonFontSize_Large}"
                                                FontWeight="Bold"
                                                IsChecked="{Binding IsChecked, ElementName=Instant_GovernmentDecreeRadioButton}"
                                                Style="{StaticResource WPF.RadioButton.ButtonLike}" />-->
                                            <RadioButton
                                                Padding="8,4"
                                                HorizontalAlignment="Stretch"
                                                Content="一般"
                                                FontSize="{StaticResource ButtonFontSize_Large}"
                                                FontWeight="Bold"
                                                IsChecked="{Binding IsChecked, ElementName=Instant_NormalRadioButton}"
                                                Style="{StaticResource WPF.RadioButton.ButtonLike}" />
                                            <RadioButton
                                                Padding="8,4"
                                                HorizontalAlignment="Stretch"
                                                Content="緊急"
                                                FontSize="{StaticResource ButtonFontSize_Large}"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource CMFT.Brush.Red.Dark}"
                                                IsChecked="{Binding IsChecked, ElementName=Instant_EmergencyRadioButton}"
                                                Style="{StaticResource WPF.RadioButton.ButtonLike}" />

                                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="播放次數" />
                                            <TextBox HorizontalContentAlignment="Center" Text="{Binding Text, ElementName=Instant_PlayCountTextBox}" />
                                        </UniformGrid>



                                    </Grid>
                                    <Button
                                        Grid.Row="1"
                                        Margin="50,20"
                                        Padding="14,8"
                                        Content="停止播放"
                                        FontSize="22"
                                        FontWeight="Bold"
                                        Style="{StaticResource WPF.Button}"
                                        Visibility="{Binding IsChecked, ElementName=Instant_EmergencyRadioButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Button.Triggers>
                                            <EventTrigger RoutedEvent="Button.Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                                        <ColorAnimation
                                                            Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
                                                            From="Gray"
                                                            To="Red"
                                                            Duration="0:0:0.5" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Button.Triggers>
                                    </Button>
                                </Grid>

                            </GroupBox>

                        </TabItem>
                    </TabControl>
                </GroupBox>
                <UniformGrid Grid.Column="2" Columns="1">
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Bottom"
                        Command="{x:Static applications:WPFApplicationCommands.NavigateCommand}"
                        CommandParameter="{x:Static applications:WPFApplicationCommands.DefaultViewName}"
                        Content="結束"
                        Style="{StaticResource NaviStepButton}" />
                </UniformGrid>
            </Grid>
            <!--#endregion-->

        </UniformGrid>

    </Grid>
</UserControl>
