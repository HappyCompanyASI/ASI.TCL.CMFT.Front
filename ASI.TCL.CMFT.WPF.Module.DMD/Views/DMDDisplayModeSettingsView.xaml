<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.DMD.Views.DMDDisplayModeSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:DMDDisplayModeSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>

            <ListBox
                x:Name="DMDDisplayModeListBox"
                Grid.Column="0"
                ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                ItemsSource="{x:Static datas:DesignTimeDatas.DMDDisplayModes}"
                ScrollViewer.VerticalScrollBarVisibility="Visible"
                SelectedIndex="0"
                SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type dtos:DMDDisplayMode}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="50" Text="{Binding Station.StationID}" />
                            <TextBlock Text="[Station Name]" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!--  初始做法  -->
            <Grid
                Grid.Column="1"
                IsHitTestVisible="{Binding IsEditMode}"
                Style="{StaticResource GridMargin5}"
                Visibility="Collapsed">
                <Grid.Resources>
                    <Style BasedOn="{StaticResource CMFT.TextBlock.Left}" TargetType="{x:Type TextBlock}" />
                    <Style TargetType="{x:Type Border}" />
                    <Style BasedOn="{StaticResource UniformGridMargin1}" TargetType="{x:Type UniformGrid}" />
                    <Style BasedOn="{StaticResource MaterialDesignFilledComboBox}" TargetType="{x:Type ComboBox}">
                        <Setter Property="TextBlock.TextAlignment" Value="Center" />
                        <Setter Property="Padding" Value="5,1" />
                    </Style>
                    <Style BasedOn="{StaticResource WPF.RadioButton.ButtonLike}" TargetType="{x:Type RadioButton}">
                        <Setter Property="Padding" Value="8" />

                        <Setter Property="IsChecked">
                            <Setter.Value>
                                <Binding
                                    Mode="TwoWay"
                                    Path="IsSelected"
                                    RelativeSource="{RelativeSource AncestorType=ListBoxItem}" />
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <DataTemplate x:Key="SettingRadioButtonData">
                        <RadioButton>
                            <RadioButton.Style>
                                <Style BasedOn="{StaticResource WPF.RadioButton.ButtonLike}" TargetType="{x:Type RadioButton}">
                                    <Setter Property="Padding" Value="6" />

                                    <Setter Property="IsChecked">
                                        <Setter.Value>
                                            <Binding
                                                Mode="TwoWay"
                                                Path="IsSelected"
                                                RelativeSource="{RelativeSource AncestorType=ListBoxItem}" />
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </RadioButton.Style>
                            <TextBlock
                                Margin="0"
                                Padding="0"
                                Text="{Binding}" />
                        </RadioButton>
                    </DataTemplate>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0" Header="CDU設定">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <UniformGrid
                                Grid.Column="0"
                                VerticalAlignment="Stretch"
                                Columns="1">
                                <TextBlock Text="現在時刻位置" />
                                <TextBlock Text="現在時刻顏色" />
                                <TextBlock Text="換頁方式" />
                                <TextBlock Text="換頁速度" />
                                <TextBlock Text="字型" />
                                <TextBlock Text="顯示模式" />
                            </UniformGrid>
                            <UniformGrid
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Columns="1"
                                DataContext="{Binding SelectedItem.CDUSetting, ElementName=DMDDisplayModeListBox}">
                                <!--  現在時刻位置  -->
                                <ListBox
                                    VerticalAlignment="Center"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemTemplate="{StaticResource SettingRadioButtonData}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel3}"
                                    ItemsSource="{x:Static datas:DesignTimeDatas.DisplayPositions}"
                                    ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                    SelectedItem="{Binding CurrentPosition}"
                                    SelectionMode="Single" />
                                <!--  現在時刻顏色  -->
                                <ListBox
                                    VerticalAlignment="Center"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel3}"
                                    ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                    SelectedItem="{Binding CurrentColor}"
                                    SelectionMode="Single">
                                    <ListBox.Items>
                                        <system:String>Red</system:String>
                                        <system:String>Orange</system:String>
                                        <system:String>Green</system:String>
                                    </ListBox.Items>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <RadioButton Background="{Binding}">
                                                <RadioButton.Style>
                                                    <Style BasedOn="{StaticResource CMFT.RadioButton.ColorButton}" TargetType="{x:Type RadioButton}">
                                                        <Setter Property="Opacity" Value="0.2" />
                                                        <Setter Property="IsChecked">
                                                            <Setter.Value>
                                                                <Binding
                                                                    Mode="TwoWay"
                                                                    Path="IsSelected"
                                                                    RelativeSource="{RelativeSource AncestorType=ListBoxItem}" />
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Opacity" Value="0.8" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </RadioButton.Style>
                                                <TextBlock Text=" " />
                                            </RadioButton>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <!--  換頁方式  -->
                                <ListBox
                                    VerticalAlignment="Center"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemTemplate="{StaticResource SettingRadioButtonData}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel3}"
                                    ItemsSource="{x:Static datas:DesignTimeDatas.MoveModes}"
                                    ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                    SelectedItem="{Binding MoveMode}"
                                    SelectionMode="Single" />
                                <!--  速度  -->
                                <ComboBox
                                    Padding="6"
                                    materialDesign:HintAssist.IsFloating="False"
                                    SelectedItem="{Binding MoveSpeed}"
                                    Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                    TextBlock.TextAlignment="Center" />
                                <!--  字型  -->
                                <ListBox
                                    VerticalAlignment="Center"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel3}"
                                    ItemsSource="{x:Static datas:DesignTimeDatas.FontTypes}"
                                    ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                    SelectedItem="{Binding FontType}"
                                    SelectionMode="Single">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <RadioButton>
                                                <RadioButton.Style>
                                                    <Style BasedOn="{StaticResource WPF.RadioButton.ButtonLike}" TargetType="{x:Type RadioButton}">
                                                        <Setter Property="Padding" Value="6" />
                                                        <Setter Property="IsChecked">
                                                            <Setter.Value>
                                                                <Binding
                                                                    Mode="TwoWay"
                                                                    Path="IsSelected"
                                                                    RelativeSource="{RelativeSource AncestorType=ListBoxItem}" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </RadioButton.Style>
                                                <TextBlock FontFamily="{Binding Converter={converters:EnumToStringConverter}}" Text="{Binding}" />
                                            </RadioButton>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <ComboBox
                                    Padding="6"
                                    materialDesign:HintAssist.IsFloating="False"
                                    SelectedIndex="60"
                                    Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                    TextBlock.TextAlignment="Center" />
                            </UniformGrid>
                        </Grid>

                        <UniformGrid
                            Grid.Row="1"
                            Margin="0,10,0,0"
                            VerticalAlignment="Stretch"
                            Columns="1">
                            <UniformGrid.Resources>
                                <Style TargetType="TextBox">
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Stretch" />
                                </Style>
                                <Style TargetType="UniformGrid" />
                            </UniformGrid.Resources>
                            <!--  模式1  -->
                            <UniformGrid Margin="0,0,0,5" Columns="2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <TextBox Grid.Row="0" Text="上行訊息" />
                                    <TextBox Grid.Row="1" Text="下行訊息" />
                                </Grid>
                                <TextBox Text="政令宣導" />
                            </UniformGrid>
                            <!--  模式2  -->
                            <UniformGrid Margin="0,0,0,5" Columns="2">
                                <TextBox Text="政令宣導" />
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition />
                                        <RowDefinition />
                                    </Grid.RowDefinitions>
                                    <TextBox Grid.Row="0" Text="上行訊息" />
                                    <TextBox Grid.Row="1" Text="下行訊息" />
                                </Grid>
                            </UniformGrid>
                            <!--  模式3  -->
                            <UniformGrid Margin="0,0,0,5" Columns="2">
                                <TextBox Text="政令宣導" />
                                <TextBox Text="政令宣導" />
                            </UniformGrid>
                            <!--  模式4  -->
                            <UniformGrid Margin="0,0,0,5" Columns="2">
                                <TextBox Text="上行訊息" />
                                <TextBox Text="下行訊息" />
                            </UniformGrid>
                        </UniformGrid>
                    </Grid>

                </GroupBox>
                <GroupBox Grid.Column="1" Header="PDU設定">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <UniformGrid
                                Grid.Column="0"
                                VerticalAlignment="Stretch"
                                Columns="1">
                                <TextBlock Text="現在時刻位置" />
                                <TextBlock Text="現在時刻顏色" />
                                <TextBlock Text="換頁方式" />
                                <TextBlock Text="換頁速度" />
                                <TextBlock Text="字型" />
                                <TextBlock Text="顯示模式" />
                            </UniformGrid>
                            <UniformGrid
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Columns="1"
                                DataContext="{Binding SelectedItem.PDUSetting, ElementName=DMDDisplayModeListBox}">
                                <!--  現在時刻位置  -->
                                <ListBox
                                    VerticalAlignment="Center"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemTemplate="{StaticResource SettingRadioButtonData}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel3}"
                                    ItemsSource="{x:Static datas:DesignTimeDatas.DisplayPositions}"
                                    ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                    SelectedItem="{Binding CurrentPosition}"
                                    SelectionMode="Single" />
                                <!--  現在時刻顏色  -->
                                <ListBox
                                    VerticalAlignment="Center"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel3}"
                                    ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                    SelectedItem="{Binding CurrentColor}"
                                    SelectionMode="Single">
                                    <ListBox.Items>
                                        <system:String>Red</system:String>
                                        <system:String>Orange</system:String>
                                        <system:String>Green</system:String>
                                    </ListBox.Items>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <RadioButton Background="{Binding}">
                                                <RadioButton.Style>
                                                    <Style BasedOn="{StaticResource CMFT.RadioButton.ColorButton}" TargetType="{x:Type RadioButton}">
                                                        <Setter Property="Opacity" Value="0.2" />
                                                        <Setter Property="IsChecked">
                                                            <Setter.Value>
                                                                <Binding
                                                                    Mode="TwoWay"
                                                                    Path="IsSelected"
                                                                    RelativeSource="{RelativeSource AncestorType=ListBoxItem}" />
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Opacity" Value="0.8" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </RadioButton.Style>
                                                <TextBlock Text=" " />
                                            </RadioButton>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <!--  換頁方式  -->
                                <ListBox
                                    VerticalAlignment="Center"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemTemplate="{StaticResource SettingRadioButtonData}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel3}"
                                    ItemsSource="{x:Static datas:DesignTimeDatas.MoveModes}"
                                    ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                    SelectedItem="{Binding MoveMode}"
                                    SelectionMode="Single" />
                                <!--  速度  -->
                                <ComboBox
                                    Padding="6"
                                    materialDesign:HintAssist.IsFloating="False"
                                    SelectedItem="{Binding MoveSpeed}"
                                    Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                    TextBlock.TextAlignment="Center" />
                                <!--  字型  -->
                                <ListBox
                                    VerticalAlignment="Center"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel3}"
                                    ItemsSource="{x:Static datas:DesignTimeDatas.FontTypes}"
                                    ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                    SelectedItem="{Binding FontType}"
                                    SelectionMode="Single">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <RadioButton>
                                                <RadioButton.Style>
                                                    <Style BasedOn="{StaticResource WPF.RadioButton.ButtonLike}" TargetType="{x:Type RadioButton}">
                                                        <Setter Property="Padding" Value="6" />
                                                        <Setter Property="IsChecked">
                                                            <Setter.Value>
                                                                <Binding
                                                                    Mode="TwoWay"
                                                                    Path="IsSelected"
                                                                    RelativeSource="{RelativeSource AncestorType=ListBoxItem}" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </RadioButton.Style>
                                                <TextBlock FontFamily="{Binding Converter={converters:EnumToStringConverter}}" Text="{Binding}" />
                                            </RadioButton>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <ComboBox
                                    Padding="6"
                                    materialDesign:HintAssist.IsFloating="False"
                                    SelectedIndex="60"
                                    Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                    TextBlock.TextAlignment="Center" />
                            </UniformGrid>
                        </Grid>
                        <Grid
                            Grid.Row="1"
                            Margin="0,10,0,0"
                            VerticalAlignment="Stretch">
                            <Grid.Resources>
                                <Style TargetType="TextBox">
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                                    <Setter Property="VerticalAlignment" Value="Stretch" />
                                </Style>
                                <Style TargetType="UniformGrid" />
                            </Grid.Resources>

                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <UniformGrid
                                Grid.Row="0"
                                Margin="0,0,0,5"
                                Columns="2">
                                <TextBox Text="上行訊息" />
                                <TextBox Text="下行訊息" />
                            </UniformGrid>

                            <UniformGrid
                                Grid.Column="0"
                                Margin="5,0"
                                Columns="1">
                                <TextBlock Text="模式4" />
                            </UniformGrid>
                            <UniformGrid Grid.Column="1" Columns="1" />

                        </Grid>
                    </Grid>
                </GroupBox>
            </Grid>

            <Grid
                Grid.Column="1"
                Style="{StaticResource GridMargin5}"
                Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3.5*" />
                    <RowDefinition Height="3.5*" />
                    <RowDefinition Height="1.5*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <!--  CDU 設定  -->
                <GroupBox
                    Grid.Row="0"
                    Grid.RowSpan="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="2"
                    Padding="6"
                    Header="CDU 設定">
                    <UniformGrid
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Columns="2"
                        Rows="1">
                        <!--  左側：第一個 StackPanel  -->
                        <StackPanel Margin="0,0,5,0">
                            <CheckBox
                                Margin="0,0,0,12"
                                Content="CDU_1 是否兩行"
                                IsChecked="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="第一行顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="第二行顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="左上角顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="右上角顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="左下角顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="右下角顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                        </StackPanel>
                        <!--  右側：第二個 StackPanel  -->
                        <StackPanel Margin="5,0,0,0">
                            <CheckBox
                                Margin="0,0,0,12"
                                Content="CDU_2 是否兩行"
                                IsChecked="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="第一行顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="第二行顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="左上角顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="右上角顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="左下角顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="右下角顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                        </StackPanel>
                    </UniformGrid>
                </GroupBox>
                <StackPanel
                    Grid.Row="0"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Vertical">
                    <Button
                        Width="140"
                        Margin="0,0,0,15"
                        Padding="6,4"
                        FontSize="16"
                        Style="{StaticResource WPF.Button}">
                        <TextBlock Text="CDU左右交換" TextAlignment="Center" />
                    </Button>
                    <Button
                        Width="140"
                        Margin="0,0,0,15"
                        Padding="6,4"
                        FontSize="16"
                        Style="{StaticResource WPF.Button}">
                        <TextBlock
                            Text="套用此CDU設定至全線車站"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                    </Button>
                    <Button
                        Width="140"
                        Padding="6,4"
                        FontSize="16"
                        Style="{StaticResource WPF.Button}">
                        <TextBlock
                            Text="套用此CDU設定至特定車站"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                    </Button>
                </StackPanel>
                <!--  PDU 設定  -->
                <GroupBox
                    Grid.Row="0"
                    Grid.Column="3"
                    Grid.ColumnSpan="2"
                    Margin="2"
                    Padding="6"
                    Header="PDU 設定">
                    <UniformGrid
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Columns="2"
                        Rows="1">
                        <!--  左側：第一個 StackPanel  -->
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock FontSize="12" Text="上行PDU" />
                            <TextBlock HorizontalAlignment="Center" Text="主顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="左邊顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="右邊顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                        </StackPanel>
                        <!--  右側：第二個 StackPanel  -->
                        <StackPanel Margin="5,0,0,0">
                            <TextBlock FontSize="12" Text="下行PDU" />
                            <TextBlock HorizontalAlignment="Center" Text="主顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="左邊顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="右邊顯示訊息種類" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                        </StackPanel>
                    </UniformGrid>
                </GroupBox>
                <StackPanel
                    Grid.Row="0"
                    Grid.Column="5"
                    VerticalAlignment="Center"
                    Orientation="Vertical">
                    <Button
                        Width="140"
                        Margin="0,0,0,15"
                        Padding="6,4"
                        FontSize="16"
                        Style="{StaticResource WPF.Button}">
                        <TextBlock
                            Text="套用此PDU設定至全線車站"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                    </Button>

                    <Button
                        Width="140"
                        Padding="6,4"
                        FontSize="16"
                        Style="{StaticResource WPF.Button}">
                        <TextBlock
                            Text="套用此PDU設定至特定車站"
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                    </Button>
                </StackPanel>
                <!--  車站CDU與PDU共同設定  -->
                <GroupBox
                    Grid.Row="1"
                    Grid.Column="2"
                    Grid.ColumnSpan="3"
                    Margin="2"
                    Padding="6"
                    Header="車站CDU與PDU共同設定">
                    <UniformGrid
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Top"
                        Columns="3"
                        Rows="1">
                        <!--  左：第一個 StackPanel  -->
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock HorizontalAlignment="Center" Text="現在時刻顏色" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="速度" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="ATS預計進站秒數" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                        </StackPanel>
                        <!--  中：第二個 StackPanel  -->
                        <StackPanel Margin="2.5,0,2.5,0">
                            <TextBlock HorizontalAlignment="Center" Text="月台碼顏色" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                            <TextBlock HorizontalAlignment="Center" Text="字型" />
                            <ComboBox ItemsSource="{x:Null}" SelectedItem="{x:Null}" />
                        </StackPanel>
                        <!--  右：第三個 StackPanel  -->
