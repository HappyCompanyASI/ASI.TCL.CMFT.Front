        <ListView
            Grid.Column="1"
            ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
            ItemsSource="{Binding DMDATSMessagesView}"
            SelectedItem="{Binding SelectedMessage}"
            SelectionMode="Single">
            <!--  IsHitTestVisible在ListView.GridViewItem.Stretch  -->
            <!--<Style BasedOn="{StaticResource MaterialDesignGridViewItem}" TargetType="{x:Type ListViewItem}">
              <Setter Property="IsHitTestVisible" Value="{Binding Source={StaticResource StaticData}, Path=IsEditMode}" />
          </Style>-->
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:DMDATSMessageDto}">
                                <TextBlock
                                    Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                    Text="{Binding Header}"
                                    TextWrapping="Wrap" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                        <GridViewColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </GridViewColumn.HeaderTemplate>
                    </GridViewColumn>

                    <GridViewColumn
                        Width="300"
                        Header="CDU"
                        HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:DMDATSMessageDto}">
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <TextBox
                                        x:Name="CDUTextBox"
                                        Style="{StaticResource GridView.Column.TextBox.Stretch}"
                                        Text="{Binding CDU}"
                                        TextWrapping="Wrap"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="CDUTextBlock"
                                        Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                        Text="{Binding CDU}"
                                        TextWrapping="Wrap"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="CDUTextBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="CDUTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn
                        Width="300"
                        Header="PDU"
                        HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:DMDATSMessageDto}">
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <TextBox
                                        x:Name="PDUTextBox"
                                        Style="{StaticResource GridView.Column.TextBox.Stretch}"
                                        Text="{Binding PDU}"
                                        TextWrapping="Wrap"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="PDUTextBlock"
                                        Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                        Text="{Binding PDU}"
                                        TextWrapping="Wrap"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="PDUTextBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="PDUTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <UniformGrid
            Grid.Column="2"
            VerticalAlignment="Top"
            IsHitTestVisible="{Binding IsEditMode}"
            Style="{StaticResource UniformGridMargin5}">
            <ComboBox
                materialDesign:HintAssist.Hint="進站倒數1"
                FontSize="16"
                ItemsSource="{x:Static datas:DesignTimeDatas.Numbers}"
                SelectedItem="{Binding IntervalConfig.StationArrival1, Mode=TwoWay}"
                Style="{StaticResource MaterialDesignFilledComboBox}"
                Tag="StationArrival1"
                TextBlock.TextAlignment="Center">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <b:InvokeCommandAction Command="{Binding IntervalSelectionChangedCommand}" PassEventArgsToCommand="True" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </ComboBox>
            <ComboBox
                materialDesign:HintAssist.Hint="進站倒數2"
                FontSize="16"
                ItemsSource="{x:Static datas:DesignTimeDatas.Numbers}"
                SelectedItem="{Binding IntervalConfig.StationArrival2, Mode=TwoWay}"
                Style="{StaticResource MaterialDesignFilledComboBox}"
                Tag="StationArrival2"
                TextBlock.TextAlignment="Center">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <b:InvokeCommandAction Command="{Binding IntervalSelectionChangedCommand}" PassEventArgsToCommand="True" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </ComboBox>
            <ComboBox
                materialDesign:HintAssist.Hint="間隔顯示1"
                FontSize="16"
                ItemsSource="{x:Static datas:DesignTimeDatas.Numbers}"
                SelectedItem="{Binding IntervalConfig.IntervalDisplay1, Mode=TwoWay}"
                Style="{StaticResource MaterialDesignFilledComboBox}"
                Tag="IntervalDisplay1"
                TextBlock.TextAlignment="Center">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <b:InvokeCommandAction Command="{Binding IntervalSelectionChangedCommand}" PassEventArgsToCommand="True" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </ComboBox>
            <ComboBox
                materialDesign:HintAssist.Hint="間隔顯示2"
                FontSize="16"
                ItemsSource="{x:Static datas:DesignTimeDatas.Numbers}"
                SelectedItem="{Binding IntervalConfig.IntervalDisplay2, Mode=TwoWay}"
                Style="{StaticResource MaterialDesignFilledComboBox}"
                Tag="IntervalDisplay2"
                TextBlock.TextAlignment="Center">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <b:InvokeCommandAction Command="{Binding IntervalSelectionChangedCommand}" PassEventArgsToCommand="True" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </ComboBox>
            <ComboBox
                materialDesign:HintAssist.Hint="間隔顯示3"
                FontSize="16"
                ItemsSource="{x:Static datas:DesignTimeDatas.Numbers}"
                SelectedItem="{Binding IntervalConfig.IntervalDisplay3, Mode=TwoWay}"
                Style="{StaticResource MaterialDesignFilledComboBox}"
                Tag="IntervalDisplay3"
                TextBlock.TextAlignment="Center">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <b:InvokeCommandAction Command="{Binding IntervalSelectionChangedCommand}" PassEventArgsToCommand="True" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </ComboBox>
        </UniformGrid>
        <UniformGrid
            Grid.Column="3"
            Margin="0,3"
            VerticalAlignment="Top"
            Columns="1"
            Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}">

            <Button Style="{StaticResource WPF.Button}">
                <TextBlock
                    FontSize="14"
                    Text="回復預設值"
                    TextWrapping="Wrap" />
            </Button>
            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="快速組件" />
            <Button
                Content="終點站"
                FontSize="14"
                Style="{StaticResource WPF.Button}" />
            <Button
                Content="下一站"
                FontSize="14"
                Style="{StaticResource WPF.Button}" />
            <Button
                Content="目前位置"
                FontSize="14"
                Style="{StaticResource WPF.Button}" />
            <Button
                Content="捷運線"
                FontSize="14"
                Style="{StaticResource WPF.Button}" />
            <Button
                Content="月台號碼"
                FontSize="14"
                Style="{StaticResource WPF.Button}" />
            <Button
                Content="倒數時間"
                FontSize="14"
                Style="{StaticResource WPF.Button}" />
            <Button
                Content="到站時間"
                FontSize="14"
                Style="{StaticResource WPF.Button}" />
            <Button
                Content="離站時間"
                FontSize="14"
                Style="{StaticResource WPF.Button}" />
            <Button
                Content="現在時刻"
                FontSize="14"
                Style="{StaticResource WPF.Button}" />
        </UniformGrid>
        <UniformGrid
            Grid.Column="3"
            VerticalAlignment="Bottom"
            Columns="1"
            Style="{StaticResource PanelMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}" />
        </UniformGrid>
    </Grid>

</UserControl>
