<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.DMD.Views.DMDTrainMessageSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataTypes="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.DataTypes"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:triggerActions="clr-namespace:ASI.TCL.CMFT.WPF.TriggerActions;assembly=ASI.TCL.CMFT.WPF"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:DMDTrainMessageSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition x:Name="GridCol" Width="8*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TreeView Grid.Column="0" FontSize="14">
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="SelectedItemChanged">
                    <b:InvokeCommandAction Command="{Binding Path=SelectionChangedCommand}" CommandParameter="{Binding Path=SelectedItem.Tag, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type TreeView}, AncestorLevel=1}}" />
                </b:EventTrigger>
            </b:Interaction.Triggers>
            <TreeView.Resources>
                <Style BasedOn="{StaticResource MaterialDesignTreeViewItem}" TargetType="{x:Type TreeViewItem}">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="-5,0,0,0" />
                    <Setter Property="IsExpanded" Value="True" />
                </Style>
            </TreeView.Resources>
            <TreeViewItem Header="雙線雙向">

                <TreeViewItem Header="一般車">
                    <TreeViewItem
                        Header="中間站"
                        IsSelected="True"
                        Tag="{x:Static dataTypes:eATSType.雙線雙向_一般車_中間站}" />
                    <TreeViewItem Header="終點站" Tag="{x:Static dataTypes:eATSType.雙線雙向_一般車_終點站}" />
                </TreeViewItem>

                <TreeViewItem Header="末班車">
                    <TreeViewItem Header="中間站 " Tag="{x:Static dataTypes:eATSType.雙線雙向_末班車_中間站}" />
                    <TreeViewItem Header="終點站 " Tag="{x:Static dataTypes:eATSType.雙線雙向_末班車_終點站}" />
                </TreeViewItem>

                <TreeViewItem Header="不停靠">
                    <TreeViewItem Header="中間站 " Tag="{x:Static dataTypes:eATSType.雙線雙向_不停靠_中間站}" />
                    <TreeViewItem Header="終點站 " Tag="{x:Static dataTypes:eATSType.雙線雙向_不停靠_終點站}" />
                </TreeViewItem>
                <TreeViewItem Header="不載客">
                    <TreeViewItem Header="中間站 " Tag="{x:Static dataTypes:eATSType.雙線雙向_不載客_中間站}" />
                    <TreeViewItem Header="終點站 " Tag="{x:Static dataTypes:eATSType.雙線雙向_不載客_終點站}" />
                </TreeViewItem>
                <TreeViewItem Header="不停靠不載客">
                    <TreeViewItem Header="中間站 " Tag="{x:Static dataTypes:eATSType.雙線雙向_不停靠不載客_中間站}" />
                    <TreeViewItem Header="終點站 " Tag="{x:Static dataTypes:eATSType.雙線雙向_不停靠不載客_終點站}" />
                </TreeViewItem>
            </TreeViewItem>
            <TreeViewItem Header="單線雙向">
                <TreeViewItem Header="一般車 ">
                    <TreeViewItem Header="中間站 " Tag="{x:Static dataTypes:eATSType.單線雙向_一般車_中間站}" />
                    <TreeViewItem Header="終點站 " Tag="{x:Static dataTypes:eATSType.單線雙向_一般車_終點站}" />
                </TreeViewItem>
                <TreeViewItem Header="末班車">
                    <TreeViewItem Header="中間站 " Tag="{x:Static dataTypes:eATSType.單線雙向_末班車_中間站}" />
                    <TreeViewItem Header="終點站 " Tag="{x:Static dataTypes:eATSType.單線雙向_末班車_終點站}" />
                </TreeViewItem>
                <TreeViewItem Header="不停靠">
                    <TreeViewItem Header="中間站 " Tag="{x:Static dataTypes:eATSType.單線雙向_不停靠_中間站}" />
                    <TreeViewItem Header="終點站 " Tag="{x:Static dataTypes:eATSType.單線雙向_不停靠_終點站}" />
                </TreeViewItem>
                <TreeViewItem Header="不載客">
                    <TreeViewItem Header="中間站 " Tag="{x:Static dataTypes:eATSType.單線雙向_不載客_中間站}" />
                    <TreeViewItem Header="終點站 " Tag="{x:Static dataTypes:eATSType.單線雙向_不載客_終點站}" />
                </TreeViewItem>
                <TreeViewItem Header="不停靠不載客">
                    <TreeViewItem Header="中間站 " Tag="{x:Static dataTypes:eATSType.單線雙向_不停靠不載客_中間站}" />
                    <TreeViewItem Header="終點站 " Tag="{x:Static dataTypes:eATSType.單線雙向_不停靠不載客_終點站}" />
                </TreeViewItem>
            </TreeViewItem>
            <TreeViewItem Header="列車已停靠月台">
                <TreeViewItem Header="起始站 ">
                    <TreeViewItem Header="二輛列車已停靠月台" Tag="{x:Static dataTypes:eATSType.列車已停靠月台_起始站_二輛列車已停靠月台}" />
                    <TreeViewItem Header="一輛列車已停靠月台" Tag="{x:Static dataTypes:eATSType.列車已停靠月台_起始站_一輛列車已停靠月台}" />
                </TreeViewItem>
                <TreeViewItem Header="非起始站" Tag="{x:Static dataTypes:eATSType.列車已停靠月台非起始站}" />
            </TreeViewItem>
            <TreeViewItem Header="月台未開放" Tag="{x:Static dataTypes:eATSType.月台未開放}" />
            <TreeViewItem Header="列車停靠異常" Tag="{x:Static dataTypes:eATSType.列車停靠異常}" />
            <TreeViewItem Header="月台狀態異常 " Tag="{x:Static dataTypes:eATSType.月台狀態異常}" />
            <TreeViewItem Header="列車狀態異常" Tag="{x:Static dataTypes:eATSType.列車狀態異常}" />
        </TreeView>

        <!--  初始寫法 已棄用  -->
