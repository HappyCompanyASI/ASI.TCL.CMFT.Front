<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.DMD.Views.DMDScheduleSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataTypes="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.DataTypes"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:triggerActions="clr-namespace:ASI.TCL.CMFT.WPF.TriggerActions;assembly=ASI.TCL.CMFT.WPF"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:DMDScheduleSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <!--
            瀏覽狀態下
            可以看到今日排程跟前妻日排程預覽
            可以點選星期
        -->
        <!--  不給選擇 IsHitTestVisible="False"  -->
        <!--  編輯狀態才可以選擇 IsHitTestVisible="{Binding Source={StaticResource StaticData}, Path=IsEditMode}"  -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="2.5*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <GroupBox
                Grid.Column="0"
                Margin="10"
                Header="樣板清單"
                IsHitTestVisible="True"
                Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ListBox
                    ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                    ItemsSource="{Binding DMDScheduleTemplates}"
                    ScrollViewer.VerticalScrollBarVisibility="Visible"
                    SelectedIndex="0"
                    SelectedItem="{Binding SelectedTemplate}"
                    SelectionMode="Single">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type dtos:DMDScheduleTemplateDto}">
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding ScheduleName}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <UniformGrid Grid.Column="1" Rows="2">
                <Button
                    x:Name="AddScheduleTemplate"
                    VerticalAlignment="Center"
                    Command="{Binding AddScheduleTemplateCommand}"
                    Style="{StaticResource WPF.Button}"
                    Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <materialDesign:PackIcon
                        Width="20"
                        Height="20"
                        Margin="10"
                        Kind="ArrowRightBold" />
                </Button>
                <Button
                    x:Name="DeleteScheduleTemplate"
                    VerticalAlignment="Center"
                    Command="{Binding DeleteScheduleTemplateCommand}"
                    Style="{StaticResource WPF.Button}"
                    Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <materialDesign:PackIcon
                        Width="20"
                        Height="20"
                        Margin="10"
                        Kind="ArrowLeftBold" />
                </Button>
            </UniformGrid>


            <GroupBox
                Grid.Column="2"
                Margin="10"
                Header="今日排程"
                IsHitTestVisible="True">
                <ListBox
                    IsHitTestVisible="{Binding IsEditMode}"
                    ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                    ItemsSource="{Binding DMDSchedules}"
                    ScrollViewer.VerticalScrollBarVisibility="Visible"
                    SelectedItem="{Binding SelectedSchedule}"
                    SelectionMode="Single">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type dtos:DMDScheduleTemplateDto}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding StartTime, StringFormat={}{0:HH:mm}}" />
                                    <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="~" />
                                    <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding EndTime, StringFormat={}{0:HH:mm}}" />
                                    <TextBlock
                                        Width="100"
                                        Style="{StaticResource CMFT.TextBlock.Center}"
                                        Text="{Binding Content.BelongGroup.GroupName}"
                                        TextAlignment="Center" />
                                    <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding Content.MessageName}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </GroupBox>

            <Button
                x:Name="ApplyDaySchedules"
                Grid.Column="3"
                VerticalAlignment="Center"
                Command="{Binding ApplyDaySchedulesCommand}"
                Style="{StaticResource WPF.Button}"
                Visibility="{Binding IsEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                <materialDesign:PackIcon
                    Width="20"
                    Height="20"
                    Margin="10"
                    Kind="ArrowLeftBold" />
            </Button>

            <GroupBox
                Grid.Column="4"
                Margin="10"
                Header="前七日排程預覽"
                IsHitTestVisible="True">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <ListBox
                        Grid.Column="0"
                        VerticalAlignment="Top"
                        ItemContainerStyle="{StaticResource StretchListBoxItem}"
                        ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                        ItemsSource="{Binding DMDDaySchedules}"
                        SelectedItem="{Binding SelectedDaySchedule, Mode=TwoWay}"
                        SelectionMode="Single"
                        Style="{StaticResource MaterialDesignListBox}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type dtos:DMDDayScheduleDto}">
                                <RadioButton
                                    Content="{Binding DayDisplay}"
                                    GroupName="WeekDays"
                                    IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected, Mode=TwoWay}"
                                    Style="{StaticResource SelecterRadioButton}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ListBox
                        Grid.Column="1"
                        IsHitTestVisible="False"
                        ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                        ItemsSource="{Binding SelectedDaySchedule.Templates}"
                        ScrollViewer.VerticalScrollBarVisibility="Visible"
                        SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type dtos:DMDScheduleTemplateDto}">
                                <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding ScheduleName}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </Grid>

            </GroupBox>

        </Grid>

        <UniformGrid
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Style="{StaticResource UniformGridMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}" />
        </UniformGrid>
    </Grid>
</UserControl>
