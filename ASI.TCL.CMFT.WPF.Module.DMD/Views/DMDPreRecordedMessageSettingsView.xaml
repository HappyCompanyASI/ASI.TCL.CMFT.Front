<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.DMD.Views.DMDPreRecordedMessageSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.Dtos"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.DMD.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:DMDPreRecordedMessageSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>
            <ListBox
                x:Name="MessageGroupListBox"
                Grid.Column="0"
                ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                ItemsSource="{Binding DMDMessageGroups}"
                ScrollViewer.VerticalScrollBarVisibility="Visible"
                SelectedIndex="0"
                SelectedItem="{Binding SelectedMessageGroup, Mode=TwoWay}"
                SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type dtos:DMDMessageGroupDto}">
                        <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding GroupName}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="GotFocus">
                        <prism:InvokeCommandAction Command="{Binding ClearSelectedMessageCommand}" />
                    </b:EventTrigger>
                    <b:EventTrigger EventName="SelectionChanged">
                        <prism:InvokeCommandAction Command="{Binding GroupSelectionChangedCommand}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </ListBox>

            <ListView
                x:Name="MessageListView"
                Grid.Column="1"
                d:ItemsSource="{x:Static datas:DesignTimeDatas.DMDPreRecordMessages}"
                ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
                ItemsSource="{Binding DMDPreRecordMessagesView}"
                SelectedItem="{Binding SelectedMessage}"
                SelectionMode="Single">
                <b:Interaction.Behaviors>
                    <!--  自訂Behavior來避免combobox的SelectionChanged事件bubble到ListViewItem  -->
                    <behaviors:ListViewSelectionChangedBehavior Command="{Binding CancelEditOnSelectionChangedCommand}" />
                </b:Interaction.Behaviors>
                <ListView.View>
                    <GridView>
                        <GridViewColumn
                            Width="160"
                            Header="訊息名稱"
                            HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Left}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:DMDPreRecordMessageDto}">
                                    <Grid>
                                        <!--  TextBox 編輯  -->
                                        <TextBox
                                            x:Name="NameTextBox"
                                            Text="{Binding MessageName}"
                                            TextWrapping="Wrap"
                                            Visibility="Collapsed" />
                                        <!--  TextBlock 檢視  -->
                                        <TextBlock
                                            x:Name="NameTextBlock"
                                            Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                            Text="{Binding MessageName}"
                                            TextWrapping="Wrap"
                                            Visibility="Visible" />
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="NameTextBox" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="NameTextBlock" Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn
                            Width="500"
                            Header="訊息內容"
                            HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Left}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:DMDPreRecordMessageDto}">
                                    <Grid>
                                        <!--  TextBox 編輯  -->
                                        <TextBox
                                            x:Name="ContentTextBox"
                                            Style="{StaticResource GridView.Column.TextBox.Stretch}"
                                            Text="{Binding MessageContent}"
                                            TextWrapping="Wrap"
                                            Visibility="Collapsed" />
                                        <!--  TextBlock 檢視  -->
                                        <TextBlock
                                            x:Name="ContentTextBlock"
                                            VerticalAlignment="Center"
                                            Text="{Binding MessageContent}"
                                            TextWrapping="Wrap"
                                            Visibility="Visible" />
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="ContentTextBox" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="ContentTextBlock" Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn
                            Width="150"
                            Header="預錄群組"
                            HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:DMDPreRecordMessageDto}">
                                    <Grid>
                                        <!--  ComboBox 編輯  -->
                                        <ComboBox
                                            x:Name="GroupComboBox"
                                            DisplayMemberPath="GroupName"
                                            ItemsSource="{Binding DataContext.EditableGroups, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            SelectedItem="{Binding BelongGroup, NotifyOnSourceUpdated=False}"
                                            Style="{StaticResource GridView.Column.ComboBox.Center}"
                                            Visibility="Collapsed" />
                                        <!--  TextBlock 檢視  -->
                                        <TextBlock
                                            x:Name="GroupTextBlock"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Text="{Binding BelongGroup.GroupName}"
                                            Visibility="Visible" />
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="GroupComboBox" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="GroupTextBlock" Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn
                            Width="90"
                            Header="DU"
                            HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <!--  TextBox 編輯  -->
                                        <CheckBox
                                            x:Name="IsUseDUCheckBox"
                                            HorizontalAlignment="Center"
                                            IsChecked="{Binding IsUseDU}"
                                            Visibility="Collapsed" />
                                        <!--  TextBlock 檢視  -->
                                        <TextBlock
                                            x:Name="IsUseDUTextBlock"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <!--  預設顯示 "關閉"  -->
                                                    <Setter Property="Text" Value="關閉" />
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <!--  IsUseDU 為 true 時顯示 "啟用"  -->
                                                        <DataTrigger Binding="{Binding IsUseDU}" Value="True">
                                                            <Setter Property="Text" Value="啟用" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="IsUseDUCheckBox" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="IsUseDUTextBlock" Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <UniformGrid
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Style="{StaticResource UniformGridMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding AddGroupCommand}"
                ContentTemplate="{StaticResource AddGroupData}"
                Style="{StaticResource AddButton}"
                Visibility="{Binding IsGroupOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding DeleteGroupCommand}"
                ContentTemplate="{StaticResource DeleteGroupData}"
                Style="{StaticResource DeleteButton}"
                Visibility="{Binding IsGroupOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding AddItemCommand}"
                ContentTemplate="{StaticResource AddItemData}"
                Style="{StaticResource AddButton}"
                Visibility="{Binding CanAddItem, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding DeleteItemCommand}"
                ContentTemplate="{StaticResource DeleteItemData}"
                Style="{StaticResource DeleteButton}"
                Visibility="{Binding CanItemAddDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}"
                Visibility="{Binding IsItemOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </UniformGrid>
    </Grid>

</UserControl>
