<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.Auth.Views.UserInformationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.Auth.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:UserInformationViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="100"
    d:DesignWidth="300"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,10"
            FontSize="18"
            Style="{StaticResource CMFT.TextBlock.Center}"
            Text="{Binding CurrentDateTime}" />

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal">

            <TextBlock
                Margin="0,0,10,0"
                Style="{StaticResource CMFT.TextBlock.Left}"
                Text="{Binding UserName}" />

            <TextBlock
                Margin="0,0,10,0"
                Style="{StaticResource CMFT.TextBlock.Left}"
                Text="{Binding UserRole}" />

            <materialDesign:PopupBox
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                SnapsToDevicePixels="True">
                <materialDesign:PopupBox.ToggleContent>
                    <materialDesign:PackIcon
                        Width="20"
                        Height="20"
                        Foreground="{DynamicResource MaterialDesignBody}"
                        Kind="Power" />
                </materialDesign:PopupBox.ToggleContent>

                <Border>
                    <StackPanel
                        Margin="10,5"
                        VerticalAlignment="Center"
                        Orientation="Vertical">

                        <Button
                            HorizontalAlignment="Left"
                            Background="{x:Null}"
                            BorderThickness="0"
                            Command="{Binding LogoutCommand}"
                            Foreground="{DynamicResource MaterialDesignBody}"
                            Style="{StaticResource CMFT.ButtonBase}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon VerticalAlignment="Center" Kind="Logout" />
                                <TextBlock Text="  登出" />
                            </StackPanel>
                        </Button>

                        <Button
                            HorizontalAlignment="Left"
                            Background="{x:Null}"
                            BorderThickness="0"
                            Command="{Binding RestartCommand}"
                            Foreground="{DynamicResource MaterialDesignBody}"
                            Style="{StaticResource CMFT.ButtonBase}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon VerticalAlignment="Center" Kind="Restart" />
                                <TextBlock Text="  重啟" />
                            </StackPanel>
                        </Button>


                    </StackPanel>
                </Border>
            </materialDesign:PopupBox>

        </StackPanel>

    </Grid>
</UserControl>
