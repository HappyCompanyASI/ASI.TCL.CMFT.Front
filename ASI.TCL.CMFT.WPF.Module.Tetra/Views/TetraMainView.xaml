<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.Tetra.Views.TetraMainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.Tetra.Datas"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.Tetra.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:TetraMainViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="541"
    d:Width="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid Margin="250,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Button
            Grid.Column="0"
            Margin="10"
            CommandParameter="{x:Static datas:NavigatePath.TetraGroupCall}"
            Content="群組呼叫"
            Style="{DynamicResource NaviBigButton}" />
        <StackPanel
            Grid.Column="0"
            Margin="10,0,0,30"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Style="{StaticResource StackPanelVerticalMargin3}">
            <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="群組自動接聽" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="1. " />
                <TextBlock Text="65006[電力2]" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="2. " />
                <TextBlock Text="65006[正電2]" />
            </StackPanel>
        </StackPanel>


        <Button
            Grid.Column="1"
            Margin="10"
            CommandParameter="{x:Static datas:NavigatePath.TetraSingleCall}"
            Content="個別呼叫"
            Style="{DynamicResource NaviBigButton}" />
        <Button
            Grid.Column="2"
            Margin="10"
            CommandParameter="{x:Static datas:NavigatePath.TetraDial}"
            Content="撥號盤"
            Style="{DynamicResource NaviBigButton}" />

    </Grid>
</UserControl>
