<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.Tetra.Views.TetraDialView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:applications="clr-namespace:ASI.TCL.CMFT.WPF.Applications;assembly=ASI.TCL.CMFT.WPF"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Module.Tetra.Converters"
    xmlns:converters1="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataTypes="clr-namespace:ASI.TCL.CMFT.WPF.Module.Tetra.DataTypes"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.Tetra.Datas"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.Tetra.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:TetraDialViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="7*" />
        </Grid.ColumnDefinitions>

        <!--#region 操作流程-->
        <GroupBox
            Grid.RowSpan="3"
            Grid.Column="0"
            Margin="0,5"
            Header="操作流程"
            IsHitTestVisible="False">
            <Grid>
                <Grid.Resources>
                    <Style BasedOn="{StaticResource StepRadioButton}" TargetType="{x:Type ToggleButton}" />
                    <Style BasedOn="{StaticResource MainTitleTextBox}" TargetType="{x:Type TextBlock}" />
                </Grid.Resources>
                <UniformGrid VerticalAlignment="Top" Style="{StaticResource UniformGridMargin5}">
                    <ToggleButton Content="1.目標選擇" IsChecked="{Binding CurrentStep, Converter={converters:StepToIsCheckedConverter}, ConverterParameter={x:Static dataTypes:eStep.Step1}}" />
                    <ToggleButton Content="2.方式及內容選擇" IsChecked="{Binding CurrentStep, Converter={converters:StepToIsCheckedConverter}, ConverterParameter={x:Static dataTypes:eStep.Step2}}" />
                    <ToggleButton Content="3.開始播送" IsChecked="{Binding CurrentStep, Converter={converters:StepToIsCheckedConverter}, ConverterParameter={x:Static dataTypes:eStep.Step3}}" />
                </UniformGrid>
                <TextBlock Text="撥號盤" />
            </Grid>

        </GroupBox>
        <!--#endregion-->

        <UniformGrid Grid.Column="1" Columns="1">

            <!--#region 1.目標選擇-->
            <Grid
                d:Visibility="Visible"
                Style="{StaticResource GridMargin5}"
                Visibility="{Binding CurrentStep, Converter={converters1:EqualityToVisibilityConverter}, ConverterParameter={x:Static dataTypes:eStep.Step1}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="11*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <GroupBox Grid.Column="0" Header="目標">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBox
                            x:Name="TargetNumberTextBox"
                            Margin="3"
                            FontSize="36"
                            MaxLength="{Binding MaxDialNumberLength}"
                            Text="{Binding DialNumber}"
                            TextAlignment="Right" />
                        <UniformGrid Columns="3">
                            <UniformGrid.Resources>
                                <Style BasedOn="{StaticResource WPF.Button}" TargetType="{x:Type Button}">
                                    <Setter Property="FontSize" Value="36" />
                                    <Setter Property="Margin" Value="3" />
                                    <Setter Property="Padding" Value="32,8" />
                                    <Setter Property="Command" Value="{Binding NumberButtonCommand}" />
                                </Style>
                            </UniformGrid.Resources>
                            <Button CommandParameter="1" Content="1" />
                            <Button CommandParameter="2" Content="2" />
                            <Button CommandParameter="3" Content="3" />
                            <Button CommandParameter="4" Content="4" />
                            <Button CommandParameter="5" Content="5" />
                            <Button CommandParameter="6" Content="6" />
                            <Button CommandParameter="7" Content="7" />
                            <Button CommandParameter="8" Content="8" />
                            <Button CommandParameter="9" Content="9" />
                            <Button CommandParameter="*" Content="*" />
                            <Button CommandParameter="0" Content="0" />
                            <Button CommandParameter="#" Content="#" />
                        </UniformGrid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.Resources>
                                <Style BasedOn="{StaticResource WPF.Button}" TargetType="{x:Type Button}">
                                    <Setter Property="FontSize" Value="20" />
                                    <Setter Property="Margin" Value="3" />
                                    <Setter Property="Padding" Value="0,8" />
                                </Style>
                            </Grid.Resources>
                            <Button Grid.Column="0" Command="{Binding BackspaceCommand}">
                                <materialDesign:PackIcon
                                    Width="22"
                                    Height="22"
                                    Kind="BackspaceOutline" />
                            </Button>
                            <Button
                                Grid.Column="1"
                                Command="{Binding ClearCommand}"
                                Content="C" />

                        </Grid>

                    </StackPanel>



                </GroupBox>

                <UniformGrid Grid.Column="1" Columns="1">
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Top"
                        Command="{x:Static applications:WPFApplicationCommands.NavigateCommand}"
                        CommandParameter="{x:Static datas:NavigatePath.TetraMain}"
                        Content="取消"
                        Style="{StaticResource NaviStepButton}" />
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Bottom"
                        Command="{Binding StepChangeCommand}"
                        CommandParameter="{x:Static dataTypes:eStep.Step2}"
                        Content="下一步"
                        Style="{StaticResource StepButton}" />
                </UniformGrid>

            </Grid>
            <!--#endregion-->

            <!--#region 2.廣播方式及內容-->
            <Grid
                d:Visibility="Visible"
                Style="{StaticResource GridMargin5}"
                Visibility="{Binding CurrentStep, Converter={converters1:EqualityToVisibilityConverter}, ConverterParameter={x:Static dataTypes:eStep.Step2}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="7*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <GroupBox
                    Grid.Column="0"
                    Header="已選擇目標"
                    IsHitTestVisible="False">
                    <Button
                        VerticalAlignment="Top"
                        Content="{Binding Text, ElementName=TargetNumberTextBox}"
                        Style="{StaticResource WPF.Button}" />

                </GroupBox>
                <GroupBox Grid.Column="1" Header="方式及內容">
                    <TabControl x:Name="SendTypeTab">
                        <TabItem Header="語音">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="150"
                                    Height="150"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Kind="AlertOutline" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="45"
                                        Style="{StaticResource CMFT.TextBlock.Center}"
                                        Text="請按通訊按鈕" />
                                    <TextBlock
                                        FontSize="45"
                                        Style="{StaticResource CMFT.TextBlock.Center}"
                                        Text="開始建立通訊" />
                                </StackPanel>
                            </StackPanel>
                        </TabItem>
                        <TabItem Header="簡訊">

                            <GroupBox Margin="80,20" Header="訊息內容">

                                <StackPanel
                                    Margin="10,5"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource PanelMargin5}">


                                    <TextBox
                                        x:Name="Instant_MessageContentTextBox"
                                        Grid.Row="0"
                                        Height="250"
                                        VerticalAlignment="Stretch"
                                        VerticalContentAlignment="Top"
                                        materialDesign:HintAssist.Hint="請輸入即時訊息內容..."
                                        materialDesign:HintAssist.IsFloating="False"
                                        MaxLength="60"
                                        TextWrapping="Wrap" />

                                    <TextBlock
                                        Grid.Row="1"
                                        FontSize="18"
                                        Style="{StaticResource CMFT.TextBlock.Center}"
                                        Text="內容輸入後請按通訊開始傳送簡訊" />


                                </StackPanel>
                            </GroupBox>

                        </TabItem>
                    </TabControl>
                </GroupBox>
                <UniformGrid Grid.Column="2" Columns="1">
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Top"
                        Command="{Binding StepChangeCommand}"
                        CommandParameter="{x:Static dataTypes:eStep.Step1}"
                        Content="上一步"
                        Style="{StaticResource StepButton}" />
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Bottom"
                        Command="{Binding StepChangeCommand}"
                        CommandParameter="{x:Static dataTypes:eStep.Step3}"
                        Content="通訊"
                        Style="{StaticResource StepButton}" />
                </UniformGrid>
            </Grid>
            <!--#endregion-->

            <!--#region 3.開始撥放-->
            <Grid
                d:Visibility="Visible"
                Style="{StaticResource GridMargin5}"
                Visibility="{Binding CurrentStep, Converter={converters1:EqualityToVisibilityConverter}, ConverterParameter={x:Static dataTypes:eStep.Step3}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="11*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>


                <GroupBox Grid.Column="0" Header="開始通訊">
                    <TabControl d:SelectedIndex="1" SelectedIndex="{Binding SelectedIndex, ElementName=SendTypeTab}">
                        <!--  語音  -->
                        <TabItem Visibility="Collapsed">
                            <Grid>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon
                                            Width="150"
                                            Height="150"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Kind="AlertOutline" />
                                        <TextBlock
                                            FontSize="45"
                                            Style="{StaticResource CMFT.TextBlock.Center}"
                                            Text="Tetra通話已建立" />
                                    </StackPanel>
                                    <TextBlock
                                        FontSize="50"
                                        Foreground="{StaticResource CMFT.Brush.Red.Dark}"
                                        Style="{StaticResource CMFT.TextBlock.Center}"
                                        Text="請於下方無線電系統中操作" />
                                </StackPanel>
                                <materialDesign:PackIcon
                                    Width="80"
                                    Height="80"
                                    Margin="150,0,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    Foreground="{StaticResource CMFT.Brush.Red.Dark}"
                                    Kind="TriangleDown">
                                    <materialDesign:PackIcon.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                                    <DoubleAnimation
                                                        Storyboard.TargetProperty="Opacity"
                                                        From="1.0"
                                                        To="0.0"
                                                        Duration="0:0:1" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </materialDesign:PackIcon.Triggers>
                                </materialDesign:PackIcon>
                            </Grid>
                        </TabItem>
                        <!--  簡訊  -->
                        <TabItem Visibility="Collapsed">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="150"
                                    Height="150"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Kind="AlertOutline" />
                                <TextBlock
                                    FontSize="45"
                                    Style="{StaticResource CMFT.TextBlock.Center}"
                                    Text="簡訊已傳送完成" />
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </GroupBox>
                <UniformGrid Grid.Column="1" Columns="1">
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Bottom"
                        Command="{x:Static applications:WPFApplicationCommands.NavigateCommand}"
                        CommandParameter="{x:Static applications:WPFApplicationCommands.DefaultViewName}"
                        Content="結束"
                        Style="{StaticResource NaviStepButton}" />
                </UniformGrid>

            </Grid>
            <!--#endregion-->

        </UniformGrid>

    </Grid>
</UserControl>
