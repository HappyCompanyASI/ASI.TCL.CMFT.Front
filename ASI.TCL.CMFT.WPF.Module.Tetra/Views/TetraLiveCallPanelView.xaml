<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.Tetra.Views.TetraLiveCallPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters1="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.Tetra.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:TetraLiveCallPanelViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="7*" />
        </Grid.ColumnDefinitions>

        <ListBox
            x:Name="ChannelList"
            Grid.Column="0"
            AlternationCount="4"
            ItemsSource="{Binding ChannelList}"
            SelectedItem="{Binding SelectedChannel}"
            SelectionMode="Single">

            <!--  ListBox背景  -->
            <ListBox.Background>
                <VisualBrush>
                    <VisualBrush.Visual>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="1*" />
                            </Grid.RowDefinitions>

                            <Button
                                Grid.Row="0"
                                Opacity="0.3"
                                Style="{StaticResource SelecterButton}">
                                <TextBlock FontSize="14" Text="Channel1" />

                            </Button>

                            <Button
                                Grid.Row="1"
                                Opacity="0.3"
                                Style="{StaticResource SelecterButton}">

                                <TextBlock FontSize="14" Text="Channel 2" />

                            </Button>

                            <Button
                                Grid.Row="2"
                                Opacity="0.3"
                                Style="{StaticResource SelecterButton}">
                                <TextBlock FontSize="14" Text="Channel 3" />
                            </Button>

                            <Button
                                Grid.Row="3"
                                Opacity="0.3"
                                Style="{StaticResource SelecterButton}">
                                <TextBlock FontSize="14" Text="Channel 4" />
                            </Button>
                        </Grid>
                    </VisualBrush.Visual>
                </VisualBrush>
            </ListBox.Background>

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ListBox.ItemContainerStyle>
                <Style TargetType="{x:Type ListBoxItem}">
                    <Setter Property="Grid.Row" Value="{Binding RelativeSource={RelativeSource Self}, Path=(ItemsControl.AlternationIndex)}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                <ContentPresenter />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <RadioButton
                        Margin="2"
                        Padding="8,2"
                        GroupName="Properties"
                        Style="{StaticResource WPF.RadioButton.ButtonLike}">
                        <RadioButton.IsChecked>
                            <Binding
                                Mode="TwoWay"
                                Path="IsSelected"
                                RelativeSource="{RelativeSource AncestorType=ListBoxItem}" />
                        </RadioButton.IsChecked>
                        <StackPanel Orientation="Vertical">
                            <TextBlock FontWeight="Bold" Text="{Binding ChannelName}" />
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Text="[" />
                                <TextBlock Text="{Binding ChannelNumber}" />
                                <TextBlock Text="]" />
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Column="1" Margin="10,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SelectedItem, ElementName=ChannelList, Converter={converters1:IsNotNullConverter}}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="通訊 : " />
                    <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="{Binding SelectedItem.ChannelName, ElementName=ChannelList}" />

                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="[" />
                        <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="{Binding SelectedItem.ChannelNumber, ElementName=ChannelList}" />
                        <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="]" />
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <HeaderedItemsControl Grid.Column="0" ItemsSource="{Binding SelectedItem.Contents, ElementName=ChannelList}">
                        <HeaderedItemsControl.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Text="號碼/列車" />
                                <TextBlock
                                    Grid.Column="1"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    Text="狀態/通訊位置" />
                            </Grid>
                        </HeaderedItemsControl.Header>

                        <HeaderedItemsControl.Template>
                            <ControlTemplate TargetType="{x:Type HeaderedItemsControl}">
                                <Border>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition />
                                        </Grid.RowDefinitions>
                                        <ContentPresenter ContentSource="Header" />
                                        <Separator Grid.Row="1" />
                                        <ItemsPresenter Grid.Row="2" />
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </HeaderedItemsControl.Template>
                        <HeaderedItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="1" Background="LightGreen">
                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="1*" />

                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Foreground="Black"
                                            Text="{Binding NumberOrTrain}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Foreground="Black"
                                            Text="{Binding Detail}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </HeaderedItemsControl.ItemTemplate>
                    </HeaderedItemsControl>

                    <Button
                        Grid.Column="1"
                        Margin="5"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Command="{Binding EndCallCommand}"
                        Content="結束通訊"
                        Style="{StaticResource CMFT.Button}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
