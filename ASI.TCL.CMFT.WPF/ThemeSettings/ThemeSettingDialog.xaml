<UserControl x:Class="ASI.TCL.CMFT.WPF.ThemeSettings.ThemeSettingDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters"
             xmlns:assist="clr-namespace:ASI.TCL.CMFT.WPF.Assist"
             xmlns:customControl="clr-namespace:ASI.TCL.CMFT.WPF.CustomControl"
             xmlns:dialogs="clr-namespace:ASI.TCL.CMFT.WPF.Dialogs"
             xmlns:themeSettings="clr-namespace:ASI.TCL.CMFT.WPF.ThemeSettings"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DataContext="{d:DesignInstance Type=themeSettings:ThemeSettingDialogViewModel,
                                              IsDesignTimeCreatable=True}"
             Style="{StaticResource Dialog}"
             mc:Ignorable="d">

    <StackPanel>
        <ContentControl Content="主題設定" Style="{StaticResource DialogHeader}" />
        <FrameworkElement x:Name="DataContextProxy" DataContext="{Binding}" />

        <Grid Height="800" Style="{StaticResource GridMargin5}">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Style="{StaticResource StackPanelVerticalMargin5}">
                <!--  BaseTheme  -->
                <StackPanel Style="{StaticResource StackPanelVerticalMargin5}">
                    <TextBlock FontSize="18"
                               Style="{StaticResource CMFT.TextBlock.Left}"
                               Text="BaseTheme" />
                    <StackPanel Width="400"
                                Margin="20,0"
                                Style="{StaticResource StackPanelHorizontalMargin5}">
                        <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="Light" />
                        <ToggleButton Margin="8,0"
                                      Command="{Binding ChangeBaseThemeCommand}"
                                      CommandParameter="{Binding IsChecked, RelativeSource={RelativeSource Mode=Self}}"
                                      IsChecked="{Binding SelectedSettings.BaseTheme, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, Converter={converters:EqualityToBoolConverter}, ConverterParameter={x:Static materialDesign:BaseTheme.Dark}}" />
                        <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="Dark" />
                    </StackPanel>

                </StackPanel>

                <!--  Color  -->
                <StackPanel Style="{StaticResource StackPanelVerticalMargin5}">
                    <TextBlock FontSize="18"
                               Style="{StaticResource CMFT.TextBlock.Left}"
                               Text="Color" />
                    <Grid Width="400" Margin="20,0">
                        <Grid.Resources>
                            <Style BasedOn="{StaticResource UniformGridMargin5}" TargetType="UniformGrid" />
                        </Grid.Resources>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <UniformGrid Grid.Column="0" Columns="1">
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="Primary" />
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="Secondary" />

                        </UniformGrid>
                        <UniformGrid Grid.Column="1">

                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding SelectedSettings.Primary, Converter={converters:ColorToHexConverter}}" />
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding SelectedSettings.Secondary, Converter={converters:ColorToHexConverter}}" />

                        </UniformGrid>

                        <UniformGrid Grid.Column="2">
                            <UniformGrid.Resources>
                                <Style BasedOn="{StaticResource CMFT.RadioButton.ColorButton}" TargetType="{x:Type RadioButton}">
                                    <Setter Property="Width" Value="45" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="Command" Value="{Binding ChangeCurrentSchemeCommand}" />
                                </Style>
                            </UniformGrid.Resources>

                            <RadioButton Background="{Binding SelectedSettings.Primary, Converter={converters:ColorToBrushConverter}}" IsChecked="{Binding SelectedColorScheme, Converter={converters:EqualityToBoolConverter}, ConverterParameter={x:Static materialDesign:ColorSelection.Primary}}" />
                            <RadioButton Background="{Binding SelectedSettings.Secondary, Converter={converters:ColorToBrushConverter}}" IsChecked="{Binding SelectedColorScheme, Converter={converters:EqualityToBoolConverter}, ConverterParameter={x:Static materialDesign:ColorSelection.Secondary}}" />

                        </UniformGrid>

                    </Grid>
                </StackPanel>

                <!--  Color Adjustment  -->
                <StackPanel>
                    <StackPanel Style="{StaticResource StackPanelHorizontalMargin5}">
                        <TextBlock FontSize="18"
                                   Style="{StaticResource CMFT.TextBlock.Center}"
                                   Text="Color Adjustment" />
                        <ToggleButton x:Name="IsAdjustmentToggleButton"
                                      Margin="5,0,0,0"
                                      Command="{Binding ChangeColorAdjustmentCommand}"
                                      IsChecked="{Binding IsColorAdjusted}" />
                    </StackPanel>

                    <Grid Width="400"
                          Margin="20,0"
                          IsEnabled="{Binding IsChecked, ElementName=IsAdjustmentToggleButton}">
                        <Grid.Resources>
                            <Style BasedOn="{StaticResource UniformGridMargin5}" TargetType="UniformGrid" />
                        </Grid.Resources>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <UniformGrid Grid.Column="0" Columns="1">
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="Contrast Ratio" />
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="Contrast" />
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="Color Selection" />
                        </UniformGrid>
                        <UniformGrid Grid.Column="1">
                            <Grid Margin="8" Style="{StaticResource PanelMargin3}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Slider Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        assist:SliderAssist.DragCompletedCommand="{Binding Path=ChangeColorAdjustmentParamCommand}"
                                        IsSnapToTickEnabled="True"
                                        Maximum="21"
                                        Minimum="1"
                                        TickFrequency="0.1"
                                        Value="{Binding SelectedSettings.ContrastRatio, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                                <TextBlock Grid.Column="1"
                                           Margin="8"
                                           HorizontalAlignment="Right"
                                           Style="{StaticResource CMFT.TextBlock.Left}"
                                           Text="{Binding SelectedSettings.ContrastRatio, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay, StringFormat={}{0:00.0}:1}"
                                           TextAlignment="Right" />
                            </Grid>
                            <ComboBox ItemsSource="{Binding ContrastValues}" SelectedItem="{Binding SelectedSettings.ContrastValue, UpdateSourceTrigger=PropertyChanged}">
                                <b:Interaction.Triggers>
                                    <b:EventTrigger EventName="SelectionChanged">
                                        <b:InvokeCommandAction Command="{Binding Path=ChangeColorAdjustmentParamCommand}" />
                                    </b:EventTrigger>
                                </b:Interaction.Triggers>
                            </ComboBox>
                            <ComboBox ItemsSource="{Binding ColorSelections}" SelectedItem="{Binding SelectedSettings.ColorSelection, UpdateSourceTrigger=PropertyChanged}">
                                <b:Interaction.Triggers>
                                    <b:EventTrigger EventName="SelectionChanged">
                                        <b:InvokeCommandAction Command="{Binding Path=ChangeColorAdjustmentParamCommand}" />
                                    </b:EventTrigger>
                                </b:Interaction.Triggers>
                            </ComboBox>

                        </UniformGrid>
                    </Grid>
                </StackPanel>

                <Button BorderBrush="{StaticResource CMFT.Brush.Blue.Mid}"
                        Command="{Binding RestoreCommand}"
                        Content="還原"
                        Style="{StaticResource CMFT.Button}" />
                <Button Command="{Binding DefaultCommand}"
                        Content="預設"
                        Style="{StaticResource CMFT.Button}" />

            </StackPanel>

            <!--#region 選顏色-->
            <Border Grid.Column="1" Width="625">
                <customControl:ColorTool SelectedColor="{Binding SelectedColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <b:Interaction.Triggers>
                        <b:EventTrigger EventName="SelectionChanged">
                            <b:InvokeCommandAction Command="{Binding Path=ChangeCurrentColorCommand}" />
                        </b:EventTrigger>
                    </b:Interaction.Triggers>
                </customControl:ColorTool>
            </Border>
            <!--#endregion-->

            <!--#region 當前顏色-->
            <Grid x:Name="CurrentScheme"
                  Grid.Column="2"
                  Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />

                    <RowDefinition Height="1*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Margin="10"
                           FontSize="24"
                           Style="{StaticResource CMFT.TextBlock.Center}"
                           Text="Material Design Color" />

                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                        BorderThickness="1">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="2*" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Margin="0,0,1,0"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                                   Text="Primary" />

                        <Grid Grid.Row="1"
                              Margin="0,0,0,2"
                              Background="{DynamicResource MaterialDesign.Brush.Primary}">
                            <TextBlock Margin="0,1"
                                       Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                                       Text="{Binding Background, RelativeSource={RelativeSource Self}, Converter={converters:BrushToHexConverter}}" />
                            <Border Width="30"
                                    Height="30"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                                    CornerRadius="15">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Bottom"
                                           FontSize="22"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                                           Text="P" />
                            </Border>
                        </Grid>
                        <UniformGrid Grid.Row="2" Rows="1">
                            <TextBlock Margin="0,0,1,0"
                                       Background="{DynamicResource MaterialDesign.Brush.Primary.Light}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary.Light.Foreground}"
                                       Text="{Binding Background, RelativeSource={RelativeSource Self}, Converter={converters:BrushToHexConverter}}" />
                            <TextBlock Margin="1,0,0,0"
                                       Background="{DynamicResource MaterialDesign.Brush.Primary.Dark}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary.Dark.Foreground}"
                                       Text="{Binding Background, RelativeSource={RelativeSource Self}, Converter={converters:BrushToHexConverter}}" />
                        </UniformGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Margin="0,5,0,0"
                        BorderBrush="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                        BorderThickness="1">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="2*" />
                            <RowDefinition Height="1*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Margin="0,0,1,0"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                                   Style="{StaticResource MaterialDesignBody1TextBlock}"
                                   Text="Secondary" />

                        <Grid Grid.Row="1"
                              Margin="0,0,0,2"
                              Background="{DynamicResource MaterialDesign.Brush.Secondary}">
                            <TextBlock Margin="0,1"
                                       Background="{DynamicResource MaterialDesign.Brush.Secondary}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                                       Text="{Binding Background, RelativeSource={RelativeSource Self}, Converter={converters:BrushToHexConverter}}" />
                            <Border Width="30"
                                    Height="30"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource MaterialDesign.Brush.Secondary.Foreground}"
                                    CornerRadius="15">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Bottom"
                                           FontSize="22"
                                           Foreground="{DynamicResource MaterialDesign.Brush.Secondary}"
                                           Text="P" />
                            </Border>
                        </Grid>
                        <UniformGrid Grid.Row="2" Rows="1">
                            <TextBlock Margin="0,0,1,0"
                                       Background="{DynamicResource MaterialDesign.Brush.Secondary.Light}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Light.Foreground}"
                                       Text="{Binding Background, RelativeSource={RelativeSource Self}, Converter={converters:BrushToHexConverter}}" />
                            <TextBlock Margin="1,0,0,0"
                                       Background="{DynamicResource MaterialDesign.Brush.Secondary.Dark}"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Secondary.Dark.Foreground}"
                                       Text="{Binding Background, RelativeSource={RelativeSource Self}, Converter={converters:BrushToHexConverter}}" />
                        </UniformGrid>
                    </Grid>
                </Border>






            </Grid>
            <!--#endregion-->

        </Grid>
        <ContentControl Content="{x:Static dialogs:eDialogFooterButtons.OKCancel}" Style="{StaticResource DialogFooter}" />
    </StackPanel>
</UserControl>
