<UserControl x:Class="ASI.TCL.CMFT.WPF.Dialogs.MessageBoxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:dialogs="clr-namespace:ASI.TCL.CMFT.WPF.Dialogs"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DataContext="{d:DesignInstance dialogs:MessageBoxViewModel,
                                              IsDesignTimeCreatable=True}"
             BorderBrush="{Binding MessageBoxColor}"
             Style="{DynamicResource MessageBox}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="MessageBox"
               BasedOn="{StaticResource CMFT.UserControl}"
               TargetType="{x:Type UserControl}">
            <Setter Property="BorderThickness" Value="2" />
        </Style>

        <Style x:Key="MessageBoxHeader" TargetType="{x:Type ContentControl}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContentControl}">
                        <Border Background="{TemplateBinding Background}">
                            <TextBlock x:Name="PART_TextBlock"
                                       Margin="15,10"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Content}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MessageBoxFooter" TargetType="{x:Type ContentControl}">
            <Setter Property="Background" Value="Red" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContentControl}">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <StackPanel.Resources>
                                <Style BasedOn="{StaticResource MaterialDesignFlatMidBgButton}" TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Setter Property="Margin" Value="10,0,10,10" />
                                    <Setter Property="Padding" Value="10,4" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Command" Value="{Binding ButtonCommand}" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.8" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Resources>
                            <Button x:Name="Yes"
                                    Background="{TemplateBinding Background}"
                                    CommandParameter="{x:Static prism:ButtonResult.Yes}"
                                    Content="是" />
                            <Button x:Name="No"
                                    Background="{TemplateBinding Background}"
                                    CommandParameter="{x:Static prism:ButtonResult.No}"
                                    Content="否" />
                            <Button x:Name="OK"
                                    Background="{TemplateBinding Background}"
                                    CommandParameter="{x:Static prism:ButtonResult.OK}"
                                    Content="確定" />
                            <Button x:Name="Abort"
                                    Background="{TemplateBinding Background}"
                                    CommandParameter="{x:Static prism:ButtonResult.Abort}"
                                    Content="中止" />
                            <Button x:Name="Retry"
                                    Background="{TemplateBinding Background}"
                                    CommandParameter="{x:Static prism:ButtonResult.Retry}"
                                    Content="重試" />
                            <Button x:Name="Ignore"
                                    Background="{TemplateBinding Background}"
                                    CommandParameter="{x:Static prism:ButtonResult.Ignore}"
                                    Content="忽略" />
                            <Button x:Name="Cancel"
                                    Background="{TemplateBinding Background}"
                                    CommandParameter="{x:Static prism:ButtonResult.Cancel}"
                                    Content="取消" />
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="{x:Static dialogs:eDialogFooterButtons.AbortRetryIgnore}">
                                <Setter TargetName="Abort" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Retry" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Ignore" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Content" Value="{x:Static dialogs:eDialogFooterButtons.OK}">
                                <Setter TargetName="OK" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Content" Value="{x:Static dialogs:eDialogFooterButtons.OKCancel}">
                                <Setter TargetName="OK" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Cancel" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Content" Value="{x:Static dialogs:eDialogFooterButtons.RetryCancel}">
                                <Setter TargetName="Retry" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Cancel" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Content" Value="{x:Static dialogs:eDialogFooterButtons.YesNo}">
                                <Setter TargetName="Yes" Property="Visibility" Value="Visible" />
                                <Setter TargetName="No" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Content" Value="{x:Static dialogs:eDialogFooterButtons.YesNoCancel}">
                                <Setter TargetName="Yes" Property="Visibility" Value="Visible" />
                                <Setter TargetName="No" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Cancel" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <ContentControl Background="{Binding MessageBoxColor}"
                        Content="{Binding Title}"
                        Foreground="{DynamicResource MaterialDesignDarkForeground}"
                        Style="{StaticResource MessageBoxHeader}" />

        <Grid MinWidth="300"
              MinHeight="100"
              Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <materialDesign:PackIcon Grid.Column="0"
                                     Width="65"
                                     Height="65"
                                     Margin="10"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     Foreground="{Binding MessageBoxColor}"
                                     Kind="{Binding MessageBoxIcon}" />

            <TextBlock Grid.Column="1"
                       MaxWidth="600"
                       HorizontalAlignment="Left"
                       Style="{StaticResource CMFT.TextBlock.Left}"
                       Text="{Binding Message}"
                       TextWrapping="Wrap" />
        </Grid>

        <ContentControl VerticalAlignment="Bottom"
                        Background="{Binding MessageBoxColor}"
                        Content="{Binding DialogFooterButton}"
                        Style="{StaticResource MessageBoxFooter}" />
    </StackPanel>

</UserControl>