<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assist="clr-namespace:ASI.TCL.CMFT.WPF.Assist"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ASI.TCL.CMFT.WPF;component/Themes/Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <system:Double x:Key="ButtonFontSize">16</system:Double>
    <system:Double x:Key="ButtonFontSize_Middle">16</system:Double>
    <system:Double x:Key="ButtonFontSize_Large">18</system:Double>
    <system:Double x:Key="ButtonHeight">34</system:Double>
    <system:Double x:Key="CheckBoxSize">22</system:Double>

    <Style x:Key="WPF.ButtonBase.ButtonLike" TargetType="{x:Type ButtonBase}">
        <Setter Property="FocusVisualStyle">
            <Setter.Value>
                <Style TargetType="{x:Type IFrameworkInputElement}">
                    <Setter Property="Control.Template">
                        <Setter.Value>
                            <ControlTemplate>
                                <Rectangle
                                    Margin="2"
                                    SnapsToDevicePixels="True"
                                    Stroke="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                                    StrokeDashArray="1 2"
                                    StrokeThickness="1" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Panel.Background" Value="#DDDDDD" />
        <Setter Property="Border.BorderBrush" Value="#707070" />
        <Setter Property="TextElement.Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" />
        <Setter Property="Border.BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="1" />
    </Style>
    <Style
        x:Key="CMFT.ButtonBase"
        BasedOn="{StaticResource MaterialDesignFlatMidBgButton}"
        TargetType="ButtonBase">
        <Setter Property="FontSize" Value="{DynamicResource ButtonFontSize}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="4" />
        <Setter Property="FontWeight" Value="Bold" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.8" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="CMFT.ButtonBase.ButtonLike"
        BasedOn="{StaticResource MaterialDesignFlatMidBgButton}"
        TargetType="{x:Type ButtonBase}" />

    <Style x:Key="WPF.Button" TargetType="{x:Type Button}" />
    <Style
        x:Key="CMFT.Button"
        BasedOn="{StaticResource CMFT.ButtonBase}"
        TargetType="Button">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Gray.Dark}" />
        <Setter Property="Foreground" Value="{StaticResource AssitColor1}" />
        <Setter Property="Background" Value="{Binding BorderBrush, RelativeSource={RelativeSource Self}}" />
        <Style.Triggers>
            <Trigger Property="Content" Value="登入">
                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
            </Trigger>
            <Trigger Property="Content" Value="返回">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Blue.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="離開">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Gray.Dark}" />
            </Trigger>
            <Trigger Property="Content" Value="儲存">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="變更">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Dark}" />
            </Trigger>
            <Trigger Property="Content" Value="查詢">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Blue.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="篩選">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Blue.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="重置">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Gray.Dark}" />
            </Trigger>
            <Trigger Property="Content" Value="確定">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="取消">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Gray.Dark}" />
            </Trigger>
            <Trigger Property="Content" Value="檢視">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Blue.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="新增">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Blue.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="編輯">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Dark}" />
            </Trigger>
            <Trigger Property="Content" Value="刪除">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Red.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="發送">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="取得車站廣播控制權">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="開始廣播">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Mid}" />
            </Trigger>

            <Trigger Property="Content" Value="取消廣播">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Red.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="中斷廣播">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Red.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="結束廣播">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Red.Mid}" />
            </Trigger>

            <Trigger Property="Content" Value="匯出">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Dark}" />
            </Trigger>
            <Trigger Property="Content" Value="列印">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Mid}" />
            </Trigger>

            <Trigger Property="Content" Value="確認警報">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="確認中">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="已確認">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="全部展開">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Blue.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="全部清除">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Red.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="全部摺疊">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Dark}" />
            </Trigger>
            <Trigger Property="Content" Value="清除">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Red.Mid}" />
            </Trigger>
            <Trigger Property="Content" Value="建立連線">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Dark}" />
            </Trigger>
            <Trigger Property="Content" Value="關閉連線">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Red.Mid}" />
            </Trigger>

        </Style.Triggers>
    </Style>
    <Style
        x:Key="CMFT.Button.Icon"
        BasedOn="{StaticResource CMFT.Button}"
        TargetType="Button">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Button
                        Height="{TemplateBinding Height}"
                        HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalAlignment}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        Command="{TemplateBinding Command}"
                        CommandParameter="{TemplateBinding CommandParameter}"
                        FontSize="{TemplateBinding FontSize}"
                        Foreground="{TemplateBinding Foreground}"
                        ToolTipService.InitialShowDelay="0">

                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                x:Name="Icon"
                                Width="{Binding FontSize, ElementName=Text}"
                                Height="{Binding FontSize, ElementName=Text}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Kind="Plus" />
                            <TextBlock
                                x:Name="Text"
                                Margin="4,0,0,0"
                                Foreground="{TemplateBinding Foreground}"
                                Text="{TemplateBinding Content}" />
                        </StackPanel>
                    </Button>



                    <ControlTemplate.Triggers>
                        <Trigger Property="Content" Value="檢視">
                            <Setter TargetName="Icon" Property="Kind" Value="Eye" />
                        </Trigger>
                        <Trigger Property="Content" Value="新增">
                            <Setter TargetName="Icon" Property="Kind" Value="Plus" />
                        </Trigger>
                        <Trigger Property="Content" Value="編輯">
                            <Setter TargetName="Icon" Property="Kind" Value="Edit" />
                        </Trigger>
                        <Trigger Property="Content" Value="刪除">
                            <Setter TargetName="Icon" Property="Kind" Value="Delete" />
                        </Trigger>

                        <Trigger Property="Content" Value="儲存">
                            <Setter TargetName="Icon" Property="Kind" Value="ContentSave" />
                        </Trigger>
                        <Trigger Property="Content" Value="篩選">
                            <Setter TargetName="Icon" Property="Kind" Value="Search" />
                        </Trigger>
                        <Trigger Property="Content" Value="重置">
                            <Setter TargetName="Icon" Property="Kind" Value="SettingsBackupRestore" />
                        </Trigger>

                        <Trigger Property="Content" Value="取消">
                            <Setter TargetName="Icon" Property="Kind" Value="Cancel" />
                        </Trigger>

                        <Trigger Property="Content" Value="發送">
                            <Setter TargetName="Icon" Property="Kind" Value="Send" />
                        </Trigger>
                        <Trigger Property="Content" Value="取得車站廣播控制權">
                            <Setter TargetName="Icon" Property="Kind" Value="Send" />
                        </Trigger>

                        <Trigger Property="Content" Value="匯出">
                            <Setter TargetName="Icon" Property="Kind" Value="Export" />
                        </Trigger>
                        <Trigger Property="Content" Value="列印">
                            <Setter TargetName="Icon" Property="Kind" Value="Printer" />
                        </Trigger>


                        <Trigger Property="Content" Value="試聽_國">
                            <Setter Property="BorderBrush" Value="{DynamicResource CMFT.Brush.Green.Mid}" />
                            <Setter TargetName="Icon" Property="Kind" Value="EarHearing" />
                            <Setter TargetName="Text" Property="Text" Value="國" />
                        </Trigger>
                        <Trigger Property="Content" Value="試聽_英">
                            <Setter Property="BorderBrush" Value="{DynamicResource CMFT.Brush.Green.Mid}" />
                            <Setter TargetName="Icon" Property="Kind" Value="EarHearing" />
                            <Setter TargetName="Text" Property="Text" Value="英" />
                        </Trigger>
                        <Trigger Property="Content" Value="試聽_台">
                            <Setter Property="BorderBrush" Value="{DynamicResource CMFT.Brush.Green.Mid}" />
                            <Setter TargetName="Icon" Property="Kind" Value="EarHearing" />
                            <Setter TargetName="Text" Property="Text" Value="台" />
                        </Trigger>
                        <Trigger Property="Content" Value="試聽_客">
                            <Setter Property="BorderBrush" Value="{DynamicResource CMFT.Brush.Green.Mid}" />
                            <Setter TargetName="Icon" Property="Kind" Value="EarHearing" />
                            <Setter TargetName="Text" Property="Text" Value="客" />
                        </Trigger>
                        <Trigger Property="Content" Value="+">
                            <Setter Property="Background" Value="{DynamicResource CMFT.Brush.Blue.Mid}" />
                            <Setter TargetName="Icon" Property="Kind" Value="Plus" />
                            <Setter TargetName="Text" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Content" Value="-">
                            <Setter Property="Background" Value="{DynamicResource CMFT.Brush.Gray.Dark}" />
                            <Setter TargetName="Icon" Property="Kind" Value="Minus" />
                            <Setter TargetName="Text" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Content" Value="Play">
                            <Setter Property="Background" Value="{DynamicResource CMFT.Brush.Green.Mid}" />
                            <Setter TargetName="Icon" Property="Kind" Value="Play" />
                            <Setter TargetName="Text" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Content" Value="Pause">
                            <Setter Property="Background" Value="{DynamicResource CMFT.Brush.Gray.Dark}" />
                            <Setter TargetName="Icon" Property="Kind" Value="Pause" />
                            <Setter TargetName="Text" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style
        x:Key="CMFT.Button.Outlined"
        BasedOn="{StaticResource CMFT.Button}"
        TargetType="Button">
        <Setter Property="Foreground" Value="{Binding BorderBrush, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Background" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{Binding BorderBrush, RelativeSource={RelativeSource Self}}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Opacity" Value="1" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="CMFT.Button.Outlined.Icon"
        BasedOn="{StaticResource CMFT.Button.Icon}"
        TargetType="Button">
        <Setter Property="Foreground" Value="{Binding BorderBrush, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Background" Value="Transparent" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{Binding BorderBrush, RelativeSource={RelativeSource Self}}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Opacity" Value="1" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="CMFT.Button.Outlined.LightButton"
        BasedOn="{StaticResource MaterialDesignOutlinedButton}"
        TargetType="Button">
        <Setter Property="BorderBrush" Value="White" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="{DynamicResource ButtonFontSize}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#4FFFFFFF" />
                <Setter Property="Foreground" Value="White" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WPF.ToggleButton" TargetType="{x:Type ToggleButton}" />
    <Style
        x:Key="WPF.ToggleButton.ButtonLike"
        BasedOn="{StaticResource WPF.ButtonBase.ButtonLike}"
        TargetType="{x:Type ToggleButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ButtonBase}">
                    <Border
                        Name="border"
                        Background="{TemplateBinding Panel.Background}"
                        BorderBrush="{TemplateBinding Border.BorderBrush}"
                        BorderThickness="{TemplateBinding Border.BorderThickness}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            Name="contentPresenter"
                            Margin="{TemplateBinding Control.Padding}"
                            HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding Control.VerticalContentAlignment}"
                            Content="{TemplateBinding ContentControl.Content}"
                            ContentStringFormat="{TemplateBinding ContentControl.ContentStringFormat}"
                            ContentTemplate="{TemplateBinding ContentControl.ContentTemplate}"
                            Focusable="False"
                            RecognizesAccessKey="True"
                            SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Button.IsDefaulted" Value="True">
                            <Setter TargetName="border" Property="Border.BorderBrush" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                        </Trigger>
                        <Trigger Property="UIElement.IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Panel.Background" Value="#BEE6FD" />
                            <Setter TargetName="border" Property="Border.BorderBrush" Value="#3C7FB1" />
                        </Trigger>
                        <Trigger Property="ButtonBase.IsPressed" Value="True">
                            <Setter TargetName="border" Property="Panel.Background" Value="#C4E5F6" />
                            <Setter TargetName="border" Property="Border.BorderBrush" Value="#2C628B" />
                        </Trigger>
                        <Trigger Property="ToggleButton.IsChecked" Value="True">
                            <Setter TargetName="border" Property="Panel.Background" Value="#BCDDEE" />
                            <Setter TargetName="border" Property="Border.BorderBrush" Value="#245A83" />
                        </Trigger>
                        <Trigger Property="UIElement.IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Panel.Background" Value="#F4F4F4" />
                            <Setter TargetName="border" Property="Border.BorderBrush" Value="#ADB2B5" />
                            <Setter Property="TextElement.Foreground" Value="#838383" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style
        x:Key="CMFT.ToggleButton"
        BasedOn="{StaticResource MaterialDesignSwitchToggleButton}"
        TargetType="{x:Type ToggleButton}" />
    <Style
        x:Key="CMFT.ToggleButton.ButtonLike"
        BasedOn="{StaticResource CMFT.ButtonBase.ButtonLike}"
        TargetType="{x:Type ToggleButton}">
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp5" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.8" />
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="WPF.RadioButton" TargetType="{x:Type RadioButton}" />
    <Style
        x:Key="WPF.RadioButton.ButtonLike"
        BasedOn="{StaticResource WPF.ButtonBase.ButtonLike}"
        TargetType="{x:Type RadioButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <Border
                        x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            x:Name="contentPresenter"
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding ContentControl.Content}"
                            ContentStringFormat="{TemplateBinding ContentControl.ContentStringFormat}"
                            ContentTemplate="{TemplateBinding ContentControl.ContentTemplate}"
                            Focusable="False"
                            RecognizesAccessKey="True"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#BCDDEE" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#245A83" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#BEE6FD" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#3C7FB1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#F4F4F4" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#ADB2B5" />
                            <Setter Property="Foreground" Value="#838383" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#C4E5F6" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#2C628B" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style
        x:Key="CMFT.RadioButton"
        BasedOn="{StaticResource MaterialDesignRadioButton}"
        TargetType="RadioButton">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="{DynamicResource FieldFontSize}" />
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.8" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="CMFT.RadioButton.ButtonLike"
        BasedOn="{StaticResource CMFT.ButtonBase.ButtonLike}"
        TargetType="{x:Type RadioButton}">
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp5" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.8" />
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="CMFT.RadioButton.ColorButton"
        BasedOn="{StaticResource MaterialDesignRaisedButton}"
        TargetType="RadioButton">
        <Setter Property="Width" Value="35" />
        <Setter Property="Height" Value="35" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Margin" Value="1,1,0,0" />
        <Setter Property="Tag" Value="0" />
        <Setter Property="assist:ButtonAssist.UniformCornerRadius" Value="0" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp0" />
        <Setter Property="materialDesign:RippleAssist.IsDisabled" Value="True" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(assist:ButtonAssist.UniformCornerRadius)"
                                To="8"
                                Duration="0:0:0.18" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>

                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(assist:ButtonAssist.UniformCornerRadius)"
                                From="8"
                                Duration="0:0:0.18" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(assist:ButtonAssist.UniformCornerRadius)"
                                To="20"
                                Duration="0:0:0.18" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>

                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation
                                Storyboard.TargetProperty="(assist:ButtonAssist.UniformCornerRadius)"
                                From="20"
                                Duration="0:0:0.18" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
            </Trigger>

        </Style.Triggers>
    </Style>
    <Style x:Key="CMFT.RadioButton.NavButton" TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{x:Null}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border
                        x:Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderThickness="1"
                        CornerRadius="4">

                        <ContentControl x:Name="Content" Foreground="{TemplateBinding Foreground}">
                            <StackPanel Margin="10,5">
                                <materialDesign:PackIcon
                                    Width="40"
                                    Height="{Binding Width, RelativeSource={RelativeSource Self}}"
                                    HorizontalAlignment="Center"
                                    Kind="{TemplateBinding Content}" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontWeight="Bold"
                                    Text="{TemplateBinding AutomationProperties.HelpText}" />
                            </StackPanel>
                        </ContentControl>
                    </Border>
                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#1FFFFFFF" />
                            <Setter TargetName="Border" Property="Opacity" Value="0.87" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.TextBox.OutlineInactiveBorder}" />
                            <Setter TargetName="Content" Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Secondary.Light}" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Content" Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Secondary}" />
                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource MaterialDesign.Brush.Secondary.Dark}" />
                            <Setter TargetName="Content" Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Secondary.Dark.Foreground}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter TargetName="Content" Property="Foreground" Value="{DynamicResource CMFT.Brush.Gray.Light}" />

                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WPF.CheckBox" TargetType="{x:Type CheckBox}" />
    <Style
        x:Key="WPF.CheckBox.ButtonLike"
        BasedOn="{StaticResource WPF.ButtonBase.ButtonLike}"
        TargetType="{x:Type CheckBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Border
                        x:Name="border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                        <ContentPresenter
                            x:Name="contentPresenter"
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentStringFormat="{TemplateBinding ContentStringFormat}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Focusable="False"
                            RecognizesAccessKey="True"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#BCDDEE" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#245A83" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#BEE6FD" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#3C7FB1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Background" Value="#F4F4F4" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#ADB2B5" />
                            <Setter Property="Foreground" Value="#838383" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#C4E5F6" />
                            <Setter TargetName="border" Property="BorderBrush" Value="#2C628B" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style
        x:Key="CMFT.CheckBox"
        BasedOn="{StaticResource MaterialDesignCheckBox}"
        TargetType="{x:Type CheckBox}">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.8" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="CMFT.CheckBox.ButtonLike"
        BasedOn="{StaticResource CMFT.ButtonBase.ButtonLike}"
        TargetType="{x:Type CheckBox}">
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp5" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.8" />
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp3" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style x:Key="CMFT.CheckBox.UserForeground" TargetType="CheckBox">
        <!--  MaterialDesignUserForegroundCheckBox  -->
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type FrameworkElement}}, Path=(TextElement.Foreground)}" />
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource MaterialDesignValidationErrorTemplate}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <ControlTemplate.Resources>
                        <Storyboard x:Key="Click">
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="InteractionEllipse" Storyboard.TargetProperty="(FrameworkElement.Width)">
                                <EasingDoubleKeyFrame KeyTime="0" Value="0" />
                                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="48" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="InteractionEllipse" Storyboard.TargetProperty="(FrameworkElement.Height)">
                                <EasingDoubleKeyFrame KeyTime="0" Value="0" />
                                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="48" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="InteractionEllipse" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.X)">
                                <EasingDoubleKeyFrame KeyTime="0" Value="0" />
                                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="-24" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="InteractionEllipse" Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
                                <EasingDoubleKeyFrame KeyTime="0" Value="0" />
                                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="-24" />
                            </DoubleAnimationUsingKeyFrames>
                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="InteractionEllipse" Storyboard.TargetProperty="(UIElement.Opacity)">
                                <EasingDoubleKeyFrame KeyTime="0" Value="0.3" />
                                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0" />
                            </DoubleAnimationUsingKeyFrames>
                        </Storyboard>
                    </ControlTemplate.Resources>

                    <Grid
                        x:Name="templateRoot"
                        Background="Transparent"
                        SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Viewbox
                            Width="18"
                            Height="18"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            FlowDirection="LeftToRight">
                            <Canvas Width="24" Height="24">
                                <Path
                                    x:Name="Graphic"
                                    Data="M19,3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M19,5V19H5V5H19Z"
                                    Fill="{TemplateBinding Foreground}" />

                                <Ellipse
                                    x:Name="InteractionEllipse"
                                    Canvas.Left="12"
                                    Canvas.Top="12"
                                    Width="0"
                                    Height="0"
                                    Fill="{TemplateBinding Foreground}"
                                    IsHitTestVisible="False"
                                    Opacity="0"
                                    RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform />
                                            <SkewTransform />
                                            <RotateTransform />
                                            <TranslateTransform />
                                        </TransformGroup>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Canvas>
                        </Viewbox>

                        <ContentPresenter
                            x:Name="contentPresenter"
                            Grid.Column="1"
                            Margin="{TemplateBinding Padding}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Focusable="False"
                            RecognizesAccessKey="True"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="ButtonBase.Click">
                            <BeginStoryboard Storyboard="{StaticResource Click}" />
                        </EventTrigger>

                        <Trigger Property="HasContent" Value="true">
                            <Setter Property="FocusVisualStyle" Value="{StaticResource OptionMarkFocusVisual}" />
                            <Setter Property="Padding" Value="4,2,0,0" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="false">
                            <Setter TargetName="Graphic" Property="Opacity" Value="0.26" />
                        </Trigger>

                        <Trigger Property="IsChecked" Value="true">
                            <Setter TargetName="Graphic" Property="Data" Value="M10,17L5,12L6.41,10.58L10,14.17L17.59,6.58L19,8M19,3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3Z" />
                        </Trigger>

                        <!--  中間狀態：一條橫線  -->
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Graphic" Property="Data" Value="F0 M 6,13 L 6,11 18,11 18,13 M 19,3 L 5,3 C 3.89,3 3,3.89 3,5 L 3,19 A 2,2 0 0 0 5,21 L 19,21 A 2,2 0 0 0 21,19 L 21,5 C 21,3.89 20.1,3 19,3 Z" />
                            <Setter TargetName="Graphic" Property="Opacity" Value="1" />
                        </Trigger>

                        <Trigger Property="Validation.HasError" Value="true">
                            <Setter TargetName="Graphic" Property="Fill" Value="{DynamicResource MaterialDesignValidationErrorBrush}" />
                            <Setter TargetName="contentPresenter" Property="Control.Foreground" Value="{DynamicResource MaterialDesignValidationErrorBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.8" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="CMFT.CheckBox.Primary"
        BasedOn="{StaticResource CMFT.CheckBox}"
        TargetType="{x:Type CheckBox}">
        <Style.Resources>
            <!--  重載CheckBox的背景跟邊框顏色  -->
            <!--<SolidColorBrush x:Key="MaterialDesign.Brush.ForegroundLight" Color="#FF3d3c39" />
            <SolidColorBrush x:Key="MaterialDesign.Brush.Primary" Color="#FF3d3c39" />-->
        </Style.Resources>
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary.Foreground}" />
    </Style>

</ResourceDictionary>