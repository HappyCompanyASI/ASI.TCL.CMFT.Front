<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ASI.TCL.CMFT.WPF;component/Themes/Panel.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--#region ItemsPanelTemplate-->
    <ItemsPanelTemplate x:Key="UniformGridItemsPanel1">
        <UniformGrid VerticalAlignment="Top" Columns="1" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="UniformGridItemsPanel2">
        <UniformGrid VerticalAlignment="Top" Columns="2" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="UniformGridItemsPanel3">
        <UniformGrid VerticalAlignment="Top" Columns="3" />
    </ItemsPanelTemplate>
    <ItemsPanelTemplate x:Key="UniformGridItemsPanel4">
        <UniformGrid VerticalAlignment="Top" Columns="4" />
    </ItemsPanelTemplate>
    <ItemsPanelTemplate x:Key="UniformGridItemsPanel14">
        <UniformGrid VerticalAlignment="Top" Columns="14" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="StackItemsPanelVerticalMargin0">
        <StackPanel Style="{StaticResource StackPanelVerticalMargin0}" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="StackItemsPanelVerticalMargin1">
        <StackPanel Style="{StaticResource StackPanelVerticalMargin1}" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="StackItemsPanelVerticalMargin2">
        <StackPanel Style="{StaticResource StackPanelVerticalMargin2}" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="StackItemsPanelVerticalMargin3">
        <StackPanel Style="{StaticResource StackPanelVerticalMargin3}" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="StackItemsPanelVerticalMargin4">
        <StackPanel Style="{StaticResource StackPanelVerticalMargin4}" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="StackItemsPanelVerticalMargin5">
        <StackPanel Style="{StaticResource StackPanelVerticalMargin5}" />
    </ItemsPanelTemplate>


    <ItemsPanelTemplate x:Key="StackItemsPanelHorizontalMargin3">
        <StackPanel Style="{StaticResource StackPanelHorizontalMargin3}" />
    </ItemsPanelTemplate>
    <!--#endregion-->

</ResourceDictionary>