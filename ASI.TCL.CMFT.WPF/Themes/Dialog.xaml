<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dialogs="clr-namespace:ASI.TCL.CMFT.WPF.Dialogs">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ASI.TCL.CMFT.WPF;component/Themes/Button.xaml" />
        <ResourceDictionary Source="pack://application:,,,/ASI.TCL.CMFT.WPF;component/Themes/Control.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style
        x:Key="Dialog"
        BasedOn="{StaticResource CMFT.UserControl}"
        TargetType="{x:Type UserControl}">
        <Setter Property="BorderBrush" Value="{DynamicResource BarBackground}" />
    </Style>

    <Style x:Key="DialogHeader" TargetType="{x:Type ContentControl}">
        <Setter Property="Background" Value="{DynamicResource BarBackground}" />
        <Setter Property="Foreground" Value="{StaticResource CMFT.Brush.Dark}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContentControl}">
                    <Border Background="{TemplateBinding Background}">
                        <TextBlock
                            x:Name="PART_TextBlock"
                            Margin="15,10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="{TemplateBinding Foreground}"
                            Text="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DialogFooter" TargetType="{x:Type ContentControl}">
        <Setter Property="Background" Value="{DynamicResource BarBackground}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContentControl}">
                    <Border Background="{TemplateBinding Background}">
                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <StackPanel.Resources>
                                <Style BasedOn="{StaticResource CMFT.Button}" TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Setter Property="Margin" Value="10" />
                                    <Setter Property="Padding" Value="10,4" />
                                </Style>
                            </StackPanel.Resources>
                            <Button x:Name="Yes" Content="是" />
                            <Button x:Name="No" Content="否" />
                            <Button x:Name="OK" Content="確定" />
                            <Button x:Name="Abort" Content="中止" />
                            <Button x:Name="Retry" Content="重試" />
                            <Button x:Name="Ignore" Content="忽略" />
                            <Button x:Name="Cancel" Content="取消" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Content" Value="{x:Static dialogs:eDialogFooterButtons.AbortRetryIgnore}">
                            <Setter TargetName="Abort" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Retry" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Ignore" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Abort" Property="Command" Value="{Binding AbortCommand}" />
                            <Setter TargetName="Retry" Property="Command" Value="{Binding RetryCommand}" />
                            <Setter TargetName="Ignore" Property="Command" Value="{Binding IgnoreCommand}" />
                        </Trigger>
                        <Trigger Property="Content" Value="{x:Static dialogs:eDialogFooterButtons.OK}">
                            <Setter TargetName="OK" Property="Visibility" Value="Visible" />
                            <Setter TargetName="OK" Property="Command" Value="{Binding OKCommand}" />
                        </Trigger>
                        <Trigger Property="Content" Value="{x:Static dialogs:eDialogFooterButtons.OKCancel}">
                            <Setter TargetName="OK" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Cancel" Property="Visibility" Value="Visible" />
                            <Setter TargetName="OK" Property="Command" Value="{Binding OKCommand}" />
                            <Setter TargetName="Cancel" Property="Command" Value="{Binding CancelCommand}" />
                        </Trigger>
                        <Trigger Property="Content" Value="{x:Static dialogs:eDialogFooterButtons.RetryCancel}">
                            <Setter TargetName="Retry" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Cancel" Property="Visibility" Value="Visible" />

                            <Setter TargetName="Retry" Property="Command" Value="{Binding RetryCommand}" />
                            <Setter TargetName="Cancel" Property="Command" Value="{Binding CancelCommand}" />
                        </Trigger>
                        <Trigger Property="Content" Value="{x:Static dialogs:eDialogFooterButtons.YesNo}">
                            <Setter TargetName="Yes" Property="Visibility" Value="Visible" />
                            <Setter TargetName="No" Property="Visibility" Value="Visible" />

                            <Setter TargetName="Yes" Property="Command" Value="{Binding YesCommand}" />
                            <Setter TargetName="No" Property="Command" Value="{Binding NoCommand}" />
                        </Trigger>
                        <Trigger Property="Content" Value="{x:Static dialogs:eDialogFooterButtons.YesNoCancel}">
                            <Setter TargetName="Yes" Property="Visibility" Value="Visible" />
                            <Setter TargetName="No" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Cancel" Property="Visibility" Value="Visible" />

                            <Setter TargetName="Yes" Property="Command" Value="{Binding YesCommand}" />
                            <Setter TargetName="No" Property="Command" Value="{Binding NoCommand}" />
                            <Setter TargetName="Cancel" Property="Command" Value="{Binding CancelCommand}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LightDialogHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource CMFT.Brush.Dark}" />
    </Style>

</ResourceDictionary>