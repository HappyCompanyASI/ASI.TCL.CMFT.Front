<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:enumType="clr-namespace:ASI.TCL.CMFT.WPF.EnumType"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ASI.TCL.CMFT.WPF;component/Themes/Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <system:Double x:Key="IconSize">30</system:Double>

    <Style x:Key="CMFT.Icon" TargetType="{x:Type materialDesign:PackIcon}">
        <Setter Property="Width" Value="{StaticResource IconSize}" />
        <Setter Property="Height" Value="{StaticResource IconSize}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
    </Style>

    <Style
        x:Key="CMFT.Icon.Small"
        BasedOn="{StaticResource CMFT.Icon}"
        TargetType="{x:Type materialDesign:PackIcon}">
        <Setter Property="Width" Value="25" />
        <Setter Property="Height" Value="25" />

    </Style>

    <Style
        x:Key="CMFT.Icon.Mid"
        BasedOn="{StaticResource CMFT.Icon}"
        TargetType="{x:Type materialDesign:PackIcon}">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
    </Style>

    <Style
        x:Key="CMFT.Icon.Big"
        BasedOn="{StaticResource CMFT.Icon}"
        TargetType="{x:Type materialDesign:PackIcon}">
        <Setter Property="Width" Value="35" />
        <Setter Property="Height" Value="35" />
    </Style>

    <Style
        x:Key="InformationIcon"
        BasedOn="{StaticResource CMFT.Icon}"
        TargetType="{x:Type materialDesign:PackIcon}">
        <Setter Property="Foreground" Value="{StaticResource CMFT.Brush.Green.Mid}" />
        <Setter Property="Kind" Value="InformationVariantCircleOutline" />
    </Style>

    <Style x:Key="SendingStateIcon" TargetType="{x:Type ContentControl}">
        <Setter Property="Width" Value="{DynamicResource IconSize}" />
        <Setter Property="Height" Value="{DynamicResource IconSize}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContentControl}">
                    <ProgressBar
                        x:Name="pgBar"
                        IsIndeterminate="True"
                        Style="{StaticResource MaterialDesignCircularProgressBar}"
                        Value="50" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding}" Value="{x:Static enumType:eSendingRowState.Successful}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ContentControl}">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource CMFT.Brush.Green.Dark}"
                                Kind="Check" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="{x:Static enumType:eSendingRowState.TimedOut}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ContentControl}">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource CMFT.Brush.Alarm.High}"
                                Kind="Close" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
            <DataTrigger Binding="{Binding}" Value="{x:Static enumType:eSendingRowState.Failed}">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ContentControl}">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource CMFT.Brush.Alarm.High}"
                                Kind="Close" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
        </Style.Triggers>


    </Style>

</ResourceDictionary>