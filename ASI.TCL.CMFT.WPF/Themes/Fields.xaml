<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assist="clr-namespace:ASI.TCL.CMFT.WPF.Assist"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ASI.TCL.CMFT.WPF;component/Themes/ColorTool.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <system:Double x:Key="FieldFontSize_Small">12</system:Double>
    <system:Double x:Key="FieldFontSize">16</system:Double>
    <system:Double x:Key="FieldFontSize_Large">20</system:Double>

    <Style
        x:Key="CMFT.Field.TextBox"
        BasedOn="{StaticResource MaterialDesignOutlinedTextBox}"
        TargetType="TextBox">
        <Setter Property="Padding" Value="8" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        <Setter Property="FontSize" Value="{DynamicResource FieldFontSize}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style
        x:Key="CMFT.Field.TextBox.Floating"
        BasedOn="{StaticResource CMFT.Field.TextBox}"
        TargetType="TextBox">
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.95" />
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="True" />
    </Style>
    <Style
        x:Key="CMFT.Field.TextBox.Numeric"
        BasedOn="{StaticResource CMFT.Field.TextBox}"
        TargetType="TextBox">
        <Setter Property="assist:TextBoxAssist.IsNumericOnly" Value="True" />
        <Setter Property="materialDesign:TextFieldAssist.CharacterCounterVisibility" Value="Collapsed" />
        <Setter Property="InputScope">
            <Setter.Value>
                <InputScope>
                    <InputScope.Names>
                        <InputScopeName NameValue="Number" />
                    </InputScope.Names>
                </InputScope>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="CMFT.Field.PasswordBox"
        BasedOn="{StaticResource MaterialDesignOutlinedRevealPasswordBox}"
        TargetType="PasswordBox">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="FontSize" Value="{DynamicResource FieldFontSize}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="assist:PasswordBoxAssist.BindPassword" Value="True" />
    </Style>
    <Style
        x:Key="CMFT.Field.PasswordBox.Floating"
        BasedOn="{StaticResource CMFT.Field.PasswordBox}"
        TargetType="PasswordBox">
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.95" />
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="True" />
    </Style>
    <Style
        x:Key="CMFT.Field.TimePicker"
        BasedOn="{StaticResource MaterialDesignOutlinedTimePicker}"
        TargetType="{x:Type materialDesign:TimePicker}">
        <Setter Property="Padding" Value="8" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        <Setter Property="FontSize" Value="{DynamicResource FieldFontSize}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Is24Hours" Value="True" />
    </Style>
    <Style
        x:Key="CMFT.Field.DatePicker"
        BasedOn="{StaticResource MaterialDesignOutlinedDatePicker}"
        TargetType="{x:Type DatePicker}">
        <Setter Property="Padding" Value="8" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        <Setter Property="FontSize" Value="{DynamicResource FieldFontSize}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SelectedDateFormat" Value="Long" />
        <Setter Property="Language" Value="zh-tw" />
    </Style>
    <Style
        x:Key="CMFT.Field.DateTimePicker"
        BasedOn="{StaticResource MaterialDesignOutlinedTimePicker}"
        TargetType="{x:Type materialDesign:TimePicker}">
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type materialDesign:TimePicker}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1.1*" />
                        </Grid.ColumnDefinitions>

                        <!--  DatePicker 只綁定日期  -->
                        <DatePicker
                            Grid.Column="0"
                            SelectedDate="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedTime}"
                            Style="{StaticResource CMFT.Field.DatePicker}" />

                        <!--  TimePicker 只綁定時間  -->
                        <materialDesign:TimePicker
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            SelectedTime="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedTime, Mode=TwoWay}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="CMFT.Field.ComboBox"
        BasedOn="{StaticResource MaterialDesignOutlinedComboBox}"
        TargetType="ComboBox">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="FontSize" Value="{DynamicResource FieldFontSize}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="IsEditable" Value="False" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource MaterialDesignComboBoxItemStyle}" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
    </Style>
    <Style
        x:Key="CMFT.Field.ComboBox.Floating"
        BasedOn="{StaticResource CMFT.Field.ComboBox}"
        TargetType="ComboBox">
        <Setter Property="materialDesign:HintAssist.FloatingScale" Value="0.95" />
        <Setter Property="materialDesign:HintAssist.IsFloating" Value="True" />
        <!--  這是Hint在ComboBox裡的顏色  -->
        <Setter Property="materialDesign:HintAssist.Background" Value="Transparent" />
    </Style>

</ResourceDictionary>