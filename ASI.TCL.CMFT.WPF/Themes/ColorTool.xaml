<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters"
    xmlns:customControl="clr-namespace:ASI.TCL.CMFT.WPF.CustomControl"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:materialDesignColors="clr-namespace:MaterialDesignColors;assembly=MaterialDesignColors">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ASI.TCL.CMFT.WPF;component/Themes/Panel.xaml" />
        <ResourceDictionary Source="pack://application:,,,/ASI.TCL.CMFT.WPF;component/Themes/ItemsControl.xaml" />
        <ResourceDictionary Source="pack://application:,,,/ASI.TCL.CMFT.WPF;component/Themes/Control.xaml" />
        <ResourceDictionary Source="pack://application:,,,/ASI.TCL.CMFT.WPF;component/Themes/Button.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="CMFT.ColorTool" TargetType="{x:Type customControl:ColorTool}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type customControl:ColorTool}">
                    <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid Width="622" Height="{TemplateBinding Height}">

                            <TabControl x:Name="PART_TabControl">
                                <TabItem Header="標準">
                                    <Grid x:Name="MD" Margin="0,10,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="1*" />
                                        </Grid.RowDefinitions>
                                        <UniformGrid
                                            Grid.Row="0"
                                            Margin="0,0,18,5"
                                            HorizontalAlignment="Right"
                                            Columns="14">
                                            <UniformGrid.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="12" />
                                                    <Setter Property="Width" Value="36" />
                                                    <Setter Property="TextAlignment" Value="Center" />
                                                </Style>
                                            </UniformGrid.Resources>
                                            <TextBlock Text="50" />
                                            <TextBlock Text="100" />
                                            <TextBlock Text="200" />
                                            <TextBlock Text="300" />
                                            <TextBlock Text="400" />
                                            <TextBlock Text="500" />
                                            <TextBlock Text="600" />
                                            <TextBlock Text="700" />
                                            <TextBlock Text="800" />
                                            <TextBlock Text="900" />
                                            <TextBlock Text="A100" />
                                            <TextBlock Text="A200" />
                                            <TextBlock Text="A400" />
                                            <TextBlock Text="A700" />
                                        </UniformGrid>
                                        <ScrollViewer Grid.Row="1">
                                            <ItemsControl x:Name="PART_ItemsControl" ItemsSource="{x:Static customControl:ColorTool.Swatches}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type materialDesignColors:ISwatch}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="100" />
                                                                <ColumnDefinition Width="1*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock
                                                                Grid.Column="0"
                                                                VerticalAlignment="Center"
                                                                FontSize="14"
                                                                FontWeight="Bold"
                                                                Text="{Binding Name, Mode=OneTime}" />
                                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding Lookup.Values, Mode=OneTime}">

                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="{x:Type Color}">
                                                                        <RadioButton
                                                                            x:Name="PART_Radio"
                                                                            Background="{Binding Converter={converters:ColorToBrushConverter}, Mode=OneWay}"
                                                                            Command="{x:Static customControl:ColorTool.ChangeSelectedColorCommand}"
                                                                            CommandParameter="{Binding}"
                                                                            GroupName="Properties"
                                                                            Style="{StaticResource CMFT.RadioButton.ColorButton}" />
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <VirtualizingStackPanel Orientation="Horizontal" />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="自訂">
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="3*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0" Margin="2,0,5,2">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="1*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="1*" />
                                                </Grid.RowDefinitions>
                                                <TextBox
                                                    x:Name="PART_TextBlock"
                                                    materialDesign:HintAssist.Hint="Color HEX value"
                                                    FontSize="14"
                                                    Style="{StaticResource MaterialDesignFilledTextBox}"
                                                    Text="{Binding SelectedColor, Converter={converters:ColorToHexConverter}, RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <Rectangle
                                                    x:Name="PART_Rectangle"
                                                    Grid.Row="1"
                                                    Fill="{Binding SelectedColor, RelativeSource={RelativeSource Mode=TemplatedParent}, Mode=OneWay, Converter={converters:ColorToBrushConverter}}" />
                                            </Grid>

                                        </Grid>
                                        <Grid Grid.Column="1">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="1*" />
                                                <RowDefinition Height="Auto" />

                                            </Grid.RowDefinitions>
                                            <materialDesign:ColorPicker
                                                x:Name="PART_ColorPicker"
                                                HueSliderPosition="Right"
                                                Color="{Binding SelectedColor, Delay=15, RelativeSource={RelativeSource Mode=TemplatedParent}}" />
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30" />
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="1*" />
                                                </Grid.ColumnDefinitions>

                                                <UniformGrid Grid.Column="0" Style="{StaticResource UniformGridMargin5}">
                                                    <UniformGrid.Resources>
                                                        <Style x:Key="FieldLabelDefault" TargetType="{x:Type TextBlock}">
                                                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
                                                            <Setter Property="FontSize" Value="{DynamicResource FieldFontSize}" />
                                                            <Setter Property="FontWeight" Value="Bold" />
                                                            <Setter Property="VerticalAlignment" Value="Center" />
                                                        </Style>
                                                        <Style
                                                            x:Key="FieldLabelCenter"
                                                            BasedOn="{StaticResource FieldLabelDefault}"
                                                            TargetType="{x:Type TextBlock}">
                                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                                        </Style>
                                                    </UniformGrid.Resources>
                                                    <TextBlock Style="{StaticResource FieldLabelCenter}" Text="R" />
                                                    <TextBlock Style="{StaticResource FieldLabelCenter}" Text="G" />
                                                    <TextBlock Style="{StaticResource FieldLabelCenter}" Text="B" />
                                                </UniformGrid>

                                                <UniformGrid Grid.Column="2" Style="{StaticResource UniformGridMargin5}">
                                                    <Slider
                                                        x:Name="PART_RColorSlider"
                                                        VerticalAlignment="Center"
                                                        materialDesign:SliderAssist.OnlyShowFocusVisualWhileDragging="True"
                                                        Foreground="Red"
                                                        Maximum="255"
                                                        Minimum="0"
                                                        Style="{StaticResource MaterialDesign3.MaterialDesignDiscreteSlider}"
                                                        TickFrequency="1"
                                                        Value="{Binding SelectedColor.R, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" />
                                                    <Slider
                                                        x:Name="PART_GColorSlider"
                                                        VerticalAlignment="Center"
                                                        materialDesign:SliderAssist.OnlyShowFocusVisualWhileDragging="True"
                                                        Foreground="Green"
                                                        Maximum="255"
                                                        Minimum="0"
                                                        Style="{StaticResource MaterialDesign3.MaterialDesignDiscreteSlider}"
                                                        Value="{Binding SelectedColor.G, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" />

                                                    <Slider
                                                        x:Name="PART_BColorSlider"
                                                        VerticalAlignment="Center"
                                                        materialDesign:SliderAssist.OnlyShowFocusVisualWhileDragging="True"
                                                        Foreground="Blue"
                                                        Maximum="255"
                                                        Minimum="0"
                                                        Style="{StaticResource MaterialDesign3.MaterialDesignDiscreteSlider}"
                                                        Value="{Binding SelectedColor.B, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" />
                                                </UniformGrid>

                                                <UniformGrid Grid.Column="1" Style="{StaticResource UniformGridMargin5}">
                                                    <TextBox
                                                        x:Name="PART_RColorTextBox"
                                                        Padding="3"
                                                        HorizontalContentAlignment="Center"
                                                        IsEnabled="False"
                                                        IsHitTestVisible="False"
                                                        Text="{Binding SelectedColor.R, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" />

                                                    <TextBox
                                                        x:Name="PART_GColorTextBox"
                                                        Padding="3"
                                                        HorizontalContentAlignment="Center"
                                                        IsEnabled="False"
                                                        IsHitTestVisible="False"
                                                        Text="{Binding SelectedColor.G, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" />
                                                    <TextBox
                                                        x:Name="PART_BColorTextBox"
                                                        Padding="3"
                                                        HorizontalContentAlignment="Center"
                                                        IsEnabled="False"
                                                        IsHitTestVisible="False"
                                                        Text="{Binding SelectedColor.B, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" />
                                                </UniformGrid>
                                            </Grid>

                                        </Grid>

                                    </Grid>
                                </TabItem>
                            </TabControl>

                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="CMFT.Field.ColorPicker" TargetType="{x:Type customControl:ColorTool}">
        <Setter Property="SelectedColor" Value="White" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type customControl:ColorTool}">
                    <Grid>

                        <Border
                            Width="20"
                            Height="20"
                            Margin="10,0,0,0"
                            HorizontalAlignment="Left"
                            Background="{Binding Converter={converters:ColorToBrushConverter}, RelativeSource={RelativeSource TemplatedParent}, Path=SelectedColor, Mode=TwoWay}"
                            BorderBrush="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                            BorderThickness="1"
                            Visibility="{Binding Text, ElementName=PART_TextBox, Converter={StaticResource StringIsEmptyVisibilityConverter}, Mode=OneWay, UpdateSourceTrigger=LostFocus}">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Style.Triggers>
                                        <Trigger Property="IsEnabled" Value="false">
                                            <Setter Property="Opacity" Value="{x:Static materialDesign:Constants.TextBoxNotEnabledOpacity}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <TextBox
                            x:Name="PART_TextBox"
                            materialDesign:TextFieldAssist.TextBoxViewMargin="26,0,20,0"
                            Focusable="False"
                            Text="{Binding Converter={converters:ColorToHexConverter}, RelativeSource={RelativeSource TemplatedParent}, Path=SelectedColor, Mode=TwoWay}"
                            TextAlignment="Center" />
                        <materialDesign:PopupBox
                            Margin="0,0,8,0"
                            HorizontalAlignment="Right"
                            StaysOpen="True">
                            <materialDesign:PopupBox.ToggleContent>

                                <materialDesign:PackIcon
                                    x:Name="PART_PackIcon"
                                    Width="Auto"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    Kind="Palette">

                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>

                            </materialDesign:PopupBox.ToggleContent>
                            <StackPanel Orientation="Horizontal">

                                <customControl:ColorTool
                                    x:Name="PART_ColorPicker"
                                    Height="450"
                                    Margin="10,0"
                                    SelectedColor="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedColor, Mode=TwoWay}" />

                            </StackPanel>
                        </materialDesign:PopupBox>

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
