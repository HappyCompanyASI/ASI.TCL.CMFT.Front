<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Style
        x:Key="CMFT.TabControl.LeftTabStrip"
        BasedOn="{StaticResource MaterialDesignTabControl}"
        TargetType="TabControl">
        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        <Setter Property="TabStripPlacement" Value="Left" />
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="{x:Type TabItem}">
                    <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="FontSize" Value="{DynamicResource TabFontSize}" />
                    <Setter Property="Margin" Value="0,10,10,10" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type TabItem}">
                                <Border
                                    x:Name="Border"
                                    Width="80"
                                    Height="80"
                                    Padding="5"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                    <ContentControl x:Name="Content" Foreground="{TemplateBinding Foreground}">

                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <materialDesign:PackIcon
                                                Width="40"
                                                Height="{Binding Width, RelativeSource={RelativeSource Self}}"
                                                HorizontalAlignment="Center"
                                                Kind="{TemplateBinding Header}" />
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontWeight="Bold"
                                                Text="{TemplateBinding AutomationProperties.HelpText}" />
                                        </StackPanel>
                                    </ContentControl>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#1FFFFFFF" />
                                        <Setter TargetName="Border" Property="Opacity" Value="0.87" />
                                        <Setter TargetName="Border" Property="BorderThickness" Value="1" />
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.TextBox.OutlineInactiveBorder}" />
                                        <Setter TargetName="Content" Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary.Dark}" />
                                    </Trigger>

                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Content" Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary.Dark}" />
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource MaterialDesignDarkForeground}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

            </Setter.Value>
        </Setter>
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Border Background="{Binding Background, RelativeSource={RelativeSource Mode=FindAncestor, AncestorLevel=1, AncestorType={x:Type TabControl}}}" CornerRadius="10 10 10 10">
                        <ContentPresenter Content="{Binding}" />
                    </Border>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="CMFT.TabControl.TopTabStrip"
        BasedOn="{StaticResource MaterialDesignTabControl}"
        TargetType="TabControl">
        <Setter Property="TabStripPlacement" Value="Top" />
        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Background}" />
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="{x:Type TabItem}">
                    <Setter Property="Height" Value="40" />
                    <Setter Property="Margin" Value="0,0,1,-10" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Grid>
                                    <Border
                                        Name="PART_Border"
                                        Background="{Binding Background, RelativeSource={RelativeSource Mode=FindAncestor, AncestorLevel=1, AncestorType={x:Type TabControl}}}"
                                        BorderThickness="0"
                                        CornerRadius="10,10,0,0" />
                                    <TextBlock
                                        Name="PART_TextBlock"
                                        Margin="20,10"
                                        Background="{Binding Background, RelativeSource={RelativeSource Mode=FindAncestor, AncestorLevel=1, AncestorType={x:Type TabControl}}}"
                                        FontSize="{DynamicResource TabFontSize}"
                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource Mode=FindAncestor, AncestorLevel=1, AncestorType={x:Type TabControl}}}"
                                        Text="{TemplateBinding Header}" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="PART_TextBlock" Property="FontWeight" Value="Bold" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Height" Value="50" />
                                        <Setter TargetName="PART_TextBlock" Property="FontWeight" Value="Bold" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="ContentTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Border
                        Padding="10"
                        Background="{Binding Background, RelativeSource={RelativeSource Mode=FindAncestor, AncestorLevel=1, AncestorType={x:Type TabControl}}}"
                        CornerRadius="0 10 10 10">
                        <ContentPresenter Content="{Binding}" />
                    </Border>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>