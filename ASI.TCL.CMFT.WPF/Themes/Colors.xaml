<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:colors="clr-namespace:MaterialDesignColors;assembly=MaterialDesignColors"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <system:Boolean x:Key="MaterialDesign.Resources.RecreateOnThemeChange">True</system:Boolean>

    <colors:StaticResource x:Key="PrimaryHueLightBrush"
                           po:Freeze="True"
                           ResourceKey="MaterialDesign.Brush.Primary.Light" />

    <colors:StaticResource x:Key="PrimaryHueLightForegroundBrush"
                           po:Freeze="True"
                           ResourceKey="MaterialDesign.Brush.Primary.Light.Foreground" />

    <colors:StaticResource x:Key="PrimaryHueMidBrush"
                           po:Freeze="True"
                           ResourceKey="MaterialDesign.Brush.Primary" />

    <colors:StaticResource x:Key="PrimaryHueMidForegroundBrush"
                           po:Freeze="True"
                           ResourceKey="MaterialDesign.Brush.Primary.Foreground" />

    <colors:StaticResource x:Key="PrimaryHueDarkBrush"
                           po:Freeze="True"
                           ResourceKey="MaterialDesign.Brush.Primary.Dark" />

    <colors:StaticResource x:Key="PrimaryHueDarkForegroundBrush"
                           po:Freeze="True"
                           ResourceKey="MaterialDesign.Brush.Primary.Dark.Foreground" />

    <colors:StaticResource x:Key="SecondaryHueLightBrush"
                           po:Freeze="True"
                           ResourceKey="MaterialDesign.Brush.Secondary.Light" />

    <colors:StaticResource x:Key="SecondaryHueLightForegroundBrush"
                           po:Freeze="True"
                           ResourceKey="MaterialDesign.Brush.Secondary.Light.Foreground" />

    <colors:StaticResource x:Key="SecondaryHueMidBrush"
                           po:Freeze="True"
                           ResourceKey="MaterialDesign.Brush.Secondary" />

    <colors:StaticResource x:Key="SecondaryHueMidForegroundBrush"
                           po:Freeze="True"
                           ResourceKey="MaterialDesign.Brush.Secondary.Foreground" />

    <colors:StaticResource x:Key="SecondaryHueDarkBrush"
                           po:Freeze="True"
                           ResourceKey="MaterialDesign.Brush.Secondary.Dark" />

    <colors:StaticResource x:Key="SecondaryHueDarkForegroundBrush"
                           po:Freeze="True"
                           ResourceKey="MaterialDesign.Brush.Secondary.Dark.Foreground" />

    <colors:StaticResource x:Key="MaterialDesignPaper" ResourceKey="MaterialDesign.Brush.Background" />
    <colors:StaticResource x:Key="MaterialDesignFlatButtonClick" ResourceKey="MaterialDesign.Brush.Button.FlatClick" />
    <colors:StaticResource x:Key="MaterialDesignFlatButtonRipple" ResourceKey="MaterialDesign.Brush.Button.Ripple" />
    <colors:StaticResource x:Key="MaterialDesignSnackbarRipple" ResourceKey="MaterialDesign.Brush.Button.Ripple" />
    <colors:StaticResource x:Key="MaterialDesignBackground" ResourceKey="MaterialDesign.Brush.Card.Background" />
    <colors:StaticResource x:Key="MaterialDesignCardBackground" ResourceKey="MaterialDesign.Brush.Card.Background" />
    <colors:StaticResource x:Key="MaterialDesignCheckBoxDisabled" ResourceKey="MaterialDesign.Brush.CheckBox.Disabled" />
    <colors:StaticResource x:Key="MaterialDesignChipBackground" ResourceKey="MaterialDesign.Brush.Chip.Background" />
    <colors:StaticResource x:Key="MaterialDesignDataGridRowHoverBackground" ResourceKey="MaterialDesign.Brush.DataGrid.RowHoverBackground" />
    <colors:StaticResource x:Key="MaterialDesignBody" ResourceKey="MaterialDesign.Brush.Foreground" />
    <colors:StaticResource x:Key="MaterialDesignBodyLight" ResourceKey="MaterialDesign.Brush.ForegroundLight" />
    <colors:StaticResource x:Key="MaterialDesignCheckBoxOff" ResourceKey="MaterialDesign.Brush.ForegroundLight" />
    <colors:StaticResource x:Key="MaterialDesignTextBoxBorder" ResourceKey="MaterialDesign.Brush.ForegroundLight" />
    <colors:StaticResource x:Key="MaterialDesignColumnHeader" ResourceKey="MaterialDesign.Brush.Header.Foreground" />
    <colors:StaticResource x:Key="MaterialDesignTextAreaBorder" ResourceKey="MaterialDesign.Brush.Header.Foreground" />
    <colors:StaticResource x:Key="MaterialDesignSnackbarBackground" ResourceKey="MaterialDesign.Brush.SnackBar.Background" />
    <colors:StaticResource x:Key="MaterialDesignSnackbarMouseOver" ResourceKey="MaterialDesign.Brush.SnackBar.MouseOver" />
    <colors:StaticResource x:Key="MaterialDesignTextFieldBoxDisabledBackground" ResourceKey="MaterialDesign.Brush.TextBox.DisabledBackground" />
    <colors:StaticResource x:Key="MaterialDesignTextFieldBoxBackground" ResourceKey="MaterialDesign.Brush.TextBox.FilledBackground" />
    <colors:StaticResource x:Key="MaterialDesignTextFieldBoxHoverBackground" ResourceKey="MaterialDesign.Brush.TextBox.HoverBackground" />
    <colors:StaticResource x:Key="MaterialDesignDivider" ResourceKey="MaterialDesign.Brush.TextBox.HoverBackground" />
    <colors:StaticResource x:Key="MaterialDesignTextAreaInactiveBorder" ResourceKey="MaterialDesign.Brush.TextBox.OutlineInactiveBorder" />
    <colors:StaticResource x:Key="MaterialDesignToolBarBackground" ResourceKey="MaterialDesign.Brush.ToolBar.Background" />
    <colors:StaticResource x:Key="MaterialDesignToolBackground" ResourceKey="MaterialDesign.Brush.ToolBar.Item.Background" />
    <colors:StaticResource x:Key="MaterialDesignToolForeground" ResourceKey="MaterialDesign.Brush.ToolBar.Item.Foreground" />
    <colors:StaticResource x:Key="MaterialDesignToolTipBackground" ResourceKey="MaterialDesign.Brush.ToolTip.Background" />
    <colors:StaticResource x:Key="MaterialDesignValidationErrorBrush" ResourceKey="MaterialDesign.Brush.ValidationError" />

    <SolidColorBrush x:Key="MaterialDesignLightBackground" Color="#FFFAFAFA" />
    <SolidColorBrush x:Key="MaterialDesignLightForeground" Color="#DD000000" />
    <SolidColorBrush x:Key="MaterialDesignDarkBackground" Color="#FF303030" />
    <SolidColorBrush x:Key="MaterialDesignDarkForeground" Color="#FFFAFAFA" />

    <SolidColorBrush x:Key="StackOverflowGray"
                     Opacity=".5"
                     Color="LightGray" />


    <!--  DidalogHost的背景覆蓋色  -->
    <SolidColorBrush x:Key="OverlayBackgroundColor" Color="#B2000000" />
    <SolidColorBrush x:Key="AssitColor1" Color="#FFececec" />
    <SolidColorBrush x:Key="AssitColor2" Color="#FFdcdcdc" />
    <SolidColorBrush x:Key="BorderColor" Color="#BC5F5F5F" />
    <SolidColorBrush x:Key="BarBackground" Color="#FFEAEAEA" />

    <SolidColorBrush x:Key="CMFT.Brush.Dark" Color="#3d3c39" />
    <SolidColorBrush x:Key="CMFT.Brush.Light" Color="#ececec" />

    <SolidColorBrush x:Key="CMFT.Brush.Blue.Light" Color="#63a4ff" />
    <SolidColorBrush x:Key="CMFT.Brush.Blue.Mid" Color="#FF017AB1" />
    <SolidColorBrush x:Key="CMFT.Brush.Blue.Dark" Color="#FF004c78" />

    <SolidColorBrush x:Key="CMFT.Brush.Green.Light" Color="#FFA2D589" />
    <SolidColorBrush x:Key="CMFT.Brush.Green.Mid" Color="#FF38B035" />
    <SolidColorBrush x:Key="CMFT.Brush.Green.Dark" Color="#FF009A76" />

    <SolidColorBrush x:Key="CMFT.Brush.Red.Mid" Color="#C73E3A" />
    <SolidColorBrush x:Key="CMFT.Brush.Red.Dark" Color="#FFBB1C1C" />

    <SolidColorBrush x:Key="CMFT.Brush.Gray.Light" Color="#AAA" />
    <SolidColorBrush x:Key="CMFT.Brush.Gray.Dark" Color="#535353" />

    <SolidColorBrush x:Key="CMFT.Brush.Yellow.Light" Color="#FFFFDB8F" />
    <SolidColorBrush x:Key="CMFT.Brush.Yellow.Dark" Color="#FFB77E06" />

    <!--<Color x:Key="CMFT.Color.Alarm.High">#C73E3A</Color>
    <Color x:Key="CMFT.Color.Alarm.Middle">#F05E1C</Color>
    <Color x:Key="CMFT.Color.Alarm.Low">#F9BF45</Color>
    <Color x:Key="CMFT.Color.Alarm.GrayBG">#535353</Color>-->

    <Color x:Key="CMFT.Color.Alarm.High">#FF5252</Color>
    <Color x:Key="CMFT.Color.Alarm.Middle">#FF9800</Color>
    <Color x:Key="CMFT.Color.Alarm.Low">#FFD54F</Color>
    <Color x:Key="CMFT.Color.Alarm.GrayBG">#424242</Color>



    <SolidColorBrush x:Key="CMFT.Brush.Alarm.High" Color="{StaticResource CMFT.Color.Alarm.High}" />
    <SolidColorBrush x:Key="CMFT.Brush.Alarm.Middle" Color="{StaticResource CMFT.Color.Alarm.Middle}" />
    <SolidColorBrush x:Key="CMFT.Brush.Alarm.Low" Color="{StaticResource CMFT.Color.Alarm.Low}" />
    <SolidColorBrush x:Key="CMFT.Brush.Alarm.GrayBG" Color="{StaticResource CMFT.Color.Alarm.GrayBG}" />


    <SolidColorBrush x:Key="CMFT.Brush.EventAlarmDrawer" Color="#535353" />
    <SolidColorBrush x:Key="CMFT.Brush.EquipAlarmDrawer" Color="#535353" />
    <SolidColorBrush x:Key="CMFT.Brush.DLTDrawer" Color="#535353" />

</ResourceDictionary>