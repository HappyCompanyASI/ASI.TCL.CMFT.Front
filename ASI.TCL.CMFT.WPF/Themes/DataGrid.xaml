<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ASI.TCL.CMFT.WPF;component/Themes/Fields.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="CMFT.DataGrid.Border.Radius4LightGray" TargetType="{x:Type Border}">
        <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Gray.Light}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <Style
        x:Key="CMFT.DataGrid.ColumnHeader.Left"
        BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
        TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="materialDesign:DataGridAssist.ColumnHeaderPadding" Value="15,10" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="FontSize" Value="{DynamicResource DataGridHeaderSize}" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style
        x:Key="CMFT.DataGrid.ColumnHeader.Center"
        BasedOn="{StaticResource CMFT.DataGrid.ColumnHeader.Left}"
        TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style
        x:Key="CMFT.DataGrid.ColumnHeader.Right"
        BasedOn="{StaticResource CMFT.DataGrid.ColumnHeader.Left}"
        TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="HorizontalContentAlignment" Value="Right" />
    </Style>

    <Style
        x:Key="CMFT.DataGrid.Cell"
        BasedOn="{StaticResource MaterialDesignDataGridCell}"
        TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="15,10" />
        <Setter Property="FontSize" Value="{DynamicResource DataGridFontSize}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="Auto" />
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="1" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="CMFT.DataGrid.Cell.SmallPadding"
        BasedOn="{StaticResource CMFT.DataGrid.Cell}"
        TargetType="DataGridCell">
        <Setter Property="Padding" Value="15,5,15,5" />
    </Style>
    <Style
        x:Key="CMFT.DataGrid.Cell.NoPadding"
        BasedOn="{StaticResource CMFT.DataGrid.Cell}"
        TargetType="DataGridCell">
        <Setter Property="Padding" Value="0" />
    </Style>
    <Style
        x:Key="CMFT.DataGrid.Cell.Vertical"
        BasedOn="{StaticResource CMFT.DataGrid.Cell}"
        TargetType="DataGridCell">
        <Setter Property="Padding" Value="0,5" />
        <Style.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True" />
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="False" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="Transparent" />
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="CMFT.DataGrid.Cell.Vertical.NoPadding"
        BasedOn="{StaticResource CMFT.DataGrid.Cell}"
        TargetType="DataGridCell">
        <Setter Property="Padding" Value="0" />
        <Style.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True" />
                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="False" />
                </MultiDataTrigger.Conditions>
                <Setter Property="Background" Value="Transparent" />
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="CMFT.DataGrid.Row"
        BasedOn="{StaticResource MaterialDesignDataGridRow}"
        TargetType="{x:Type DataGridRow}" />

    <Style
        x:Key="CMFT.DataGrid.RowHeader"
        BasedOn="{StaticResource MaterialDesignDataGridRowHeader}"
        TargetType="{x:Type DataGridRowHeader}" />

    <Style
        x:Key="CMFT.DataGrid.Element.TextBlock.Left"
        BasedOn="{StaticResource MaterialDesignDataGridTextColumnStyle}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground}" />
        <Setter Property="FontSize" Value="{DynamicResource DataGridFontSize}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="1" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style
        x:Key="CMFT.DataGrid.Element.TextBlock.Left.SmallFontSize"
        BasedOn="{StaticResource CMFT.DataGrid.Element.TextBlock.Left}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="{DynamicResource DataGridContentSize}" />
    </Style>
    <Style
        x:Key="CMFT.DataGrid.Element.TextBlock.Center"
        BasedOn="{StaticResource CMFT.DataGrid.Element.TextBlock.Left}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <Style
        x:Key="CMFT.DataGrid.Element.TextBlock.Center.SmallFontSize"
        BasedOn="{StaticResource CMFT.DataGrid.Element.TextBlock.Left}"
        TargetType="{x:Type TextBlock}">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="FontSize" Value="{DynamicResource DataGridContentSize}" />
    </Style>
    <Style
        x:Key="CMFT.DataGrid.Element.ComboBox.Left"
        BasedOn="{StaticResource MaterialDesignDataGridComboBox}"
        TargetType="ComboBox">
        <Setter Property="Padding" Value="0,0,8,0" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="False" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="{x:Null}" />

        <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Light}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Light}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Light}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style
        x:Key="CMFT.DataGrid"
        BasedOn="{StaticResource MaterialDesignDataGrid}"
        TargetType="{x:Type DataGrid}">
        <Setter Property="materialDesign:DataGridAssist.CornerRadius" Value="0" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CanUserSortColumns" Value="True" />
        <Setter Property="CanUserResizeRows" Value="False" />
        <Setter Property="CanUserResizeColumns" Value="True" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="VerticalScrollBarVisibility" Value="Visible" />
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource CMFT.DataGrid.ColumnHeader.Left}" />
        <!--
            刪除最後一行空白行
            ScrollViewer.CanContentScroll="False"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
        -->
        <!--  性能優化 START  -->
        <!--  ScrollViewer.CanContentScroll  -->
        <!--  此設定是設定滾動條的滾動方式，而非是否可以滾動  -->
        <!--  (項目滾動)為 True  速度快 滾動不絲滑,且會多最後空白行,但效率高  -->
        <!--  (像素滾動)為 False 速度慢 滾動絲滑  -->
        <!--  False情況下，整個控制項的虛擬化會取消，即便設定了 VirtualizingPanel.IsVirtualizing="True" 也沒用；  -->
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.IsContainerVirtualizable" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="EnableColumnVirtualization" Value="True" />
        <Setter Property="EnableRowVirtualization" Value="True" />
        <!--  性能優化 END  -->

        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.8" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>