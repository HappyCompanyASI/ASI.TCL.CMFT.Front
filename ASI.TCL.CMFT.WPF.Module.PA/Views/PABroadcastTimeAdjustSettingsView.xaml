<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.PA.Views.PABroadcastTimeAdjustSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:PABroadcastTimeAdjustSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="6*" />
            </Grid.ColumnDefinitions>

            <ListBox
                x:Name="StationBroadcastSchedulesListBox"
                Grid.Column="0"
                ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                ItemsSource="{Binding PAStationBroadcastSchedules}"
                ScrollViewer.VerticalScrollBarVisibility="Visible"
                SelectedItem="{Binding SelectedStationBroadcast}"
                SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type dtos:PAStationBroadcastScheduleDto}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="50" Text="{Binding Station.StationID}" />
                            <TextBlock Text="[Station Name]" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ListBox
                x:Name="DailyBroadcastSchedulesListBox"
                Grid.Column="1"
                d:ItemsSource="{x:Static datas:DesignTimeDatas.PADayOfWeeks}"
                ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                ItemsSource="{Binding SelectedItem.DailySchedules, ElementName=StationBroadcastSchedulesListBox}"
                ScrollViewer.VerticalScrollBarVisibility="Visible"
                SelectedItem="{Binding SelectedDailyBroadcast}"
                SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type dtos:PADailyBroadcastScheduleDto}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Width="50" Text="{Binding DayDisplay}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ListView
                Grid.Column="2"
                d:ItemsSource="{x:Static datas:DesignTimeDatas.PADaypartTimes}"
                ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
                ItemsSource="{Binding SelectedItem.DaypartTimes, ElementName=DailyBroadcastSchedulesListBox}"
                SelectedItem="{Binding SelectedTimeSlot}"
                SelectionMode="Single">
                <b:Interaction.Behaviors>
                    <!--  自訂Behavior來避免combobox的SelectionChanged事件bubble到ListViewItem  -->
                    <behaviors:ListViewSelectionChangedBehavior Command="{Binding CancelEditOnSelectionChangedCommand}" />
                </b:Interaction.Behaviors>
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">

                        <GridViewColumn Width="120" Header="開始日">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:PATimeSlotDto}">
                                    <!--<ComboBox
                                        ItemsSource="{x:Static datas:DesignTimeDatas.DayTypes}"
                                        SelectedItem="{Binding StartDayType}"
                                        Style="{StaticResource GridView.Column.ComboBox.Center}" />-->
                                    <Grid>
                                        <!--  ComboBox 編輯  資料名稱綁定:DisplayMemberPath  -->
                                        <ComboBox
                                            x:Name="StartDayTypeComboBox"
                                            ItemsSource="{x:Static datas:DesignTimeDatas.DayTypes}"
                                            SelectedItem="{Binding StartDayType}"
                                            Style="{StaticResource GridView.Column.ComboBox.Center}"
                                            Visibility="Collapsed" />
                                        <!--  TextBlock 檢視  -->
                                        <TextBlock
                                            x:Name="StartDayTypeTextBlock"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                            Text="{Binding StartDayType}"
                                            Visibility="Visible" />
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="StartDayTypeComboBox" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="StartDayTypeTextBlock" Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="160" Header="開始時間">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:PATimeSlotDto}">
                                    <!--<materialDesign:TimePicker SelectedTime="{Binding StartTime}" Style="{StaticResource GridView.Column.TimePicker.Center}" />-->
                                    <Grid>
                                        <!--  ComboBox 編輯  資料名稱綁定:DisplayMemberPath  -->
                                        <materialDesign:TimePicker
                                            x:Name="StartTimeComboBox"
                                            SelectedTime="{Binding StartTime}"
                                            Style="{StaticResource GridView.Column.TimePicker.Center}"
                                            Visibility="Collapsed" />
                                        <!--  TextBlock 檢視  -->
                                        <TextBlock
                                            x:Name="StartTimeTextBlock"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                            Text="{Binding StartTime, StringFormat='{}{0:HH:mm}'}"
                                            Visibility="Visible" />
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="StartTimeComboBox" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="StartTimeTextBlock" Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="120" Header="結束日">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:PATimeSlotDto}">
                                    <!--<ComboBox
                                        ItemsSource="{x:Static datas:DesignTimeDatas.DayTypes}"
                                        SelectedItem="{Binding EndDayType}"
                                        Style="{StaticResource GridView.Column.ComboBox.Center}" />-->
                                    <Grid>
                                        <!--  ComboBox 編輯  資料名稱綁定:DisplayMemberPath  -->
                                        <ComboBox
                                            x:Name="EndDayTypeComboBox"
                                            ItemsSource="{x:Static datas:DesignTimeDatas.DayTypes}"
                                            SelectedItem="{Binding EndDayType}"
                                            Style="{StaticResource GridView.Column.ComboBox.Center}"
                                            Visibility="Collapsed" />
                                        <!--  TextBlock 檢視  -->
                                        <TextBlock
                                            x:Name="EndDayTypeTextBlock"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                            Text="{Binding EndDayType}"
                                            Visibility="Visible" />
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="EndDayTypeComboBox" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="EndDayTypeTextBlock" Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="160" Header="結束時間">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:PATimeSlotDto}">
                                    <!--<materialDesign:TimePicker SelectedTime="{Binding EndTime}" Style="{StaticResource GridView.Column.TimePicker.Center}" />-->
                                    <Grid>
                                        <!--  ComboBox 編輯  資料名稱綁定:DisplayMemberPath  -->
                                        <materialDesign:TimePicker
                                            x:Name="EndTimeComboBox"
                                            SelectedTime="{Binding EndTime}"
                                            Style="{StaticResource GridView.Column.TimePicker.Center}"
                                            Visibility="Collapsed" />
                                        <!--  TextBlock 檢視  -->
                                        <TextBlock
                                            x:Name="EndTimeTextBlock"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                            Text="{Binding EndTime, StringFormat='{}{0:HH:mm}'}"
                                            Visibility="Visible" />
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="EndTimeComboBox" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="EndTimeTextBlock" Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="160" Header="時段類型">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:PATimeSlotDto}">
                                    <!--<ComboBox
                                        ItemsSource="{x:Static datas:DesignTimeDatas.DaypartTypes}"
                                        SelectedItem="{Binding DayPartType}"
                                        Style="{StaticResource GridView.Column.ComboBox.Center}" />-->
                                    <Grid>
                                        <!--  ComboBox 編輯  資料名稱綁定:DisplayMemberPath  -->
                                        <ComboBox
                                            x:Name="DayPartTypeComboBox"
                                            ItemsSource="{x:Static datas:DesignTimeDatas.DaypartTypes}"
                                            SelectedItem="{Binding DayPartType}"
                                            Style="{StaticResource GridView.Column.ComboBox.Center}"
                                            Visibility="Collapsed" />
                                        <!--  TextBlock 檢視  -->
                                        <TextBlock
                                            x:Name="DayPartTypeTextBlock"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                            Text="{Binding DayPartType}"
                                            Visibility="Visible" />
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="DayPartTypeComboBox" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="DayPartTypeTextBlock" Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>


                </ListView.View>
            </ListView>
        </Grid>
        <UniformGrid
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Columns="1"
            Style="{StaticResource PanelMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding AddItemCommand}"
                ContentTemplate="{StaticResource AddItemData}"
                Style="{StaticResource AddButton}"
                Visibility="{Binding IsGroupOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding DeleteItemCommand}"
                ContentTemplate="{StaticResource DeleteItemData}"
                Style="{StaticResource DeleteButton}"
                Visibility="{Binding CanItemAddDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}"
                Visibility="{Binding IsItemOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </UniformGrid>
    </Grid>

</UserControl>
