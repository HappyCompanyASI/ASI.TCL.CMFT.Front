<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.PA.Views.PAScheduleTemplateSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:PAScheduleTemplateSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>
            <ListBox
                x:Name="ScheduleTemplatesListBox"
                Grid.Column="0"
                ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                ItemsSource="{Binding PAScheduleTemplates}"
                ScrollViewer.VerticalScrollBarVisibility="Visible"
                SelectedIndex="0"
                SelectedItem="{Binding SelectedTemplate}"
                SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type dtos:PAScheduleTemplateDto}">
                        <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding ScheduleName}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <prism:InvokeCommandAction Command="{Binding CancelEditOnSelectionChangedCommand}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </ListBox>
            <TabControl
                x:Name="VoiceTypeTab"
                Grid.Column="1"
                d:DataContext="{d:DesignInstance Type=dtos:PAScheduleTemplateDto,
                                                 IsDesignTimeCreatable=False}"
                DataContext="{Binding SelectedItem, ElementName=ScheduleTemplatesListBox}"
                SelectedIndex="{Binding DataContext.SelectedTabIndex, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}">
                <TabItem Header="設定結果" IsHitTestVisible="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <GroupBox
                            Grid.Column="0"
                            Margin="10,20"
                            Header="已設定時程"
                            IsHitTestVisible="False">
                            <StackPanel VerticalAlignment="Top" Style="{StaticResource PanelMargin3}">
                                <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="排程名稱" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    Text="{Binding ScheduleName}" />
                                <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="開始日時" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Text="{Binding StartDayType}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="4,0,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Text="{Binding StartTime, StringFormat={}{0:HH:mm}}" />
                                </Grid>
                                <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="結束日時" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Text="{Binding EndDayType}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Margin="4,0,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        Text="{Binding EndTime, StringFormat={}{0:HH:mm}}" />
                                </Grid>
                            </StackPanel>
                        </GroupBox>
                        <GroupBox
                            Grid.Column="1"
                            Margin="10,20"
                            Header="已選擇目標"
                            IsHitTestVisible="True">
                            <ListBox
                                d:ItemsSource="{x:Static datas:DesignTimeDatas.SYSStations}"
                                IsHitTestVisible="True"
                                ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                                ItemsSource="{Binding DataContext.SelectedStationsView, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                ScrollViewer.VerticalScrollBarVisibility="Visible"
                                SelectedIndex="-1"
                                SelectionMode="Single">
                                <ListBox.ItemContainerStyle>
                                    <Style BasedOn="{StaticResource MaterialDesignListBoxItem}" TargetType="{x:Type ListBoxItem}">
                                        <Setter Property="IsHitTestVisible" Value="False" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type dtos:SYSStationDto}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Width="50" Text="{Binding StationID}" />
                                            <TextBlock Text="[Station Name]" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </GroupBox>
                        <GroupBox
                            Grid.Column="2"
                            Margin="10,20"
                            d:DataContext="{x:Static datas:DesignTimeDatas.PAPreRecordVoices}"
                            DataContext="{Binding Content}"
                            Header="已選擇內容"
                            IsHitTestVisible="False">
                            <Grid Style="{StaticResource PanelMargin3}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="1*" />
                                    <RowDefinition Height="5*" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="24"
                                    FontWeight="Bold"
                                    Text="{Binding VoiceName}" />
                                <Border
                                    Grid.Row="1"
                                    Margin="10,30"
                                    Padding="8"
                                    Background="Transparent"
                                    BorderBrush="LightGray"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                    <TextBlock
                                        VerticalAlignment="Stretch"
                                        FontSize="16"
                                        IsHitTestVisible="False"
                                        Text="{Binding VoiceContent}"
                                        TextWrapping="Wrap" />
                                </Border>
                            </Grid>
                        </GroupBox>
                    </Grid>
                </TabItem>
                <TabItem Header="時程設定" Visibility="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel
                        Margin="300,50"
                        VerticalAlignment="Top"
                        Style="{StaticResource PanelMargin3}">
                        <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="排程名稱" />
                        <TextBox Text="{Binding ScheduleName}" />
                        <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="開始日時" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox
                                Grid.Column="0"
                                ItemsSource="{x:Static datas:DesignTimeDatas.DayTypes}"
                                SelectedItem="{Binding StartDayType}" />
                            <materialDesign:TimePicker
                                Grid.Column="1"
                                Margin="4,0,0,0"
                                SelectedTime="{Binding StartTime}" />
                        </Grid>
                        <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="結束日時" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox
                                Grid.Column="0"
                                ItemsSource="{x:Static datas:DesignTimeDatas.DayTypes}"
                                SelectedItem="{Binding EndDayType}" />

                            <materialDesign:TimePicker
                                Grid.Column="1"
                                Margin="4,0,0,0"
                                SelectedTime="{Binding EndTime}" />
                        </Grid>
                    </StackPanel>
                </TabItem>
                <TabItem Header="目標設定" Visibility="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Style="{StaticResource GridMargin5}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <GroupBox Grid.Column="0" Header="目標">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>
                                <ListBox
                                    x:Name="TargetGroupListBox"
                                    Grid.Column="0"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemTemplate="{StaticResource SYSStationGroup}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                                    ItemsSource="{Binding DataContext.SYSStationGroups, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    ScrollViewer.VerticalScrollBarVisibility="Visible"
                                    SelectedIndex="0"
                                    SelectedItem="{Binding DataContext.SelectedStationGroup, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    SelectionMode="Single"
                                    Style="{StaticResource MaterialDesignListBox}" />
                                <ListBox
                                    x:Name="TargetListBox"
                                    Grid.Column="1"
                                    Margin="5,0,0,0"
                                    d:ItemsSource="{x:Static datas:DesignTimeDatas.SYSStations}"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                                    ItemsSource="{Binding DataContext.UnselectedStationsView, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    ScrollViewer.VerticalScrollBarVisibility="Visible"
                                    SelectionMode="Single">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Button
                                                Command="{Binding DataContext.SelectStationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="{Binding StationID}"
                                                Style="{StaticResource SelecterButton}" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </GroupBox>
                        <GroupBox Grid.Column="1" Header="已選擇目標">
                            <ListBox
                                x:Name="SelectedTargetListBox"
                                d:ItemsSource="{x:Static datas:DesignTimeDatas.SYSStations}"
                                ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                                ItemsSource="{Binding DataContext.SelectedStationsView, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                ScrollViewer.VerticalScrollBarVisibility="Visible"
                                SelectionMode="Single">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Button
                                            Command="{Binding DataContext.SelectStationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding StationID}"
                                            Style="{StaticResource SelecterButton}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </GroupBox>
                    </Grid>
                </TabItem>
                <TabItem Header="內容設定" Visibility="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>

                        <ListBox
                            x:Name="ContentGroupListBox"
                            Grid.Column="0"
                            ItemContainerStyle="{StaticResource StretchListBoxItem}"
                            ItemTemplate="{StaticResource PAVoiceGroup}"
                            ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                            ItemsSource="{Binding DataContext.PAVoiceGroups, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            ScrollViewer.VerticalScrollBarVisibility="Visible"
                            SelectedItem="{Binding DataContext.SelectedVoiceGroup, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            SelectionMode="Single" />

                        <ListBox
                            x:Name="ContentListBox"
                            Grid.Column="1"
                            d:ItemsSource="{x:Static datas:DesignTimeDatas.PAPreRecordVoices}"
                            ItemContainerStyle="{StaticResource StretchListBoxItem}"
                            ItemTemplate="{StaticResource PAPreRecordVoice}"
                            ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                            ItemsSource="{Binding SelectedItem.Voices, ElementName=ContentGroupListBox}"
                            ScrollViewer.VerticalScrollBarVisibility="Visible"
                            SelectedItem="{Binding DataContext.SelectedTemplate.Content, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            SelectionMode="Single" />

                        <GroupBox
                            Grid.Column="2"
                            Margin="10,5"
                            d:DataContext="{x:Static datas:DesignTimeDatas.PAPreRecordVoices}"
                            DataContext="{Binding SelectedItem, ElementName=ContentListBox}"
                            Header="播放內容">
                            <Grid Margin="5" Style="{StaticResource PanelMargin3}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="1*" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Button
                                    Grid.Row="0"
                                    Height="60"
                                    Content="{Binding VoiceName}"
                                    FontSize="{StaticResource ButtonFontSize_Large}"
                                    FontWeight="Bold"
                                    Style="{StaticResource WPF.Button}" />
                                <TextBox
                                    Grid.Row="1"
                                    Margin="10"
                                    VerticalAlignment="Stretch"
                                    IsHitTestVisible="False"
                                    Text="{Binding VoiceContent}"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </GroupBox>
                    </Grid>

                </TabItem>
            </TabControl>
        </Grid>

        <UniformGrid
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Style="{StaticResource UniformGridMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding AddItemCommand}"
                ContentTemplate="{StaticResource AddItemData}"
                Style="{StaticResource AddButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource FalseValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding DeleteItemCommand}"
                ContentTemplate="{StaticResource DeleteItemData}"
                Style="{StaticResource DeleteButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource FalseValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}"
                Visibility="{Binding IsItemOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </UniformGrid>

    </Grid>

</UserControl>
