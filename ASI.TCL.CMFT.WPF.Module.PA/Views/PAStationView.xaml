<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.PA.Views.PAStationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:applications="clr-namespace:ASI.TCL.CMFT.WPF.Applications;assembly=ASI.TCL.CMFT.WPF"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.Converters"
    xmlns:converters1="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataTypes="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.DataTypes"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.Datas"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:triggerActions="clr-namespace:ASI.TCL.CMFT.WPF.TriggerActions;assembly=ASI.TCL.CMFT.WPF"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:PAStationViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="7*" />
        </Grid.ColumnDefinitions>

        <!--#region 操作流程-->
        <GroupBox
            Grid.RowSpan="3"
            Grid.Column="0"
            Margin="0,5"
            Header="操作流程"
            IsHitTestVisible="False">
            <Grid>
                <Grid.Resources>
                    <Style BasedOn="{StaticResource StepRadioButton}" TargetType="{x:Type ToggleButton}" />
                    <Style BasedOn="{StaticResource MainTitleTextBox}" TargetType="{x:Type TextBlock}" />
                </Grid.Resources>
                <UniformGrid VerticalAlignment="Top" Style="{StaticResource UniformGridMargin5}">
                    <ToggleButton Content="1.目標選擇" IsChecked="{Binding CurrentStep, Converter={converters:StepToIsCheckedConverter}, ConverterParameter={x:Static dataTypes:eStep.Step1}}" />
                    <ToggleButton Content="2.方式及內容選擇" IsChecked="{Binding CurrentStep, Converter={converters:StepToIsCheckedConverter}, ConverterParameter={x:Static dataTypes:eStep.Step2}}" />
                    <ToggleButton Content="3.開始播送" IsChecked="{Binding CurrentStep, Converter={converters:StepToIsCheckedConverter}, ConverterParameter={x:Static dataTypes:eStep.Step3}}" />
                </UniformGrid>
                <TextBlock Text="車站語音廣播" />
            </Grid>
        </GroupBox>
        <!--#endregion-->

        <UniformGrid Grid.Column="1" Columns="1">

            <!--#region 1.目標選擇-->
            <Grid
                d:Visibility="Visible"
                Style="{StaticResource GridMargin5}"
                Visibility="{Binding CurrentStep, Converter={converters1:EqualityToVisibilityConverter}, ConverterParameter={x:Static dataTypes:eStep.Step1}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="7*" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <GroupBox Grid.Column="0" Header="目標">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <ListBox
                            x:Name="TargetGroupListBox"
                            Grid.Column="0"
                            ItemContainerStyle="{StaticResource StretchListBoxItem}"
                            ItemTemplate="{StaticResource SYSStationGroup}"
                            ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                            ItemsSource="{x:Static datas:DesignTimeDatas.SYSStationGroups}"
                            SelectedIndex="0"
                            SelectionMode="Single"
                            Style="{StaticResource MaterialDesignListBox}">
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="SelectionChanged">
                                    <triggerActions:DoNothingTriggerAction
                                        OperationID="1"
                                        Source="{Binding ItemsSource, ElementName=SelectedTargetListBox}"
                                        Target="{Binding SelectedItems, ElementName=TargetListBox}"
                                        TargetOperation="Add" />
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                        </ListBox>
                        <ListBox
                            x:Name="TargetListBox"
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            d:ItemsSource="{x:Static datas:DesignTimeDatas.SYSStations}"
                            ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                            ItemsSource="{Binding SelectedItem.Stations, ElementName=TargetGroupListBox}"
                            SelectionMode="Multiple">
                            <ListBox.ItemContainerStyle>
                                <Style BasedOn="{StaticResource StretchListBoxItem}" TargetType="ListBoxItem">
                                    <!--  要設定ListBoxItem的不是RadioButton的IsEnabled  -->
                                    <Setter Property="IsEnabled" Value="{Binding IsSelected, RelativeSource={RelativeSource Self}, Converter={converters1:BoolNegationConverter}}" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton Style="{StaticResource SelecterRadioButton}">
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger EventName="Checked">
                                                <triggerActions:DoNothingTriggerAction
                                                    OperationID="2"
                                                    Source="{Binding SelectedItems, ElementName=TargetListBox}"
                                                    Target="{Binding ItemsSource, ElementName=SelectedTargetListBox}"
                                                    TargetOperation="Add" />
                                            </b:EventTrigger>
                                        </b:Interaction.Triggers>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding StationID}" />
                                        </StackPanel>
                                    </RadioButton>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </GroupBox>
                <GroupBox Grid.Column="1" Header="已選擇目標">
                    <ListBox
                        x:Name="SelectedTargetListBox"
                        d:ItemsSource="{x:Static datas:DesignTimeDatas.SYSStations}"
                        ItemContainerStyle="{StaticResource StretchListBoxItem}"
                        ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                        ItemsSource="{Binding SelectedTargets}"
                        SelectionMode="Multiple">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <RadioButton
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorLevel=1, AncestorType=UserControl, Mode=FindAncestor}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource SelecterRadioButton}">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="Checked">
                                            <triggerActions:DoNothingTriggerAction
                                                OperationID="3"
                                                Source="{Binding SelectedItems, ElementName=SelectedTargetListBox}"
                                                Target="{Binding SelectedItems, ElementName=TargetListBox}"
                                                TargetOperation="Remove" />
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding StationID}" />
                                    </StackPanel>
                                </RadioButton>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>
                <UniformGrid Grid.Column="2" Columns="1">
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Top"
                        Command="{x:Static applications:WPFApplicationCommands.NavigateCommand}"
                        CommandParameter="{x:Static datas:NavigatePath.PAMain}"
                        Content="取消"
                        Style="{StaticResource NaviStepButton}" />
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Bottom"
                        Command="{Binding StepChangeCommand}"
                        CommandParameter="{x:Static dataTypes:eStep.Step2}"
                        Content="下一步"
                        Style="{StaticResource StepButton}" />
                </UniformGrid>
            </Grid>
            <!--#endregion-->

            <!--#region 2.廣播方式及內容-->
            <Grid
                d:Visibility="Visible"
                Style="{StaticResource GridMargin5}"
                Visibility="{Binding CurrentStep, Converter={converters1:EqualityToVisibilityConverter}, ConverterParameter={x:Static dataTypes:eStep.Step2}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="7*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <GroupBox
                    Grid.Column="0"
                    Header="已選擇目標"
                    IsHitTestVisible="False">
                    <ListBox
                        d:ItemsSource="{x:Static datas:DesignTimeDatas.SYSStations}"
                        Background="{StaticResource ReadOnlyColor}"
                        IsHitTestVisible="False"
                        ItemContainerStyle="{StaticResource StretchListBoxItem}"
                        ItemTemplate="{StaticResource SYSStation}"
                        ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                        ItemsSource="{Binding SelectedTargets}" />
                </GroupBox>
                <GroupBox Grid.Column="1" Header="方式及內容">
                    <TabControl x:Name="VoiceTypeTab">
                        <TabItem Header="預錄廣播">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1.5*" />
                                </Grid.ColumnDefinitions>

                                <ListBox
                                    x:Name="ContentGroupListBox"
                                    Grid.Column="0"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemTemplate="{StaticResource PAVoiceGroup}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                                    ItemsSource="{x:Static datas:DesignTimeDatas.PAVoiceGroups}"
                                    SelectedIndex="0"
                                    SelectionMode="Single" />

                                <ListBox
                                    x:Name="ContentListBox"
                                    Grid.Column="1"
                                    d:ItemsSource="{x:Static datas:DesignTimeDatas.PAPreRecordVoices}"
                                    ItemContainerStyle="{StaticResource StretchListBoxItem}"
                                    ItemTemplate="{StaticResource PAPreRecordVoice}"
                                    ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                                    ItemsSource="{Binding SelectedItem.Voices, ElementName=ContentGroupListBox}"
                                    SelectedItem="{Binding SelectedVoice}"
                                    SelectionMode="Single" />

                                <GroupBox
                                    Grid.Column="2"
                                    Margin="10,5"
                                    d:DataContext="{x:Static datas:DesignTimeDatas.PAPreRecordVoices}"
                                    DataContext="{Binding SelectedItem, ElementName=ContentListBox}"
                                    Header="播放內容">

                                    <Grid Style="{StaticResource PanelMargin3}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="1*" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Button
                                            Grid.Row="0"
                                            Height="60"
                                            Command="{Binding DataContext.DseleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Content="{Binding VoiceName}"
                                            FontSize="{StaticResource ButtonFontSize_Large}"
                                            FontWeight="Bold"
                                            Style="{StaticResource WPF.Button}" />
                                        <TextBox
                                            Grid.Row="1"
                                            VerticalAlignment="Stretch"
                                            IsHitTestVisible="False"
                                            Text="{Binding VoiceContent}"
                                            TextWrapping="Wrap" />
                                        <UniformGrid
                                            Grid.Row="2"
                                            HorizontalAlignment="Center"
                                            Columns="4"
                                            Style="{StaticResource PanelMargin5}">
                                            <ToggleButton
                                                Padding="12,4"
                                                HorizontalAlignment="Center"
                                                Content="國"
                                                FontSize="{StaticResource ButtonFontSize_Large}"
                                                FontWeight="Bold"
                                                IsChecked="{Binding DataContext.IsChineseSelected, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IsEnabled="{Binding IsIncludeCHN}"
                                                Style="{StaticResource WPF.ToggleButton}" />
                                            <ToggleButton
                                                Padding="12,4"
                                                HorizontalAlignment="Center"
                                                Content="台"
                                                FontSize="{StaticResource ButtonFontSize_Large}"
                                                FontWeight="Bold"
                                                IsChecked="{Binding DataContext.IsTaiwaneseSelected, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IsEnabled="{Binding IsIncludeTWN}"
                                                Style="{StaticResource WPF.ToggleButton}" />
                                            <ToggleButton
                                                Padding="12,4"
                                                HorizontalAlignment="Center"
                                                Content="客"
                                                FontSize="{StaticResource ButtonFontSize_Large}"
                                                FontWeight="Bold"
                                                IsChecked="{Binding DataContext.IsHakkaSelected, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IsEnabled="{Binding IsIncludeHAKKA}"
                                                Style="{StaticResource WPF.ToggleButton}" />
                                            <ToggleButton
                                                Padding="12,4"
                                                HorizontalAlignment="Center"
                                                Content="英"
                                                FontSize="{StaticResource ButtonFontSize_Large}"
                                                FontWeight="Bold"
                                                IsChecked="{Binding DataContext.IsEnglishSelected, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                IsEnabled="{Binding IsIncludeENG}"
                                                Style="{StaticResource WPF.ToggleButton}" />
                                        </UniformGrid>


                                        <UniformGrid
                                            Grid.Row="3"
                                            HorizontalAlignment="Stretch"
                                            Columns="3"
                                            Style="{StaticResource PanelMargin5}">
                                            <StackPanel Orientation="Vertical">
                                                <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="播放次數" />
                                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                    <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="[" />
                                                    <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="1~10" />
                                                    <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="]" />
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBox x:Name="PlayCountTextBox" HorizontalContentAlignment="Center">
                                                <TextBox.Style>
                                                    <Style BasedOn="{StaticResource CMFT.Field.TextBox}" TargetType="TextBox">
                                                        <Setter Property="Text" Value="{Binding DataContext.PlayCount, RelativeSource={RelativeSource AncestorType=UserControl}, UpdateSourceTrigger=PropertyChanged}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked, ElementName=InfinityRadioButton, Mode=TwoWay}" Value="True">
                                                                <Setter Property="Text" Value="∞" />
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                            <ToggleButton
                                                x:Name="InfinityRadioButton"
                                                Margin="10"
                                                HorizontalAlignment="Stretch"
                                                FontWeight="Bold"
                                                IsChecked="{Binding DataContext.IsInfinitePlayback, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                Style="{StaticResource WPF.ToggleButton}">

                                                <materialDesign:PackIcon
                                                    Width="25"
                                                    Height="25"
                                                    Kind="Infinity" />
                                            </ToggleButton>
                                        </UniformGrid>
                                    </Grid>
                                </GroupBox>
                            </Grid>

                        </TabItem>
                        <TabItem Header="即時廣播">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="150"
                                    Height="150"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Kind="AlertOutline" />
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="45"
                                        Style="{StaticResource CMFT.TextBlock.Center}"
                                        Text="請按撥放按鈕" />
                                    <TextBlock
                                        FontSize="45"
                                        Style="{StaticResource CMFT.TextBlock.Center}"
                                        Text="開始語音控制" />
                                </StackPanel>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </GroupBox>
                <UniformGrid Grid.Column="2" Columns="1">
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Top"
                        Command="{Binding StepChangeCommand}"
                        CommandParameter="{x:Static dataTypes:eStep.Step1}"
                        Content="上一步"
                        Style="{StaticResource StepButton}" />
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Bottom"
                        Command="{Binding StepChangeCommand}"
                        CommandParameter="{x:Static dataTypes:eStep.Step3}"
                        Content="播放"
                        Style="{StaticResource StepButton}" />
                </UniformGrid>
            </Grid>
            <!--#endregion-->

            <!--#region 3.開始撥放-->
            <Grid
                d:Visibility="Visible"
                Style="{StaticResource GridMargin5}"
                Visibility="{Binding CurrentStep, Converter={converters1:EqualityToVisibilityConverter}, ConverterParameter={x:Static dataTypes:eStep.Step3}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="7*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <GroupBox
                    Grid.Column="0"
                    Header="已選擇目標"
                    IsHitTestVisible="False">
                    <ListBox
                        d:ItemsSource="{x:Static datas:DesignTimeDatas.SYSStations}"
                        Background="{StaticResource ReadOnlyColor}"
                        IsHitTestVisible="False"
                        ItemContainerStyle="{StaticResource StretchListBoxItem}"
                        ItemTemplate="{StaticResource SYSStation}"
                        ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                        ItemsSource="{Binding SelectedTargets}" />
                </GroupBox>
                <GroupBox Grid.Column="1" Header="開始播送">
                    <TabControl d:SelectedIndex="1" SelectedIndex="{Binding SelectedIndex, ElementName=VoiceTypeTab}">

                        <TabItem Visibility="Collapsed">
                            <StackPanel
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center"
                                Orientation="Vertical">

                                <Button
                                    Padding="120,15"
                                    HorizontalAlignment="Center"
                                    Content="{Binding SelectedItem.VoiceName, ElementName=ContentListBox}"
                                    FontSize="{StaticResource ButtonFontSize_Large}"
                                    FontWeight="Bold"
                                    Style="{StaticResource WPF.Button}" />

                                <StackPanel
                                    Margin="0,50,0,0"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource StackPanelHorizontalMargin10}">
                                    <RadioButton
                                        Padding="12,4"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource WPF.RadioButton.ButtonLike}">
                                        <materialDesign:PackIcon
                                            Width="30"
                                            Height="30"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Kind="Play" />
                                    </RadioButton>
                                    <RadioButton
                                        Padding="12,4"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource WPF.RadioButton.ButtonLike}">
                                        <materialDesign:PackIcon
                                            Width="30"
                                            Height="30"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Kind="Pause" />
                                    </RadioButton>
                                    <RadioButton
                                        Padding="12,4"
                                        HorizontalAlignment="Center"
                                        Style="{StaticResource WPF.RadioButton.ButtonLike}">
                                        <materialDesign:PackIcon
                                            Width="30"
                                            Height="30"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Kind="Stop" />
                                    </RadioButton>
                                </StackPanel>
                            </StackPanel>
                        </TabItem>

                        <TabItem Visibility="Collapsed">
                            <Grid>
                                <StackPanel
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="150"
                                        Height="150"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Kind="AlertOutline" />
                                    <StackPanel Orientation="Vertical">

                                        <TextBlock
                                            FontSize="40"
                                            Style="{StaticResource CMFT.TextBlock.Left}"
                                            Text="與車站廣播的語音通道已打開" />
                                        <TextBlock
                                            FontSize="38"
                                            Foreground="{StaticResource CMFT.Brush.Red.Dark}"
                                            Style="{StaticResource CMFT.TextBlock.Left}"
                                            Text="請按下Audio Panel 的 PTT鈕" />
                                        <TextBlock
                                            FontSize="40"
                                            Style="{StaticResource CMFT.TextBlock.Left}"
                                            Text="進行即時語音廣播" />
                                    </StackPanel>

                                </StackPanel>
                                <Button
                                    Margin="30"
                                    Padding="50,20"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    BorderBrush="Black"
                                    BorderThickness="5"
                                    Content="On-AIR"
                                    FontWeight="Bold"
                                    Style="{StaticResource WPF.Button}" />

                            </Grid>
                        </TabItem>
                    </TabControl>
                </GroupBox>
                <UniformGrid Grid.Column="2" Columns="1">
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Bottom"
                        Command="{x:Static applications:WPFApplicationCommands.NavigateCommand}"
                        CommandParameter="{x:Static applications:WPFApplicationCommands.DefaultViewName}"
                        Content="結束"
                        Style="{StaticResource NaviStepButton}" />
                </UniformGrid>
            </Grid>
            <!--#endregion-->

        </UniformGrid>

    </Grid>
</UserControl>
