<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.PA.Views.PAPreRecordedAudioSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.Dtos"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:PAPreRecordedAudioSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>
            <ListBox
                x:Name="VoiceGroupListBox"
                Grid.Column="0"
                ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                ItemsSource="{Binding PAVoiceGroupDtos}"
                ScrollViewer.VerticalScrollBarVisibility="Visible"
                SelectedIndex="0"
                SelectedItem="{Binding SelectedVoiceGroup, Mode=TwoWay}"
                SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type dtos:PAVoiceGroupDto}">
                        <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding GroupName}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="GotFocus">
                        <prism:InvokeCommandAction Command="{Binding ClearSelectedVoiceCommand}" />
                    </b:EventTrigger>
                    <b:EventTrigger EventName="SelectionChanged">
                        <prism:InvokeCommandAction Command="{Binding GroupSelectionChangedCommand}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </ListBox>

            <ListView
                x:Name="VoicesListView"
                Grid.Column="1"
                d:ItemsSource="{x:Static datas:DesignTimeDatas.PAPreRecordVoices}"
                ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
                ItemsSource="{Binding PAPreRecordVoicesView}"
                SelectedItem="{Binding SelectedVoice}"
                SelectionMode="Single">
                <b:Interaction.Behaviors>
                    <!--  自訂Behavior來避免combobox的SelectionChanged事件bubble到ListViewItem  -->
                    <behaviors:ListViewSelectionChangedBehavior Command="{Binding CancelEditOnSelectionChangedCommand}" />
                </b:Interaction.Behaviors>
                <ListView.View>
                    <GridView>
                        <GridViewColumn
                            Width="160"
                            Header="訊息名稱"
                            HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Left}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:PAPreRecordVoiceDto}">
                                    <TextBlock
                                        Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                        Text="{Binding VoiceName}"
                                        TextWrapping="Wrap" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn
                            Width="400"
                            Header="訊息內容"
                            HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Left}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:PAPreRecordVoiceDto}">
                                    <TextBlock
                                        Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                        Text="{Binding VoiceContent}"
                                        TextWrapping="Wrap" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="國" HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <ToggleButton
                                        Padding="8,4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="國"
                                        FontWeight="Bold"
                                        IsChecked="True"
                                        IsEnabled="{Binding IsIncludeCHN}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource WPF.ToggleButton}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="台" HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <ToggleButton
                                        Padding="8,4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="台"
                                        FontWeight="Bold"
                                        IsChecked="True"
                                        IsEnabled="{Binding IsIncludeTWN}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource WPF.ToggleButton}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="客" HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <ToggleButton
                                        Padding="8,4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="客"
                                        FontWeight="Bold"
                                        IsChecked="True"
                                        IsEnabled="{Binding IsIncludeHAKKA}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource WPF.ToggleButton}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="英" HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <ToggleButton
                                        Padding="8,4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Content="英"
                                        FontWeight="Bold"
                                        IsChecked="True"
                                        IsEnabled="{Binding IsIncludeENG}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource WPF.ToggleButton}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn
                            Width="150"
                            Header="預錄群組"
                            HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:PAPreRecordVoiceDto}">
                                    <Grid>
                                        <!--  ComboBox 編輯  -->
                                        <ComboBox
                                            x:Name="GroupComboBox"
                                            DisplayMemberPath="GroupName"
                                            ItemsSource="{Binding DataContext.EditableGroups, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            SelectedItem="{Binding BelongGroup, NotifyOnSourceUpdated=False}"
                                            Style="{StaticResource GridView.Column.ComboBox.Center}"
                                            Visibility="Collapsed" />
                                        <!--  TextBlock 檢視  -->
                                        <TextBlock
                                            x:Name="GroupTextBlock"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                            Text="{Binding BelongGroup.GroupName}"
                                            Visibility="Visible" />
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="GroupComboBox" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="GroupTextBlock" Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <UniformGrid
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Columns="1"
            Style="{StaticResource PanelMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding AddGroupCommand}"
                ContentTemplate="{StaticResource AddGroupData}"
                Style="{StaticResource AddButton}"
                Visibility="{Binding IsGroupOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding DeleteGroupCommand}"
                ContentTemplate="{StaticResource DeleteGroupData}"
                Style="{StaticResource DeleteButton}"
                Visibility="{Binding IsGroupOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}"
                Visibility="{Binding IsItemOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </UniformGrid>
    </Grid>

</UserControl>
