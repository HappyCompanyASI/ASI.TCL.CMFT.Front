<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.PA.Views.PAMainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas11="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.Datas"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:PAMainViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="541"
    d:Width="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <TextBlock
            Grid.Column="0"
            Margin="10,0,0,0"
            VerticalAlignment="Top"
            FontSize="{StaticResource FieldFontSize_Large}"
            Foreground="{StaticResource CMFT.Brush.Blue.Light}"
            Style="{StaticResource CMFT.TextBlock.PanelHeader}"
            Text="列車預錄語音廣播(無限次):" />

        <ListBox
            Grid.Column="0"
            Margin="10,30,10,10"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="1"
            ItemsSource="{x:Static datas11:DesignTimeDatas.PACurrentTrainPlaying}"
            SelectionMode="Multiple"
            Style="{StaticResource MaterialDesignListBox}">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text=":" />
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text=":" />
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding VoiceName}" />
                        </StackPanel>

                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Column="1">
            <Button
                Margin="10"
                CommandParameter="{x:Static datas11:NavigatePath.PATrain}"
                Content="列車語音廣播"
                Style="{StaticResource NaviBigButton}" />


            <Button
                Margin="10"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Content="刪除"
                Style="{StaticResource CMFT.Button}" />
        </Grid>

        <Grid Grid.Column="2">
            <Button
                Margin="10"
                CommandParameter="{x:Static datas11:NavigatePath.PAStation}"
                Content="車站語音廣播"
                Style="{DynamicResource NaviBigButton}" />

            <Button
                Margin="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Content="刪除"
                Style="{StaticResource CMFT.Button}" />
        </Grid>

        <TextBlock
            Grid.Column="3"
            Margin="10,0,0,0"
            VerticalAlignment="Top"
            FontSize="{StaticResource FieldFontSize_Large}"
            Foreground="{StaticResource CMFT.Brush.Blue.Light}"
            Style="{StaticResource CMFT.TextBlock.PanelHeader}"
            Text="車站語音廣播(排程+即時):" />

        <!--  ItemsSource="{x:Static provider:SampleData.PAInstantVoice}"  -->
        <ListBox
            Grid.Column="3"
            Margin="10,30,10,10"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="1"
            ItemContainerStyle="{StaticResource CMFT.ListBox.ListBoxItem}">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding VoiceFrom, StringFormat={}{0:HH:mm}}" />
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="~" />
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding VoiceTo, StringFormat={}{0:HH:mm}}" />
                            <TextBlock
                                Margin="10,0,0,0"
                                Style="{StaticResource CMFT.TextBlock.Center}"
                                Text="{Binding VoiceType}" />
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text=":" />
                            <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding VoiceName}" />
                        </StackPanel>
                        <StackPanel
                            Margin="10,0"
                            VerticalAlignment="Top"
                            Orientation="Horizontal">
                            <TextBlock FontSize="{StaticResource FieldFontSize_Small}" Text="廣播區域" />
                            <TextBlock FontSize="{StaticResource FieldFontSize_Small}" Text=":" />
                            <ItemsControl FontSize="{StaticResource FieldFontSize_Small}" ItemsSource="{Binding VoiceArea}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            Margin="1,0"
                                            FontSize="{StaticResource FieldFontSize_Small}"
                                            Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
