<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.PA.Views.PABroadcastEquipmentSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.Dtos"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.PA.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:PABroadcastEquipmentSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*" />
                <ColumnDefinition Width="7*" />
            </Grid.ColumnDefinitions>

            <ListView
                x:Name="BroadcastEquipmentListView"
                Grid.Column="1"
                d:ItemsSource="{x:Static datas:DesignTimeDatas.PABroadcastEquipments}"
                ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
                ItemsSource="{Binding PAStationBroadcastEquipments}"
                SelectedItem="{Binding SelectedItem}"
                SelectionMode="Single">
                <!--<b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <prism:InvokeCommandAction Command="{Binding CancelEditOnSelectionChangedCommand}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>-->
                <ListView.View>
                    <GridView>
                        <GridViewColumn
                            Width="200"
                            Header="主控台名稱"
                            HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:PABroadcastEquipmentDto}">
                                    <TextBlock
                                        Style="{StaticResource GridView.VerticalColumnHeader.Center}"
                                        Text="{Binding ConsoleName}"
                                        TextWrapping="Wrap" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn
                            Width="200"
                            Header="安裝地點"
                            HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:PABroadcastEquipmentDto}">
                                    <TextBlock
                                        Style="{StaticResource GridView.VerticalColumnHeader.Center}"
                                        Text="{Binding Location}"
                                        TextWrapping="Wrap" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn
                            Width="200"
                            Header="座位名稱"
                            HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:PABroadcastEquipmentDto}">
                                    <TextBlock
                                        Style="{StaticResource GridView.VerticalColumnHeader.Center}"
                                        Text="{Binding SeatName}"
                                        TextWrapping="Wrap" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn
                            Width="200"
                            Header="車站廣播"
                            HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:PABroadcastEquipmentDto}">
                                    <Grid>
                                        <!--  TextBox 編輯  -->
                                        <RadioButton
                                            x:Name="IsStationBroadcastEnabledRadioButton"
                                            HorizontalAlignment="Center"
                                            GroupName="IsStationBroadcastEnabledGroup"
                                            IsChecked="{Binding IsStationBroadcastEnabled}"
                                            Visibility="Collapsed" />
                                        <!--  TextBlock 檢視  -->
                                        <TextBlock
                                            x:Name="IsStationBroadcastEnabledTextBlock"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <!--  預設顯示 "關閉"  -->
                                                    <Setter Property="Text" Value="關閉" />
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <!--  IsUseDU 為 true 時顯示 "啟用"  -->
                                                        <DataTrigger Binding="{Binding IsStationBroadcastEnabled}" Value="True">
                                                            <Setter Property="Text" Value="啟用" />
                                                            <Setter Property="Foreground" Value="#FFFFDB00" />
                                                            <Setter Property="FontWeight" Value="Bold" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                <!--<Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />-->
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="IsStationBroadcastEnabledRadioButton" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="IsStationBroadcastEnabledTextBlock" Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <UniformGrid
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Columns="1"
            Style="{StaticResource PanelMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}" />
        </UniformGrid>
    </Grid>

</UserControl>
