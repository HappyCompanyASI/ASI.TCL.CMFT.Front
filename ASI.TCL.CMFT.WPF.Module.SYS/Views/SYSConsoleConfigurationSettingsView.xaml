<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.SYS.Views.SYSConsoleConfigurationSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assist="clr-namespace:ASI.TCL.CMFT.WPF.Assist;assembly=ASI.TCL.CMFT.WPF"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:provider="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.DataTypes"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:SYSConsoleConfigurationSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="9*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ListView
            ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
            ItemsSource="{Binding SYSConsoles}"
            SelectedItem="{Binding SelectedItem}"
            SelectionMode="Single">
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="SelectionChanged">
                    <prism:InvokeCommandAction Command="{Binding CancelEditOnSelectionChangedCommand}" />
                </b:EventTrigger>
            </b:Interaction.Triggers>
            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">

                    <GridViewColumn Width="120" Header="系統代號">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:SYSConsoleDto}">
                                <!--<TextBlock Style="{StaticResource GridView.VerticalColumnHeader.Center}" Text="{Binding SystemID}" />-->
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <TextBox
                                        x:Name="SystemIDTextBox"
                                        Text="{Binding SystemID}"
                                        TextWrapping="Wrap"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="SystemIDTextBlock"
                                        Style="{StaticResource GridView.VerticalColumnHeader.Center}"
                                        Text="{Binding SystemID}"
                                        TextWrapping="Wrap"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="SystemIDTextBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="SystemIDTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="120" Header="主控台名稱">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:SYSConsoleDto}">
                                <!--<TextBox Style="{StaticResource GridView.Column.TextBox.Stretch}" Text="{Binding ConsoleName}" />-->
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <TextBox
                                        x:Name="ConsoleNameTextBox"
                                        Text="{Binding ConsoleName}"
                                        TextWrapping="Wrap"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="ConsoleNameTextBlock"
                                        Style="{StaticResource GridView.VerticalColumnHeader.Center}"
                                        Text="{Binding ConsoleName}"
                                        TextWrapping="Wrap"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="ConsoleNameTextBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="ConsoleNameTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="120" Header="IP位址">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:SYSConsoleDto}">
                                <!--<TextBox Style="{StaticResource GridView.Column.TextBox.Stretch}" Text="{Binding IPAddress}" />-->
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <TextBox
                                        x:Name="IPAddressTextBox"
                                        Text="{Binding IPAddress}"
                                        TextWrapping="Wrap"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="IPAddressTextBlock"
                                        Style="{StaticResource GridView.VerticalColumnHeader.Center}"
                                        Text="{Binding IPAddress}"
                                        TextWrapping="Wrap"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IPAddressTextBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IPAddressTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="120" Header="安裝地點">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:SYSConsoleDto}">
                                <!--<TextBox Style="{StaticResource GridView.Column.TextBox.Stretch}" Text="{Binding SetupLocation}" />-->
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <TextBox
                                        x:Name="SetupLocationTextBox"
                                        Text="{Binding SetupLocation}"
                                        TextWrapping="Wrap"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="SetupLocationTextBlock"
                                        Style="{StaticResource GridView.VerticalColumnHeader.Center}"
                                        Text="{Binding SetupLocation}"
                                        TextWrapping="Wrap"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="SetupLocationTextBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="SetupLocationTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="120" Header="座位名稱">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:SYSConsoleDto}">
                                <!--<TextBox Style="{StaticResource GridView.Column.TextBox.Stretch}" Text="{Binding SeatName}" />-->
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <TextBox
                                        x:Name="SeatNameTextBox"
                                        Text="{Binding SeatName}"
                                        TextWrapping="Wrap"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="SeatNameTextBlock"
                                        Style="{StaticResource GridView.VerticalColumnHeader.Center}"
                                        Text="{Binding SeatName}"
                                        TextWrapping="Wrap"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="SeatNameTextBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="SeatNameTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="120" Header="DLT號碼">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:SYSConsoleDto}">
                                <!--<TextBox Style="{StaticResource GridView.Column.TextBox.Stretch}" Text="{Binding DLTNumber}" />-->
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <TextBox
                                        x:Name="DLTNumberTextBox"
                                        Text="{Binding DLTNumber}"
                                        TextWrapping="Wrap"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="DLTNumberTextBlock"
                                        Style="{StaticResource GridView.VerticalColumnHeader.Center}"
                                        Text="{Binding DLTNumber}"
                                        TextWrapping="Wrap"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="DLTNumberTextBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="DLTNumberTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="120" Header="無線電號碼">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:SYSConsoleDto}">
                                <!--<TextBox Style="{StaticResource GridView.Column.TextBox.Stretch}" Text="{Binding TetraNumber}" />-->
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <TextBox
                                        x:Name="TetraNumberTextBox"
                                        Text="{Binding TetraNumber}"
                                        TextWrapping="Wrap"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="TetraNumberTextBlock"
                                        Style="{StaticResource GridView.VerticalColumnHeader.Center}"
                                        Text="{Binding TetraNumber}"
                                        TextWrapping="Wrap"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="TetraNumberTextBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="TetraNumberTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
        <UniformGrid
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Style="{StaticResource UniformGridMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding AddItemCommand}"
                ContentTemplate="{StaticResource AddItemData}"
                Style="{StaticResource AddButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource FalseValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding DeleteItemCommand}"
                ContentTemplate="{StaticResource DeleteItemData}"
                Style="{StaticResource DeleteButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource FalseValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}"
                Visibility="{Binding IsItemOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </UniformGrid>
    </Grid>
</UserControl>
