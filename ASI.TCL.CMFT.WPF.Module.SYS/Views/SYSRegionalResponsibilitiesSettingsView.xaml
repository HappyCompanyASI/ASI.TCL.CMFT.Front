<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.SYS.Views.SYSRegionalResponsibilitiesSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assist="clr-namespace:ASI.TCL.CMFT.WPF.Assist;assembly=ASI.TCL.CMFT.WPF"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:provider="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.DataTypes"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:SYSRegionalResponsibilitiesSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="LocalListViewItemStyle"
            BasedOn="{StaticResource ListView.GridViewItem.Stretch}"
            TargetType="{x:Type ListViewItem}">
            <Setter Property="MinHeight" Value="60" />
            <Setter Property="Height" Value="60" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <ListView
                x:Name="SYSOTCSAuthoritysListView"
                Grid.Column="0"
                ItemContainerStyle="{StaticResource LocalListViewItemStyle}"
                ItemsSource="{Binding SYSOTCSAuthoritys}"
                SelectedIndex="{Binding SelectedIndex}"
                SelectedItem="{Binding SelectedItem}"
                SelectionMode="Single">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <prism:InvokeCommandAction Command="{Binding CancelEditOnSelectionChangedCommand}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                        <GridViewColumn Header="主控台名稱">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:SYSOTCSAuthorityDto}">
                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding Console.ConsoleName}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="地點/座位">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:SYSOTCSAuthorityDto}">
                                    <StackPanel Orientation="Vertical">
                                        <TextBlock
                                            FontSize="14"
                                            Style="{StaticResource GridView.Column.TextBlock.Center}"
                                            Text="{Binding Console.SetupLocation}" />
                                        <TextBlock
                                            FontSize="14"
                                            Style="{StaticResource GridView.Column.TextBlock.Center}"
                                            Text="{Binding Console.SeatName}" />
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
            <ListView
                Grid.Column="1"
                ItemContainerStyle="{StaticResource LocalListViewItemStyle}"
                ItemsSource="{Binding ItemsSource, ElementName=SYSOTCSAuthoritysListView}"
                SelectedIndex="{Binding SelectedIndex}"
                SelectionMode="Single">
                <ListView.View>
                    <GridView>
                        <GridViewColumn>
                            <GridViewColumn.Header>
                                <GridViewColumnHeader HorizontalContentAlignment="Left" FontSize="14">
                                    <StackPanel
                                        Margin="10,0,0,0"
                                        HorizontalAlignment="Stretch"
                                        Orientation="Horizontal">

                                        <ItemsControl ItemsSource="{x:Static datas:DesignTimeDatas.SYSStations}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid VerticalAlignment="Top" Rows="1" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="80">
                                                        <TextBlock
                                                            HorizontalAlignment="Stretch"
                                                            Text="{Binding StationID}"
                                                            TextAlignment="Center" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock
                                            Width="80"
                                            HorizontalAlignment="Center"
                                            Text="南機廠"
                                            TextAlignment="Center" />
                                    </StackPanel>
                                </GridViewColumnHeader>
                            </GridViewColumn.Header>
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:SYSOTCSAuthorityDto}">
                                    <ItemsControl ItemsSource="{Binding Authorities}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid VerticalAlignment="Top" Rows="1" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Width="80"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                    <Grid>
                                                        <CheckBox
                                                            x:Name="IsFunctionCheckBox"
                                                            HorizontalAlignment="Center"
                                                            IsChecked="{Binding IsChecked}"
                                                            Style="{StaticResource GridView.Column.CheckBox.Center}"
                                                            ToolTip="MaterialDesignActionToggleButton"
                                                            Visibility="Collapsed" />
                                                        <ToggleButton
                                                            x:Name="IsFunctionToggleButton"
                                                            IsChecked="{Binding IsChecked}"
                                                            IsHitTestVisible="False"
                                                            Style="{StaticResource GridView.Column.ToggleButton.State.Center}"
                                                            Visibility="Visible" />
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter TargetName="IsFunctionCheckBox" Property="Visibility" Value="Visible" />
                                                        <Setter TargetName="IsFunctionToggleButton" Property="Visibility" Value="Collapsed" />
                                                    </MultiDataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

        </Grid>

        <UniformGrid
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Columns="1"
            Style="{StaticResource PanelMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}"
                Visibility="{Binding IsItemOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </UniformGrid>
    </Grid>
</UserControl>
