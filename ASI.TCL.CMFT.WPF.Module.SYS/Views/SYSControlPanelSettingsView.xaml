<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.SYS.Views.SYSControlPanelSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assist="clr-namespace:ASI.TCL.CMFT.WPF.Assist;assembly=ASI.TCL.CMFT.WPF"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:provider="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.DataTypes"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.ViewModels"
    xmlns:views="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Views"
    d:DataContext="{d:DesignInstance viewModels:SYSControlPanelSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <TabControl Style="{DynamicResource MaterialDesignTabControl}" TabStripPlacement="Left">

            <!--#region 主控台配置-->
            <TabItem>
                <TabItem.Header>
                    <TextBlock
                        FontSize="{StaticResource ButtonFontSize}"
                        FontWeight="Bold"
                        Text="主控台配置" />
                </TabItem.Header>
                <views:SYSConsoleConfigurationSettingsView prism:ViewModelLocator.AutoWireViewModel="True" />
            </TabItem>
            <!--#endregion-->

            <!--#region 主控台功能-->
            <TabItem>
                <TabItem.Header>
                    <TextBlock
                        FontSize="{StaticResource ButtonFontSize}"
                        FontWeight="Bold"
                        Text="主控台功能" />
                </TabItem.Header>
                <views:SYSConsoleFunctionSettingsView prism:ViewModelLocator.AutoWireViewModel="True" />
            </TabItem>
            <!--#endregion-->

        </TabControl>
    </Grid>

</UserControl>
