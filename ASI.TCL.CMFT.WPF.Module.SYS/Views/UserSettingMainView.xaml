<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.SYS.Views.UserSettingMainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataTypes="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.DataTypes"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:UserSettingMainViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="8*" />
        </Grid.ColumnDefinitions>

        <GroupBox
            Grid.Column="0"
            Margin="5,5,0,5"
            Header="操作功能">
            <Grid>
                <Grid.Resources>
                    <Style BasedOn="{StaticResource StepRadioButton}" TargetType="{x:Type RadioButton}">
                        <Setter Property="Command" Value="{Binding NavigateCommand}" />
                    </Style>
                    <Style BasedOn="{StaticResource MainTitleTextBox}" TargetType="{x:Type TextBlock}" />
                </Grid.Resources>
                <UniformGrid VerticalAlignment="Top" Style="{StaticResource UniformGridMargin5}">
                    <RadioButton
                        CommandParameter="{x:Static datas:NavigatePath.SYSUserRoleSettings}"
                        Content="使用者角色"
                        IsChecked="True" />
                    <RadioButton CommandParameter="{x:Static datas:NavigatePath.SYSUserAccountSettings}" Content="使用者帳號" />
                    <RadioButton CommandParameter="{x:Static datas:NavigatePath.SYSUserPasswordSettings}" Content="使用者密碼" />
                </UniformGrid>
                <TextBlock Text="使用者設定" />
            </Grid>
        </GroupBox>

        <GroupBox
            Grid.Column="1"
            Margin="5"
            Header="設定">
            <UniformGrid Columns="1">
                <ContentControl prism:RegionManager.RegionName="{x:Static datas:RegionNames.UserSettingsRegion}" />
            </UniformGrid>
        </GroupBox>
    </Grid>
</UserControl>
