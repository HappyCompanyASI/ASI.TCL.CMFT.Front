<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.SYS.Views.SYSUserRoleSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Dtos"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:SYSUserRoleSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ListView
            ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
            ItemsSource="{Binding SYSUserRoleDtos}"
            SelectedIndex="0"
            SelectedItem="{Binding SelectedRole}"
            SelectionMode="Single">
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="SelectionChanged">
                    <prism:InvokeCommandAction Command="{Binding CancelEditOnSelectionChangedCommand}" />
                </b:EventTrigger>
            </b:Interaction.Triggers>
            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                    <!--  角色名稱  -->
                    <GridViewColumn Header="角色名稱">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <TextBox
                                        x:Name="RoleNameTextBox"
                                        Text="{Binding RoleName, Mode=TwoWay}"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="RoleNameTextBlock"
                                        Text="{Binding RoleName}"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="RoleNameTextBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="RoleNameTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!--  廣播功能  -->
                    <GridViewColumn Header="廣播功能">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                <Grid>
                                    <CheckBox
                                        x:Name="IsPAFunctionCheckBox"
                                        IsChecked="{Binding IsPAFunction, Mode=TwoWay}"
                                        Style="{StaticResource GridView.Column.CheckBox.Center}"
                                        Visibility="Collapsed" />
                                    <ToggleButton
                                        x:Name="IsPAFunctionToggleButton"
                                        IsChecked="{Binding IsPAFunction}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource GridView.Column.ToggleButton.State.Center}"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsPAFunctionCheckBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsPAFunctionToggleButton" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!--  廣播設定  -->
                    <GridViewColumn Header="廣播設定">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                <Grid>
                                    <CheckBox
                                        x:Name="IsPASettingCheckBox"
                                        IsChecked="{Binding IsPASetting, Mode=TwoWay}"
                                        Style="{StaticResource GridView.Column.CheckBox.Center}"
                                        Visibility="Collapsed" />
                                    <ToggleButton
                                        x:Name="IsPASettingToggleButton"
                                        IsChecked="{Binding IsPASetting}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource GridView.Column.ToggleButton.State.Center}"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsPASettingCheckBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsPASettingToggleButton" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!--  點矩陣功能  -->
                    <GridViewColumn Header="點矩陣功能">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                <Grid>
                                    <CheckBox
                                        x:Name="IsDMDFunctionCheckBox"
                                        IsChecked="{Binding IsDMDFunction, Mode=TwoWay}"
                                        Style="{StaticResource GridView.Column.CheckBox.Center}"
                                        Visibility="Collapsed" />
                                    <ToggleButton
                                        x:Name="IsDMDFunctionToggleButton"
                                        IsChecked="{Binding IsDMDFunction}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource GridView.Column.ToggleButton.State.Center}"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsDMDFunctionCheckBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsDMDFunctionToggleButton" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!--  點矩陣設定  -->
                    <GridViewColumn Header="點矩陣設定">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                <Grid>
                                    <CheckBox
                                        x:Name="IsDMDSettingCheckBox"
                                        IsChecked="{Binding IsDMDSetting, Mode=TwoWay}"
                                        Style="{StaticResource GridView.Column.CheckBox.Center}"
                                        Visibility="Collapsed" />
                                    <ToggleButton
                                        x:Name="IsDMDSettingToggleButton"
                                        IsChecked="{Binding IsDMDSetting}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource GridView.Column.ToggleButton.State.Center}"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsDMDSettingCheckBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsDMDSettingToggleButton" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!--  無線電功能  -->
                    <GridViewColumn Header="無線電功能">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                <Grid>
                                    <CheckBox
                                        x:Name="IsTetraFunctionCheckBox"
                                        IsChecked="{Binding IsTetraFunction, Mode=TwoWay}"
                                        Style="{StaticResource GridView.Column.CheckBox.Center}"
                                        Visibility="Collapsed" />
                                    <ToggleButton
                                        x:Name="IsTetraFunctionToggleButton"
                                        IsChecked="{Binding IsTetraFunction}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource GridView.Column.ToggleButton.State.Center}"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsTetraFunctionCheckBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsTetraFunctionToggleButton" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!--  無線電設定  -->
                    <GridViewColumn Header="無線電設定">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                <Grid>
                                    <CheckBox
                                        x:Name="IsTetraSettingCheckBox"
                                        IsChecked="{Binding IsTetraSetting, Mode=TwoWay}"
                                        Style="{StaticResource GridView.Column.CheckBox.Center}"
                                        Visibility="Collapsed" />
                                    <ToggleButton
                                        x:Name="IsTetraSettingToggleButton"
                                        IsChecked="{Binding IsTetraSetting}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource GridView.Column.ToggleButton.State.Center}"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsTetraSettingCheckBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsTetraSettingToggleButton" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!--  列車通訊功能  -->
                    <GridViewColumn Header="列車通訊功能">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                <Grid>
                                    <CheckBox
                                        x:Name="IsOTCSFunctionCheckBox"
                                        IsChecked="{Binding IsOTCSFunction, Mode=TwoWay}"
                                        Style="{StaticResource GridView.Column.CheckBox.Center}"
                                        Visibility="Collapsed" />
                                    <ToggleButton
                                        x:Name="IsOTCSFunctionToggleButton"
                                        IsChecked="{Binding IsOTCSFunction}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource GridView.Column.ToggleButton.State.Center}"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsOTCSFunctionCheckBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsOTCSFunctionToggleButton" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!--  告警設定  -->
                    <GridViewColumn Header="告警設定">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                <Grid>
                                    <CheckBox
                                        x:Name="IsAlarmSettingCheckBox"
                                        IsChecked="{Binding IsAlarmSetting, Mode=TwoWay}"
                                        Style="{StaticResource GridView.Column.CheckBox.Center}"
                                        Visibility="Collapsed" />
                                    <ToggleButton
                                        x:Name="IsAlarmSettingToggleButton"
                                        IsChecked="{Binding IsAlarmSetting}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource GridView.Column.ToggleButton.State.Center}"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsAlarmSettingCheckBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsAlarmSettingToggleButton" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!--  系統設定  -->
                    <GridViewColumn Header="系統設定">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                <Grid>
                                    <CheckBox
                                        x:Name="IsSystemSettingCheckBox"
                                        IsChecked="{Binding IsSystemSetting, Mode=TwoWay}"
                                        Style="{StaticResource GridView.Column.CheckBox.Center}"
                                        Visibility="Collapsed" />
                                    <ToggleButton
                                        x:Name="IsSystemSettingToggleButton"
                                        IsChecked="{Binding IsSystemSetting}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource GridView.Column.ToggleButton.State.Center}"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsSystemSettingCheckBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsSystemSettingToggleButton" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!--  使用者設定  -->
                    <GridViewColumn Header="使用者設定">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                <Grid>
                                    <CheckBox
                                        x:Name="IsUserSettingCheckBox"
                                        IsChecked="{Binding IsUserSetting, Mode=TwoWay}"
                                        Style="{StaticResource GridView.Column.CheckBox.Center}"
                                        Visibility="Collapsed" />
                                    <ToggleButton
                                        x:Name="IsUserSettingToggleButton"
                                        IsChecked="{Binding IsUserSetting}"
                                        IsHitTestVisible="False"
                                        Style="{StaticResource GridView.Column.ToggleButton.State.Center}"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsUserSettingCheckBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsUserSettingToggleButton" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                </GridView>
            </ListView.View>
        </ListView>

        <UniformGrid
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Columns="1"
            Style="{StaticResource PanelMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding AddItemCommand}"
                ContentTemplate="{StaticResource AddItemData}"
                Style="{StaticResource AddButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource FalseValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding DeleteItemCommand}"
                ContentTemplate="{StaticResource DeleteItemData}"
                Style="{StaticResource DeleteButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource FalseValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}"
                Visibility="{Binding IsItemOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </UniformGrid>
    </Grid>
</UserControl>
