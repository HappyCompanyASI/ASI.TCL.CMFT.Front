<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.SYS.Views.SYSOperationRecordsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assist="clr-namespace:ASI.TCL.CMFT.WPF.Assist;assembly=ASI.TCL.CMFT.WPF"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:provider="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.DataTypes"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:SYSOperationRecordsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <ListView
                x:Name="EventListView"
                Grid.Column="0"
                ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
                ItemsSource="{Binding SYSOperationLogs}"
                ScrollViewer.VerticalScrollBarVisibility="Visible"
                SelectionMode="Single">
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">

                        <GridViewColumn Header="事件時間">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding EventTime, StringFormat='{}{0:yyyy/MM/dd HH:mm:ss}'}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="登入使用者">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding UserID}" />
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="主控台">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding Console.SetupLocation}" />
                                        <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="(" />
                                        <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding Console.SeatName}" />
                                        <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text=")" />
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn
                            Width="120"
                            Header="事件種類"
                            HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding SystemType}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="事件內容" HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.Left}" Text="{Binding Content}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>

            <StackPanel Grid.Column="1">
                <TextBlock
                    Margin="10,0,10,10"
                    Style="{StaticResource CMFT.TextBlock.Left}"
                    Text="搜尋條件" />
                <UniformGrid VerticalAlignment="Top" Style="{StaticResource UniformGridMargin10}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <DatePicker
                            Grid.Column="0"
                            materialDesign:HintAssist.Hint="開始時間"
                            SelectedDate="{Binding SelectedStartTime}" />
                        <materialDesign:TimePicker
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            SelectedTime="{Binding SelectedStartTime}" />
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <DatePicker
                            Grid.Column="0"
                            materialDesign:HintAssist.Hint="結束時間"
                            SelectedDate="{Binding SelectedEndTime}" />
                        <materialDesign:TimePicker
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            SelectedTime="{Binding SelectedEndTime}" />
                    </Grid>

                    <ComboBox
                        Margin="4,2"
                        materialDesign:HintAssist.Hint="事件種類"
                        materialDesign:TextFieldAssist.HasClearButton="True"
                        ItemsSource="{x:Static datas:DesignTimeDatas.SystemTypes}"
                        SelectedItem="{Binding SelectedSystemTypes}" />

                    <ComboBox
                        Margin="4,2"
                        materialDesign:HintAssist.Hint="主控台"
                        materialDesign:TextFieldAssist.HasClearButton="True"
                        ItemsSource="{x:Static datas:DesignTimeDatas.SYSConsoles}"
                        SelectedItem="{Binding SelectedSYSConsole}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type dtos:SYSConsoleDto}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding SetupLocation}" />
                                    <TextBlock Text="(" />
                                    <TextBlock Text="{Binding SeatName}" />
                                    <TextBlock Text=")" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox
                        Margin="4,0"
                        materialDesign:HintAssist.Hint="使用者(員工編號)"
                        materialDesign:TextFieldAssist.HasClearButton="True"
                        Text="{Binding SelectedAccountId}" />
                    <TextBox
                        Margin="4,2"
                        materialDesign:HintAssist.Hint="事件內容"
                        materialDesign:TextFieldAssist.HasClearButton="True"
                        Text="{Binding SelectedContent}" />
                </UniformGrid>
                <UniformGrid Columns="2">
                    <Button
                        Command="{Binding SearchCommand}"
                        Content="搜尋"
                        Style="{StaticResource OperationButton}" />
                    <Button
                        Background="{StaticResource CMFT.Brush.Green.Dark}"
                        Command="{Binding RemitCommand}"
                        Content="匯出"
                        Style="{StaticResource OperationButton}" />
                </UniformGrid>
            </StackPanel>

        </Grid>
    </Grid>

</UserControl>
