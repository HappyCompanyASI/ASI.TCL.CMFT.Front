<UserControl x:Class="ASI.TCL.CMFT.WPF.Module.SYS.Views.SystemSettingMainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Datas"
             xmlns:markupExtensions="clr-namespace:ASI.TCL.CMFT.WPF.MarkupExtensions;assembly=ASI.TCL.CMFT.WPF"
             xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.ViewModels"
             xmlns:views="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Views"
             xmlns:prism="http://prismlibrary.com/"
             d:DataContext="{d:DesignInstance viewModels:SystemSettingMainViewModel,
                                              IsDesignTimeCreatable=True}"
             d:DesignHeight="540"
             d:DesignWidth="1420"
             Style="{StaticResource CMFT.UserControl}"
             mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="8*" />
        </Grid.ColumnDefinitions>

        <!--#region 操作功能-->
        <GroupBox Grid.Column="0"
                  Margin="5,5,0,5"
                  Header="操作功能">
            <Grid>
                <Grid.Resources>
                    <Style BasedOn="{StaticResource StepRadioButton}" TargetType="{x:Type RadioButton}">
                        <Setter Property="Command" Value="{Binding NavigateCommand}" />
                    </Style>
                    <Style BasedOn="{StaticResource MainTitleTextBox}" TargetType="{x:Type TextBlock}" />
                </Grid.Resources>
                <UniformGrid VerticalAlignment="Top" Style="{StaticResource UniformGridMargin5}">
                    <RadioButton CommandParameter="{x:Static datas:NavigatePath.SYSControlPanelSettings}"
                                 Content="主控台設定"
                                 IsChecked="True" />
                    <!--<RadioButton CommandParameter="{x:Static datas:NavigatePath.SYSRegionalResponsibilitiesSettings}" Content="區域權責設定" />-->
                    <RadioButton CommandParameter="{x:Static datas:NavigatePath.SYSGroupPhonebookSettings}" Content="群組與電話簿" />
                    <RadioButton CommandParameter="{x:Static datas:NavigatePath.SYSInappropriateWordSettings}" Content="不雅字設定" />
                </UniformGrid>
                <TextBlock Text="系統設定" />
            </Grid>
        </GroupBox>
        <!--#endregion-->

        <!--#region 設定-->
        <GroupBox Grid.Column="1"
                  Margin="5"
                  Header="設定">
            <UniformGrid Columns="1">
                <ContentControl d:Content="{markupExtensions:DesignTimeMarkupExtension ViewType={x:Type views:SYSConsoleSettingsView}, ViewModelType={x:Type viewModels:SYSConsoleSettingsViewModel}}" prism:RegionManager.RegionName="{x:Static datas:RegionNames.SystemSettingsRegion}" />
            </UniformGrid>
        </GroupBox>
        <!--#endregion-->
    </Grid>
</UserControl>
