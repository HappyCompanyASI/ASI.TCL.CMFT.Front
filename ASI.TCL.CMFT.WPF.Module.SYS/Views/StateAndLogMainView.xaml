<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.SYS.Views.StateAndLogMainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assist="clr-namespace:ASI.TCL.CMFT.WPF.Assist;assembly=ASI.TCL.CMFT.WPF"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:provider="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.DataTypes"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:StateAndLogMainViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="8*" />
        </Grid.ColumnDefinitions>

        <!--#region 操作功能-->
        <GroupBox
            Grid.Column="0"
            Margin="5,5,0,5"
            Header="操作功能">
            <Grid>
                <Grid.Resources>
                    <Style BasedOn="{StaticResource StepRadioButton}" TargetType="{x:Type RadioButton}">
                        <Setter Property="Command" Value="{Binding NavigateCommand}" />
                    </Style>
                    <Style BasedOn="{StaticResource MainTitleTextBox}" TargetType="{x:Type TextBlock}" />
                </Grid.Resources>
                <UniformGrid VerticalAlignment="Top" Style="{StaticResource UniformGridMargin5}">
                    <RadioButton
                        CommandParameter="{x:Static datas:NavigatePath.SYSControlPanelStatus}"
                        Content="主控台狀態"
                        IsChecked="True" />
                    <RadioButton CommandParameter="{x:Static datas:NavigatePath.SYSOperationRecords}" Content="操作紀錄" />
                </UniformGrid>
                <TextBlock Text="狀態與紀錄" />
            </Grid>
        </GroupBox>
        <!--#endregion-->

        <GroupBox
            Grid.Column="1"
            Margin="5"
            Header="主控台狀態與紀錄">
            <UniformGrid Columns="1">

                <ContentControl prism:RegionManager.RegionName="{x:Static datas:RegionNames.StateAndLogRegion}" />

            </UniformGrid>
        </GroupBox>

    </Grid>
</UserControl>
