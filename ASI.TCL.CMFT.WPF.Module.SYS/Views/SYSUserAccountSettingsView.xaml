<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.SYS.Views.SYSUserAccountSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataTypes="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.DataTypes"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:SYSUserAccountSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <GroupBox
            Grid.Column="0"
            Margin="5,0,0,0"
            Header="群組列表">
            <ListBox
                x:Name="UserRolesGroupListBox"
                Margin="5,0,0,0"
                ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                ItemsSource="{Binding SYSUserRoleDtos}"
                SelectedIndex="0"
                SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                SelectionMode="Single"
                Style="{StaticResource MaterialDesignListBox}">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type dtos:RoleDto}">
                        <TextBlock Text="{Binding RoleName}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="GotFocus">
                        <prism:InvokeCommandAction Command="{Binding ClearSelectedMessageCommand}" />
                    </b:EventTrigger>
                    <b:EventTrigger EventName="SelectionChanged">
                        <prism:InvokeCommandAction Command="{Binding GroupSelectionChangedCommand}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </ListBox>
        </GroupBox>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <GroupBox
                Grid.Row="0"
                Margin="5,0,0,0"
                Header="群組成員">
                <ListView
                    d:ItemsSource="{x:Static datas:DesignTimeDatas.UserAccounts}"
                    ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
                    ItemsSource="{Binding SYSUserAccountDtosView}"
                    SelectedItem="{Binding SelectedAccount}"
                    SelectionMode="Single">
                    <b:Interaction.Behaviors>
                        <!--  自訂Behavior來避免combobox的SelectionChanged事件bubble到ListViewItem  -->
                        <behaviors:ListViewSelectionChangedBehavior Command="{Binding CancelEditOnSelectionChangedCommand}" />
                    </b:Interaction.Behaviors>
                    <ListView.View>
                        <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">
                            <GridViewColumn Width="150" Header="員工編號">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type dtos:AccountDto}">
                                        <TextBlock
                                            x:Name="UserIDTextBlock"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                            Text="{Binding UserID}"
                                            TextWrapping="Wrap" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="150" Header="姓名">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type dtos:AccountDto}">
                                        <Grid>
                                            <!--  TextBox 編輯  -->
                                            <TextBox
                                                x:Name="UserNameTextBox"
                                                Text="{Binding UserName}"
                                                TextWrapping="Wrap"
                                                Visibility="Collapsed" />
                                            <!--  TextBlock 檢視  -->
                                            <TextBlock
                                                x:Name="UserNameTextBlock"
                                                HorizontalAlignment="Center"
                                                Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                                Text="{Binding UserName}"
                                                TextWrapping="Wrap"
                                                Visibility="Visible" />
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="UserNameTextBox" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="UserNameTextBlock" Property="Visibility" Value="Collapsed" />
                                            </MultiDataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="200" Header="職務描述">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type dtos:AccountDto}">
                                        <Grid>
                                            <!--  TextBox 編輯  -->
                                            <TextBox
                                                x:Name="DescriptionTextBox"
                                                Text="{Binding Description}"
                                                TextWrapping="Wrap"
                                                Visibility="Collapsed" />
                                            <!--  TextBlock 檢視  -->
                                            <TextBlock
                                                x:Name="DescriptionTextBlock"
                                                HorizontalAlignment="Center"
                                                Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                                Text="{Binding Description}"
                                                TextWrapping="Wrap"
                                                Visibility="Visible" />
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="DescriptionTextBox" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="DescriptionTextBlock" Property="Visibility" Value="Collapsed" />
                                            </MultiDataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="180" Header="使用者角色">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type dtos:AccountDto}">
                                        <!--<ComboBox
                                            DisplayMemberPath="RoleName"
                                            ItemsSource="{Binding ItemsSource, ElementName=UserRolesGroupListBox, Mode=OneWay}"
                                            SelectedItem="{Binding RoleDto}"
                                            Style="{StaticResource GridView.Column.ComboBox.Center}" />-->
                                        <Grid>
                                            <!--  ComboBox 編輯  -->
                                            <ComboBox
                                                x:Name="GroupComboBox"
                                                DisplayMemberPath="RoleName"
                                                ItemsSource="{Binding DataContext.EditableGroups, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                SelectedItem="{Binding RoleDto, NotifyOnSourceUpdated=False}"
                                                Style="{StaticResource GridView.Column.ComboBox.Center}"
                                                Visibility="Collapsed" />
                                            <!--  TextBlock 檢視  -->
                                            <TextBlock
                                                x:Name="GroupTextBlock"
                                                HorizontalAlignment="Center"
                                                Style="{StaticResource GridView.VerticalColumnHeader.Stretch}"
                                                Text="{Binding RoleDto.RoleName}"
                                                Visibility="Visible" />
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter TargetName="GroupComboBox" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="GroupTextBlock" Property="Visibility" Value="Collapsed" />
                                            </MultiDataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>
            <ListView
                Grid.Row="1"
                Height="80"
                Margin="0,5"
                d:ItemsSource="{x:Static datas:DesignTimeDatas.UserRoles}"
                IsHitTestVisible="False"
                ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
                ItemsSource="{Binding SelectedItems, ElementName=UserRolesGroupListBox}"
                SelectionMode="Single">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style BasedOn="{StaticResource GridView.ColumnHeader.Center}" TargetType="GridViewColumnHeader">
                                <Setter Property="FontSize" Value="14" />
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>

                        <GridViewColumn Width="110" Header="角色名稱">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding RoleName}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="廣播功能">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                    <ToggleButton IsChecked="{Binding IsPAFunction}" Style="{StaticResource GridView.Column.ToggleButton.State.Center}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="廣播設定">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                    <ToggleButton IsChecked="{Binding IsPASetting}" Style="{StaticResource GridView.Column.ToggleButton.State.Center}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="點矩陣功能">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                    <ToggleButton IsChecked="{Binding IsDMDFunction}" Style="{StaticResource GridView.Column.ToggleButton.State.Center}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="點矩陣設定">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                    <ToggleButton IsChecked="{Binding IsDMDSetting}" Style="{StaticResource GridView.Column.ToggleButton.State.Center}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="無線電功能">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                    <ToggleButton IsChecked="{Binding IsTetraFunction}" Style="{StaticResource GridView.Column.ToggleButton.State.Center}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="無線電設定">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                    <ToggleButton IsChecked="{Binding IsTetraSetting}" Style="{StaticResource GridView.Column.ToggleButton.State.Center}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="列車通訊功能">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                    <ToggleButton IsChecked="{Binding IsOTCSFunction}" Style="{StaticResource GridView.Column.ToggleButton.State.Center}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="告警設定">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                    <ToggleButton IsChecked="{Binding IsAlarmSetting}" Style="{StaticResource GridView.Column.ToggleButton.State.Center}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="系統設定">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                    <ToggleButton IsChecked="{Binding IsSystemSetting}" Style="{StaticResource GridView.Column.ToggleButton.State.Center}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="使用者設定">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type dtos:RoleDto}">
                                    <ToggleButton IsChecked="{Binding IsUserSetting}" Style="{StaticResource GridView.Column.ToggleButton.State.Center}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <UniformGrid
            Grid.Column="2"
            VerticalAlignment="Bottom"
            Columns="1"
            Style="{StaticResource PanelMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding AddItemCommand}"
                ContentTemplate="{StaticResource AddItemData}"
                Style="{StaticResource AddButton}"
                Visibility="{Binding CanAddItem, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding DeleteItemCommand}"
                ContentTemplate="{StaticResource DeleteItemData}"
                Style="{StaticResource DeleteButton}"
                Visibility="{Binding CanItemAddDelete, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}"
                Visibility="{Binding IsItemOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </UniformGrid>
    </Grid>
</UserControl>
