<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.SYS.Views.SYSConsoleFunctionSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Dtos"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:SYSConsoleFunctionSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <ListView
            ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
            ItemsSource="{Binding SYSCMFTAuthoritys}"
            SelectedItem="{Binding SelectedItem}"
            SelectionMode="Single">
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="SelectionChanged">
                    <prism:InvokeCommandAction Command="{Binding CancelEditOnSelectionChangedCommand}" />
                </b:EventTrigger>
            </b:Interaction.Triggers>

            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">

                    <GridViewColumn Header="主控台名稱">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="dtos:SYSCMFTAuthorityDto">
                                <TextBlock Text="{Binding Console.ConsoleName}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="安裝地點">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="dtos:SYSCMFTAuthorityDto">
                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding Console.SetupLocation}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="座位名稱">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="dtos:SYSCMFTAuthorityDto">
                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding Console.SeatName}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="點矩陣">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="dtos:SYSCMFTAuthorityDto">
                                <!--<ToggleButton IsChecked="{Binding IsDMDEnable}" Style="{StaticResource GridView.Column.ToggleButton.Switch.Center}" />-->
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <ToggleButton
                                        x:Name="IsDMDEnableToggleButton"
                                        HorizontalAlignment="Center"
                                        IsChecked="{Binding IsDMDEnable}"
                                        Style="{StaticResource GridView.Column.ToggleButton.Switch.Center}"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="IsDMDEnableTextBlock"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <!--  預設顯示 "關閉"  -->
                                                <Setter Property="Text" Value="關閉" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <!--  IsUseDU 為 true 時顯示 "啟用"  -->
                                                    <DataTrigger Binding="{Binding IsDMDEnable}" Value="True">
                                                        <Setter Property="Text" Value="啟用" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsDMDEnableToggleButton" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsDMDEnableTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="車站廣播">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="dtos:SYSCMFTAuthorityDto">
                                <!--<ToggleButton IsChecked="{Binding IsPAEnable}" Style="{StaticResource GridView.Column.ToggleButton.Switch.Center}" />-->
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <ToggleButton
                                        x:Name="IsPAEnableToggleButton"
                                        HorizontalAlignment="Center"
                                        IsChecked="{Binding IsPAEnable}"
                                        Style="{StaticResource GridView.Column.ToggleButton.Switch.Center}"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="IsPAEnableTextBlock"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <!--  預設顯示 "關閉"  -->
                                                <Setter Property="Text" Value="關閉" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <!--  IsUseDU 為 true 時顯示 "啟用"  -->
                                                    <DataTrigger Binding="{Binding IsPAEnable}" Value="True">
                                                        <Setter Property="Text" Value="啟用" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsPAEnableToggleButton" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsPAEnableTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="無線電">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="dtos:SYSCMFTAuthorityDto">
                                <!--<ToggleButton IsChecked="{Binding IsTetraEnable}" Style="{StaticResource GridView.Column.ToggleButton.Switch.Center}" />-->
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <ToggleButton
                                        x:Name="IsTetraEnableToggleButton"
                                        HorizontalAlignment="Center"
                                        IsChecked="{Binding IsTetraEnable}"
                                        Style="{StaticResource GridView.Column.ToggleButton.Switch.Center}"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="IsTetraEnableTextBlock"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <!--  預設顯示 "關閉"  -->
                                                <Setter Property="Text" Value="關閉" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <!--  IsUseDU 為 true 時顯示 "啟用"  -->
                                                    <DataTrigger Binding="{Binding IsTetraEnable}" Value="True">
                                                        <Setter Property="Text" Value="啟用" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsTetraEnableToggleButton" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsTetraEnableTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="列車通訊">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="dtos:SYSCMFTAuthorityDto">
                                <Grid>
                                    <ToggleButton
                                        x:Name="IsOTCSEnableToggleButton"
                                        HorizontalAlignment="Center"
                                        IsChecked="{Binding IsOTCSEnable}"
                                        Style="{StaticResource GridView.Column.ToggleButton.Switch.Center}"
                                        Visibility="Collapsed" />
                                    <TextBlock
                                        x:Name="IsOTCSEnableTextBlock"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="關閉" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOTCSEnable}" Value="True">
                                                        <Setter Property="Text" Value="啟用" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsOTCSEnableToggleButton" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsOTCSEnableTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="系統告警">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="dtos:SYSCMFTAuthorityDto">
                                <Grid>
                                    <ToggleButton
                                        x:Name="IsSystemAlarmEnableToggleButton"
                                        HorizontalAlignment="Center"
                                        IsChecked="{Binding IsSystemAlarmEnable}"
                                        Style="{StaticResource GridView.Column.ToggleButton.Switch.Center}"
                                        Visibility="Collapsed" />
                                    <TextBlock
                                        x:Name="IsSystemAlarmEnableTextBlock"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="關閉" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSystemAlarmEnable}" Value="True">
                                                        <Setter Property="Text" Value="啟用" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsSystemAlarmEnableToggleButton" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsSystemAlarmEnableTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="紀錄查詢">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="dtos:SYSCMFTAuthorityDto">
                                <Grid>
                                    <ToggleButton
                                        x:Name="IsLogSearchEnableToggleButton"
                                        HorizontalAlignment="Center"
                                        IsChecked="{Binding IsLogSearchEnable}"
                                        Style="{StaticResource GridView.Column.ToggleButton.Switch.Center}"
                                        Visibility="Collapsed" />
                                    <TextBlock
                                        x:Name="IsLogSearchEnableTextBlock"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="關閉" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLogSearchEnable}" Value="True">
                                                        <Setter Property="Text" Value="啟用" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsLogSearchEnableToggleButton" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsLogSearchEnableTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                </GridView>
            </ListView.View>
        </ListView>
        <UniformGrid
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Columns="1"
            Style="{StaticResource PanelMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding AddItemCommand}"
                ContentTemplate="{StaticResource AddItemData}"
                Style="{StaticResource AddButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource FalseValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding DeleteItemCommand}"
                ContentTemplate="{StaticResource DeleteItemData}"
                Style="{StaticResource DeleteButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource FalseValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}"
                Visibility="{Binding IsItemOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </UniformGrid>
    </Grid>
</UserControl>
