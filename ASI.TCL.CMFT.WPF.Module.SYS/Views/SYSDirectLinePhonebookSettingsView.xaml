<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.SYS.Views.SYSDirectLinePhonebookSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assist="clr-namespace:ASI.TCL.CMFT.WPF.Assist;assembly=ASI.TCL.CMFT.WPF"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:provider="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.DataTypes"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.ViewModels"
    xmlns:views="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Views"
    d:DataContext="{d:DesignInstance viewModels:SYSDirectLinePhonebookSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <GroupBox
            Grid.Column="0"
            Margin="5,0,0,0"
            Header="群組列表"
            Style="{x:Null}">
            <ListBox
                x:Name="DLTPhoneGroupListBox"
                ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                ItemsSource="{x:Static datas:DesignTimeDatas.DLTPhoneGroups}"
                SelectedIndex="0"
                SelectionMode="Single">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Station.StationID}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ListBox>
        </GroupBox>
        <GroupBox
            Grid.Column="1"
            Margin="5,0,0,0"
            Header="群組成員">

            <ListView
                x:Name="list"
                d:ItemsSource="{x:Static datas:DesignTimeDatas.DLTPhones}"
                ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
                ItemsSource="{Binding SelectedItem.Phones, ElementName=DLTPhoneGroupListBox}"
                SelectionMode="Single">
                <ListView.View>
                    <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">

                        <GridViewColumn Header="遠端電話話">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding PhoneLocation}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Width="150" Header="號碼">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding PhoneNumber}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>
        </GroupBox>
        <UniformGrid
            Grid.Column="2"
            VerticalAlignment="Bottom"
            Style="{StaticResource UniformGridMargin3}">
            <Button d:Visibility="Visible" Style="{StaticResource CancelButton}" />
            <Button Style="{StaticResource AddButton}" />
            <Button Style="{StaticResource DeleteButton}" />
            <Button Style="{StaticResource ConfirmButton}" />
            <Button d:Visibility="Visible" Style="{StaticResource EditButton}" />
        </UniformGrid>
    </Grid>
</UserControl>
