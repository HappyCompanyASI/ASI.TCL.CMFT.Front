<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.SYS.Views.SYSRadioGroupSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assist="clr-namespace:ASI.TCL.CMFT.WPF.Assist;assembly=ASI.TCL.CMFT.WPF"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:provider="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.DataTypes"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.ViewModels"
    xmlns:views="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Views"
    d:DataContext="{d:DesignInstance viewModels:SYSRadioGroupSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <GroupBox
            Grid.Column="0"
            Margin="5,0,0,0"
            Header="群組列表"
            Style="{x:Null}">
            <ListBox
                x:Name="RadioGroupListBox"
                ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                ItemsSource="{Binding SYSRadioGroups}"
                SelectedIndex="0"
                SelectedItem="{Binding SelectedGroup}"
                SelectionMode="Single">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding GroupName}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <prism:InvokeCommandAction Command="{Binding CancelEditOnSelectionChangedCommand}" />
                    </b:EventTrigger>
                </b:Interaction.Triggers>
            </ListBox>
        </GroupBox>
        <GroupBox
            Grid.Column="1"
            Width="350"
            Margin="5,0,0,0"
            Header="可選目標"
            Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}">
            <ListBox
                x:Name="UnselectedRadioListBox"
                Grid.Column="1"
                Margin="5,0,0,0"
                ItemContainerStyle="{StaticResource StretchListBoxItem}"
                ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                ItemsSource="{Binding DataContext.UnselectedRadiosView, RelativeSource={RelativeSource AncestorType=UserControl}}"
                ScrollViewer.VerticalScrollBarVisibility="Visible"
                SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Command="{Binding DataContext.SelectRadioCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Content="{Binding RadioNumber}"
                            Style="{StaticResource SelecterButton}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
        <GroupBox
            Grid.Column="2"
            Margin="5,0,0,0"
            Header="已選目標">
            <ListBox
                x:Name="SelectedRadioListBox"
                ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                ItemsSource="{Binding DataContext.SelectedRadiosView, RelativeSource={RelativeSource AncestorType=UserControl}}"
                ScrollViewer.VerticalScrollBarVisibility="Visible"
                SelectionMode="Single">
                <ListBox.ItemContainerStyle>
                    <Style BasedOn="{StaticResource StretchListBoxItem}" TargetType="ListBoxItem">
                        <Setter Property="IsHitTestVisible" Value="False" />
                        <Setter Property="Focusable" Value="False" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="IsHitTestVisible" Value="True" />
                                <Setter Property="Focusable" Value="True" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Command="{Binding DataContext.SelectRadioCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            Content="{Binding RadioNumber}"
                            Style="{StaticResource SelecterButton}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
        <UniformGrid
            Grid.Column="3"
            VerticalAlignment="Bottom"
            Columns="1"
            Style="{StaticResource PanelMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding AddGroupCommand}"
                ContentTemplate="{StaticResource AddGroupData}"
                Style="{StaticResource AddButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource FalseValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding DeleteGroupCommand}"
                ContentTemplate="{StaticResource DeleteGroupData}"
                Style="{StaticResource DeleteButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource FalseValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditGroupData}"
                Style="{StaticResource EditButton}"
                Visibility="{Binding IsItemOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </UniformGrid>
    </Grid>
</UserControl>
