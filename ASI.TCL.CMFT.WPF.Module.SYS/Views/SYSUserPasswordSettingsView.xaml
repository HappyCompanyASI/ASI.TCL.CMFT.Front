<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.SYS.Views.SYSUserPasswordSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:assist="clr-namespace:ASI.TCL.CMFT.WPF.Assist;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:SYSUserPasswordSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <Grid
        Grid.Row="0"
        Margin="450,0"
        VerticalAlignment="Center">
        <Grid.Resources>
            <Style BasedOn="{StaticResource UniformGridMargin10}" TargetType="UniformGrid" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <UniformGrid Grid.Column="0">
                <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="原密碼" />
                <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="新密碼" />
                <TextBlock Style="{StaticResource CMFT.TextBlock.Left}" Text="確認密碼" />
            </UniformGrid>
            <UniformGrid Grid.Column="1">
                <PasswordBox assist:PasswordBoxAssist.BoundPassword="{Binding OldPassWord, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <PasswordBox assist:PasswordBoxAssist.BoundPassword="{Binding NewPassWord, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <PasswordBox assist:PasswordBoxAssist.BoundPassword="{Binding ConfirmPassWord, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </UniformGrid>
        </Grid>
        <UniformGrid Grid.Row="1" Columns="2">
            <Button
                Height="60"
                Command="{Binding ConfirmCommand}"
                Content="確定"
                Style="{StaticResource OperationButton}" />
            <Button
                Height="60"
                Command="{Binding CancelCommand}"
                Content="取消"
                Style="{StaticResource OperationButton}" />
        </UniformGrid>
    </Grid>
</UserControl>
