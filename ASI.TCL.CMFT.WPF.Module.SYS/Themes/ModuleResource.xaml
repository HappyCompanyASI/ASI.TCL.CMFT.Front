<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dtos1="clr-namespace:ASI.TCL.CMFT.WPF.Module.SYS.Dtos">
    <!--#region SYS-->
    <DataTemplate x:Key="RadioButtonData">
        <RadioButton Style="{StaticResource SelecterRadioButton}">
            <TextBlock Text="{Binding}" />
        </RadioButton>
    </DataTemplate>
    <DataTemplate x:Key="SYSStationGroup" DataType="{x:Type dtos1:SYSStationGroupDto}">
        <RadioButton Style="{StaticResource SelecterRadioButton}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding GroupName}" />
            </StackPanel>
        </RadioButton>
    </DataTemplate>

    <DataTemplate x:Key="SYSStation" DataType="{x:Type dtos1:SYSStationDto}">
        <RadioButton Style="{StaticResource SelecterRadioButton}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StationID}" />
            </StackPanel>
        </RadioButton>
    </DataTemplate>

    <DataTemplate x:Key="SYSRadioGroup" DataType="{x:Type dtos1:RadioGroupDto}">
        <RadioButton Style="{StaticResource SelecterRadioButton}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding GroupName}" />
            </StackPanel>
        </RadioButton>
    </DataTemplate>

    <DataTemplate x:Key="SYSRadio" DataType="{x:Type dtos1:RadioDto}">
        <RadioButton Style="{StaticResource SelecterRadioButton}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding RadioNumber}" />
            </StackPanel>
        </RadioButton>
    </DataTemplate>

    <DataTemplate x:Key="SYSTrainGroup" DataType="{x:Type dtos1:SYSTrainGroupDto}">
        <RadioButton Style="{StaticResource SelecterRadioButton}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding GroupName}" />
            </StackPanel>
        </RadioButton>
    </DataTemplate>

    <DataTemplate x:Key="SYSTrain" DataType="{x:Type dtos1:SYSTrainDto}">
        <RadioButton Style="{StaticResource SelecterRadioButton}">

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding TrainNumber}" />
            </StackPanel>
        </RadioButton>
    </DataTemplate>
    <!--#endregion-->
</ResourceDictionary>