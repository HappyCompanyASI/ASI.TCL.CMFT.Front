<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.OTCS.Views.OTCSMainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:applications="clr-namespace:ASI.TCL.CMFT.WPF.Applications;assembly=ASI.TCL.CMFT.WPF"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Module.OTCS.Converters"
    xmlns:converters1="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataTypes="clr-namespace:ASI.TCL.CMFT.WPF.Module.OTCS.DataTypes"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.OTCS.Datas"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:triggerActions="clr-namespace:ASI.TCL.CMFT.WPF.TriggerActions;assembly=ASI.TCL.CMFT.WPF"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.OTCS.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:OTCSMainViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1620"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="7*" />
        </Grid.ColumnDefinitions>

        <!--#region 操作流程-->
        <GroupBox
            Grid.RowSpan="3"
            Grid.Column="0"
            Margin="0,5"
            Header="操作流程"
            IsHitTestVisible="False">
            <Grid>
                <Grid.Resources>
                    <Style BasedOn="{StaticResource StepRadioButton}" TargetType="{x:Type ToggleButton}" />
                    <Style BasedOn="{StaticResource MainTitleTextBox}" TargetType="{x:Type TextBlock}" />
                </Grid.Resources>
                <UniformGrid VerticalAlignment="Top" Style="{StaticResource UniformGridMargin5}">
                    <ToggleButton Content="1.列車選擇" IsChecked="{Binding CurrentStep, Converter={converters:StepToIsCheckedConverter}, ConverterParameter={x:Static dataTypes:eStep.Step1}}" />
                    <ToggleButton Content="2.車廂選擇" IsChecked="{Binding CurrentStep, Converter={converters:StepToIsCheckedConverter}, ConverterParameter={x:Static dataTypes:eStep.Step2}}" />
                    <ToggleButton Content="3.開始收音" IsChecked="{Binding CurrentStep, Converter={converters:StepToIsCheckedConverter}, ConverterParameter={x:Static dataTypes:eStep.Step3}}" />
                </UniformGrid>
                <TextBlock Text="列車收音" />
            </Grid>
        </GroupBox>
        <!--#endregion-->

        <UniformGrid Grid.Column="1" Columns="1">

            <!--#region 1.目標選擇-->
            <Grid
                d:Visibility="Visible"
                Style="{StaticResource GridMargin5}"
                Visibility="{Binding CurrentStep, Converter={converters1:EqualityToVisibilityConverter}, ConverterParameter={x:Static dataTypes:eStep.Step1}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="7*" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <GroupBox Grid.Column="0" Header="目標">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <ListBox
                            x:Name="TargetGroupListBox"
                            Grid.Column="0"
                            ItemContainerStyle="{StaticResource StretchListBoxItem}"
                            ItemTemplate="{StaticResource SYSTrainGroup}"
                            ItemsPanel="{StaticResource UniformGridItemsPanel1}"
                            ItemsSource="{x:Static datas:DesignTimeDatas.SYSTrainGroups}"
                            SelectedIndex="0"
                            SelectionMode="Single"
                            Style="{StaticResource MaterialDesignListBox}">
                            <b:Interaction.Triggers>
                                <b:EventTrigger EventName="SelectionChanged">
                                    <triggerActions:DoNothingTriggerAction
                                        OperationID="1"
                                        Source="{Binding ItemsSource, ElementName=SelectedTargetListBox}"
                                        Target="{Binding SelectedItems, ElementName=TargetListBox}"
                                        TargetOperation="Add" />
                                </b:EventTrigger>
                            </b:Interaction.Triggers>
                        </ListBox>
                        <ListBox
                            x:Name="TargetListBox"
                            Grid.Column="1"
                            Margin="5,0,0,0"
                            d:ItemsSource="{x:Static datas:DesignTimeDatas.SYSTrains}"
                            ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                            ItemsSource="{Binding SelectedItem.Trains, ElementName=TargetGroupListBox}"
                            SelectionMode="Multiple">
                            <ListBox.ItemContainerStyle>
                                <Style BasedOn="{StaticResource StretchListBoxItem}" TargetType="ListBoxItem">
                                    <!--  要設定ListBoxItem的不是RadioButton的IsEnabled  -->
                                    <Setter Property="IsEnabled" Value="{Binding IsSelected, RelativeSource={RelativeSource Self}, Converter={converters1:BoolNegationConverter}}" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton Style="{StaticResource SelecterRadioButton}">
                                        <b:Interaction.Triggers>
                                            <b:EventTrigger EventName="Checked">
                                                <triggerActions:DoNothingTriggerAction
                                                    OperationID="2"
                                                    Source="{Binding SelectedItems, ElementName=TargetListBox}"
                                                    Target="{Binding ItemsSource, ElementName=SelectedTargetListBox}"
                                                    TargetOperation="Add" />
                                            </b:EventTrigger>
                                        </b:Interaction.Triggers>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding TrainNumber}" />
                                        </StackPanel>
                                    </RadioButton>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </GroupBox>
                <GroupBox Grid.Column="1" Header="已選擇目標">
                    <ListBox
                        x:Name="SelectedTargetListBox"
                        d:ItemsSource="{x:Static datas:DesignTimeDatas.SYSTrains}"
                        ItemContainerStyle="{StaticResource StretchListBoxItem}"
                        ItemsPanel="{StaticResource UniformGridItemsPanel2}"
                        ItemsSource="{Binding SelectedTargets}"
                        SelectionMode="Multiple">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <RadioButton
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorLevel=1, AncestorType=UserControl, Mode=FindAncestor}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource SelecterRadioButton}">
                                    <b:Interaction.Triggers>
                                        <b:EventTrigger EventName="Checked">
                                            <triggerActions:DoNothingTriggerAction
                                                OperationID="3"
                                                Source="{Binding SelectedItems, ElementName=SelectedTargetListBox}"
                                                Target="{Binding SelectedItems, ElementName=TargetListBox}"
                                                TargetOperation="Remove" />
                                        </b:EventTrigger>
                                    </b:Interaction.Triggers>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TrainNumber}" />
                                    </StackPanel>
                                </RadioButton>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>
                <UniformGrid Grid.Column="2" Columns="1">
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Top"
                        Command="{x:Static applications:WPFApplicationCommands.NavigateCommand}"
                        CommandParameter="{x:Static applications:WPFApplicationCommands.DefaultViewName}"
                        Content="取消"
                        Style="{StaticResource NaviStepButton}" />
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Bottom"
                        Command="{Binding StepChangeCommand}"
                        CommandParameter="{x:Static dataTypes:eStep.Step2}"
                        Content="下一步"
                        Style="{StaticResource StepButton}" />
                </UniformGrid>
            </Grid>
            <!--#endregion-->

            <!--#region 2.廣播方式及內容-->
            <Grid
                d:Visibility="Visible"
                Style="{StaticResource GridMargin5}"
                Visibility="{Binding CurrentStep, Converter={converters1:EqualityToVisibilityConverter}, ConverterParameter={x:Static dataTypes:eStep.Step2}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="11*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Style="{StaticResource StackPanelHorizontalMargin5}">
                        <GroupBox Header="已選擇列車">
                            <TextBlock
                                Margin="10,5"
                                Style="{StaticResource CMFT.TextBlock.Center}"
                                Text="{Binding SelectedItem.TrainNumber, ElementName=TargetListBox}" />
                        </GroupBox>
                        <GroupBox Header="已選擇車廂PI">
                            <ContentControl
                                Margin="10,5"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Setter Property="Content">
                                            <Setter.Value>
                                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                    <TextBlock>
                                                        <TextBlock.Style>
                                                            <Style BasedOn="{StaticResource CMFT.TextBlock.Left}" TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=CarPIListBox}" Value="#1">
                                                                        <Setter Property="Text" Value="A" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=CarPIListBox}" Value="#2">
                                                                        <Setter Property="Text" Value="A" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=CarPIListBox}" Value="#3">
                                                                        <Setter Property="Text" Value="A" />
                                                                    </DataTrigger>


                                                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=CarPIListBox}" Value="#7">
                                                                        <Setter Property="Text" Value="C" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=CarPIListBox}" Value="#8">
                                                                        <Setter Property="Text" Value="C" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=CarPIListBox}" Value="#9">
                                                                        <Setter Property="Text" Value="C" />
                                                                    </DataTrigger>

                                                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=CarPIListBox}" Value="#10">
                                                                        <Setter Property="Text" Value="D" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=CarPIListBox}" Value="#11">
                                                                        <Setter Property="Text" Value="D" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=CarPIListBox}" Value="#12">
                                                                        <Setter Property="Text" Value="D" />
                                                                    </DataTrigger>


                                                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=CarPIListBox}" Value="#4">
                                                                        <Setter Property="Text" Value="B" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=CarPIListBox}" Value="#5">
                                                                        <Setter Property="Text" Value="B" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding SelectedItem, ElementName=CarPIListBox}" Value="#6">
                                                                        <Setter Property="Text" Value="B" />
                                                                    </DataTrigger>

                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="車, PI" />
                                                    <TextBlock Style="{StaticResource CMFT.TextBlock.Center}" Text="{Binding SelectedItem, ElementName=CarPIListBox}" />
                                                </StackPanel>
                                            </Setter.Value>
                                        </Setter>

                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </GroupBox>
                    </StackPanel>
                    <GroupBox
                        Grid.Row="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Header="PI位置圖">


                        <StackPanel
                            Margin="30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <UniformGrid Rows="1">
                                <TextBlock
                                    Margin="5"
                                    FontSize="18"
                                    Style="{StaticResource CMFT.TextBlock.Center}"
                                    Text="CAR A" />
                                <TextBlock
                                    Margin="5"
                                    FontSize="18"
                                    Style="{StaticResource CMFT.TextBlock.Center}"
                                    Text="CAR C" />
                            </UniformGrid>
                            <ListBox x:Name="CarPIListBox" SelectedIndex="0">
                                <ItemsControl.Items>
                                    <system:String>#1</system:String>
                                    <system:String>#2</system:String>
                                    <system:String>#3</system:String>
                                    <system:String>#7</system:String>
                                    <system:String>#8</system:String>
                                    <system:String>#9</system:String>

                                    <system:String>#10</system:String>
                                    <system:String>#11</system:String>
                                    <system:String>#12</system:String>
                                    <system:String>#4</system:String>
                                    <system:String>#5</system:String>
                                    <system:String>#6</system:String>
                                </ItemsControl.Items>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListBoxItem}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="6">
                                            <UniformGrid.Resources>
                                                <Style BasedOn="{StaticResource WPF.RadioButton.ButtonLike}" TargetType="{x:Type RadioButton}">
                                                    <Setter Property="FontSize" Value="36" />
                                                    <Setter Property="Margin" Value="3" />
                                                    <Setter Property="Padding" Value="32,8" />
                                                </Style>
                                            </UniformGrid.Resources>
                                        </UniformGrid>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <RadioButton Content="{Binding}" GroupName="Properties">
                                            <RadioButton.IsChecked>
                                                <Binding
                                                    Mode="TwoWay"
                                                    Path="IsSelected"
                                                    RelativeSource="{RelativeSource AncestorType=ListBoxItem}" />
                                            </RadioButton.IsChecked>
                                        </RadioButton>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <UniformGrid Rows="1">
                                <TextBlock
                                    Margin="5"
                                    FontSize="18"
                                    Style="{StaticResource CMFT.TextBlock.Center}"
                                    Text="CAR D" />
                                <TextBlock
                                    Margin="5"
                                    FontSize="18"
                                    Style="{StaticResource CMFT.TextBlock.Center}"
                                    Text="CAR B" />
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>
                </Grid>
                <UniformGrid Grid.Column="1" Columns="1">
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Top"
                        Command="{Binding StepChangeCommand}"
                        CommandParameter="{x:Static dataTypes:eStep.Step1}"
                        Content="上一步"
                        Style="{StaticResource StepButton}" />
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Bottom"
                        Command="{Binding StepChangeCommand}"
                        CommandParameter="{x:Static dataTypes:eStep.Step3}"
                        Content="收音"
                        Style="{StaticResource StepButton}" />
                </UniformGrid>
            </Grid>
            <!--#endregion-->

            <!--#region 3.開始撥放-->
            <Grid
                d:Visibility="Visible"
                Style="{StaticResource GridMargin5}"
                Visibility="{Binding CurrentStep, Converter={converters1:EqualityToVisibilityConverter}, ConverterParameter={x:Static dataTypes:eStep.Step3}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="11*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <GroupBox Grid.Column="0" Header="開始通訊">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="150"
                                    Height="150"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Kind="AlertOutline" />
                                <TextBlock
                                    FontSize="45"
                                    Style="{StaticResource CMFT.TextBlock.Center}"
                                    Text="列車收音已建立" />
                            </StackPanel>
                            <TextBlock
                                FontSize="50"
                                Foreground="{StaticResource CMFT.Brush.Red.Dark}"
                                Style="{StaticResource CMFT.TextBlock.Center}"
                                Text="請於下方無線電系統中操作" />
                        </StackPanel>
                        <materialDesign:PackIcon
                            Width="80"
                            Height="80"
                            Margin="150,0,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Foreground="{StaticResource CMFT.Brush.Red.Dark}"
                            Kind="TriangleDown">
                            <materialDesign:PackIcon.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="1.0"
                                                To="0.0"
                                                Duration="0:0:1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </materialDesign:PackIcon.Triggers>
                        </materialDesign:PackIcon>
                    </Grid>
                </GroupBox>
                <UniformGrid Grid.Column="1" Columns="1">
                    <Button
                        Margin="0,5"
                        VerticalAlignment="Bottom"
                        Command="{x:Static applications:WPFApplicationCommands.NavigateCommand}"
                        CommandParameter="{x:Static applications:WPFApplicationCommands.DefaultViewName}"
                        Content="結束"
                        Style="{StaticResource NaviStepButton}" />
                </UniformGrid>

            </Grid>
            <!--#endregion-->

        </UniformGrid>

    </Grid>
</UserControl>
