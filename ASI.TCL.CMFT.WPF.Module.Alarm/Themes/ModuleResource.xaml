        <Style.Triggers>
            <!--  關掉預設樣式 (需放最前面)  -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="Transparent" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
            </Trigger>

            <!--  # 未解除 && 未確認  -->
            <!--#region 重大 (紅底/黑字/閃爍)-->
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                    <Condition Binding="{Binding Path=IsConfirmed}" Value="false" />
                    <Condition Binding="{Binding Path=AlarmLevel}" Value="{x:Static dto:eAlarmLevel.重大}" />
                </MultiDataTrigger.Conditions>
                <MultiDataTrigger.Setters>
                    <Setter Property="TextBlock.Foreground" Value="{StaticResource CMFT.Brush.Dark}" />
                </MultiDataTrigger.Setters>
                <MultiDataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimationUsingKeyFrames FillBehavior="HoldEnd"
                                                          RepeatBehavior="Forever"
                                                          Storyboard.TargetProperty="(DataGridRow.Background).(SolidColorBrush.Color)"
                                                          Duration="0:0:1">
                                <ColorAnimationUsingKeyFrames.KeyFrames>
                                    <LinearColorKeyFrame KeyTime="0:0:0.0" Value="{StaticResource CMFT.Color.Alarm.High}" />
                                    <LinearColorKeyFrame KeyTime="0:0:0.5" Value="{StaticResource CMFT.Color.Alarm.GrayBG}" />
                                    <LinearColorKeyFrame KeyTime="0:0:1.0" Value="{StaticResource CMFT.Color.Alarm.High}" />
                                </ColorAnimationUsingKeyFrames.KeyFrames>
                            </ColorAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </MultiDataTrigger.EnterActions>
            </MultiDataTrigger>
