                                  d:ItemsSource="{x:Static datas:DesignTimeDatas.EquipAlarmInfos}"
                                  ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
                                  ItemsSource="{Binding EquipAlarms}"
                                  ScrollViewer.VerticalScrollBarVisibility="Visible"
                                  SelectionMode="Single">
                            <ListView.View>
                                <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Left}">

                                    <GridViewColumn Width="Auto" Header="發生時間">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding AlarmTime, StringFormat='{}{0:yyyy/MM/dd HH:mm:ss}'}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="Auto" Header="確認人員">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding Equip.EquipID}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="Auto" Header="地點">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding Equip.RegionName}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="Auto" Header="系統別">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding Equip.EquipTypes.EquipType}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="Auto" Header="設備描述">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding Equip.EquipID}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="Auto" Header="等級">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="600" Header="告警描述">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding AlarmDefine.Description}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <CheckBox Width="100"
                                                          Height="30"
                                                          IsChecked="{Binding IsConfirmed, Mode=OneTime}">
                                                    <CheckBox.Style>
                                                        <Style BasedOn="{StaticResource CMFT.ButtonBase.ButtonLike}" TargetType="{x:Type CheckBox}">
                                                            <Setter Property="IsThreeState" Value="True" />
                                                            <Setter Property="FontWeight" Value="Bold" />
                                                            <Setter Property="Foreground" Value="{DynamicResource AssitColor1}" />
                                                            <Setter Property="Background" Value="{StaticResource CMFT.Brush.Green.Mid}" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Mid}" />
                                                            <Setter Property="Content" Value="確認警報" />
                                                            <Setter Property="IsEnabled" Value="False" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Mode=Self}}" Value="True">
                                                                    <Setter Property="Content" Value="已確認" />
                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Mode=Self}}" Value="False">
                                                                    <Setter Property="Content" Value="確認警報" />
                                                                    <Setter Property="IsEnabled" Value="True" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                </GridView>
                            </ListView.View>

                        </ListView>-->


                        <DataGrid Grid.Row="1"
                                  d:ItemsSource="{x:Static datas:DesignTimeDatas.EquipAlarmInfos}"
                                  CellStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell}"
                                  FontWeight="Bold"
                                  ItemsSource="{Binding EquipAlarms}"
                                  RowStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmRow}"
                                  ScrollViewer.CanContentScroll="False"
                                  Style="{StaticResource CMFT.DataGrid}">

                            <DataGrid.Columns>

                                <DataGridTextColumn Width="Auto"
                                                    Binding="{Binding AlarmTime, StringFormat={}{0:yyyy/MM/dd HH:mm:ss}}"
                                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                                    Header="發生時間" />

                                <DataGridTextColumn Width="Auto"
                                                    Binding="{Binding ReleaseTime, StringFormat={}{0:yyyy/MM/dd HH:mm:ss}}"
                                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                                    Header="解除時間" />

                                <DataGridTextColumn Width="Auto"
                                                    Binding="{Binding EquipDescription}"
                                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                                    Header="設備描述" />

                                <DataGridTextColumn Width="Auto"
                                                    Binding="{Binding SystemType}"
                                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                                    Header="系統別" />

                                <DataGridTextColumn Width="Auto"
                                                    Binding="{Binding AlarmLevel}"
                                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                                    Header="等級" />

                                <DataGridTextColumn Width="1*"
                                                    Binding="{Binding AlarmDescription}"
                                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                                    Header="告警描述" />

                                <DataGridTextColumn Width="Auto"
                                                    Binding="{Binding ConfirmedUserName}"
                                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                                    Header="確認人員" />

                                <DataGridTemplateColumn Header="">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox Width="100" IsChecked="{Binding IsConfirmed, Mode=OneWay}">
                                                <CheckBox.Style>
                                                    <Style BasedOn="{StaticResource CMFT.ButtonBase.ButtonLike}" TargetType="CheckBox">
                                                        <Setter Property="IsThreeState" Value="True" />
                                                        <Setter Property="FontWeight" Value="Bold" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AssitColor1}" />
                                                        <Setter Property="Background" Value="{StaticResource CMFT.Brush.Green.Mid}" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Mid}" />
                                                        <Setter Property="Content" Value="確認警報" />
                                                        <Setter Property="IsEnabled" Value="False" />

                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                                                                <Setter Property="Content" Value="已確認" />
                                                                <Setter Property="IsEnabled" Value="False" />
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="False">
                                                                <Setter Property="Content" Value="確認警報" />
                                                                <Setter Property="IsEnabled" Value="True" />
                                                            </DataTrigger>
                                                        </Style.Triggers>

                                                    </Style>
                                                </CheckBox.Style>
                                            </CheckBox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>

                        </DataGrid>
                    </Grid>
                </Grid>
            </UniformGrid>
        </GroupBox>
    </Grid>
</UserControl>

