<UserControl x:Class="ASI.TCL.CMFT.WPF.Module.Alarm.Views.EquipAlarmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Datas"
             xmlns:mvvm="http://prismlibrary.com/"
             xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance viewModels:EquipAlarmViewModel,
                                              IsDesignTimeCreatable=True}"
             d:DesignWidth="1420"
             mvvm:ViewModelLocator.AutoWireViewModel="True"
             Style="{StaticResource CMFT.UserControl}"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid Grid.Row="0" Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid Grid.Row="0" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <DatePicker Grid.Column="0"
                                materialDesign:HintAssist.Hint="開始時間"
                                SelectedDate="{Binding SelectedStartTime}" />
                    <materialDesign:TimePicker Grid.Column="1"
                                               Margin="5,0,0,0"
                                               SelectedTime="{Binding SelectedStartTime}" />
                </Grid>
                <Grid Grid.Row="1" Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <DatePicker Grid.Column="0"
                                materialDesign:HintAssist.Hint="結束時間"
                                SelectedDate="{Binding SelectedEndTime}" />
                    <materialDesign:TimePicker Grid.Column="1"
                                               Margin="5,0,0,0"
                                               SelectedTime="{Binding SelectedEndTime}" />
                </Grid>
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Margin="4,2"
                         materialDesign:HintAssist.Hint="子系統"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Text="{Binding SelectedSYSConsole.ConsoleName}" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Margin="4,2"
                         materialDesign:HintAssist.Hint="確認人員"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Text="{Binding SelectedAlarmCode}" />

                <TextBox Grid.Row="0"
                         Grid.Column="2"
                         Margin="4,0"
                         materialDesign:HintAssist.Hint="嚴重程度"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Text="{Binding SelectedAccountId}" />
                <TextBox Grid.Row="1"
                         Grid.Column="2"
                         Margin="4,2"
                         materialDesign:HintAssist.Hint="顯示筆數"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Text="{Binding SelectedContent}" />

                <TextBox Grid.Row="0"
                         Grid.Column="3"
                         Margin="4,2"
                         materialDesign:HintAssist.Hint="設備地點"
                         materialDesign:TextFieldAssist.HasClearButton="True" />
                <TextBox Grid.Row="1"
                         Grid.Column="3"
                         Margin="4,2"
                         materialDesign:HintAssist.Hint="告警描述"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Text="{Binding SelectedContent}" />
            </Grid>
            <Grid Grid.RowSpan="2" Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Margin="2"
                        Command="{Binding SearchCommand}"
                        Content="搜尋"
                        Style="{StaticResource OperationButton}" />
                <Button Grid.Column="1"
                        Margin="2"
                        Background="{StaticResource CMFT.Brush.Green.Dark}"
                        Command="{Binding RemitCommand}"
                        Content="匯出"
                        Style="{StaticResource OperationButton}" />
            </Grid>
        </Grid>

        <DataGrid Grid.Row="1"
                  d:ItemsSource="{x:Static datas:DesignTimeDatas.EquipAlarmInfos}"
                  CellStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell}"
                  FontWeight="Bold"
                  ItemsSource="{Binding EquipAlarms}"
                  RowStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmRow}"
                  ScrollViewer.CanContentScroll="False"
                  Style="{StaticResource CMFT.DataGrid}">

            <DataGrid.Columns>

                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding AlarmTime, StringFormat={}{0:yyyy/MM/dd HH:mm:ss}}"
                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                    Header="發生時間" />

                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding ReleaseTime, StringFormat={}{0:yyyy/MM/dd HH:mm:ss}}"
                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                    Header="解除時間" />

                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding EquipDescription}"
                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                    Header="設備描述" />

                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding SystemType}"
                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                    Header="系統別" />

                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding AlarmLevel}"
                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                    Header="等級" />

                <DataGridTextColumn Width="1*"
                                    Binding="{Binding AlarmDescription}"
                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                    Header="告警描述" />

                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding ConfirmedUserName}"
                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                    Header="確認人員" />

                <DataGridTemplateColumn Header="">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox Width="100" IsChecked="{Binding IsConfirmed, Mode=OneWay}">
                                <CheckBox.Style>
                                    <Style BasedOn="{StaticResource CMFT.ButtonBase.ButtonLike}" TargetType="CheckBox">
                                        <Setter Property="IsThreeState" Value="True" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="Foreground" Value="{DynamicResource AssitColor1}" />
                                        <Setter Property="Background" Value="{StaticResource CMFT.Brush.Green.Mid}" />
                                        <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Mid}" />
                                        <Setter Property="Content" Value="確認警報" />
                                        <Setter Property="IsEnabled" Value="False" />

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True">
                                                <Setter Property="Content" Value="已確認" />
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="False">
                                                <Setter Property="Content" Value="確認警報" />
                                                <Setter Property="IsEnabled" Value="True" />
                                            </DataTrigger>
                                        </Style.Triggers>

                                    </Style>
                                </CheckBox.Style>
                            </CheckBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>
    </Grid>

</UserControl>

