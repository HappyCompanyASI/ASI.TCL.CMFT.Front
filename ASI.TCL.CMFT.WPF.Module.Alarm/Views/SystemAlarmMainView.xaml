<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.Alarm.Views.SystemAlarmMainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataTypes="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.DataTypes"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:SystemAlarmMainViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="540"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <GroupBox Margin="5" Header="設定">
            <UniformGrid Columns="1">


                <Grid d:Visibility="Visible">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="7*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <ListView
                            x:Name="EventListView"
                            Grid.Column="0"
                            ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
                            ItemsSource="{x:Static datas:DesignTimeDatas.SYSOperationLogs}"
                            ScrollViewer.VerticalScrollBarVisibility="Visible"
                            SelectionMode="Single">

                            <ListView.View>
                                <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">

                                    <GridViewColumn Header="事件時間">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding EventTime, StringFormat='{}{0:yyyy/MM/dd HH:mm:ss}'}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="確認人員">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="通訊系統別">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="設備代號">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="類別">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="代碼">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="等級">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="告警描述">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="狀態">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="攝影機連動">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:SYSOperationLogDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                </GridView>
                            </ListView.View>
                        </ListView>
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Margin="10,0,10,10"
                                Style="{StaticResource CMFT.TextBlock.Left}"
                                Text="搜尋條件" />
                            <ScrollViewer Grid.Row="1" VerticalAlignment="Top">
                                <UniformGrid Style="{StaticResource UniformGridMargin10}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <DatePicker
                                            Grid.Column="0"
                                            materialDesign:HintAssist.Hint="開始時間"
                                            SelectedDate="{Binding SelectedStartTime}" />
                                        <materialDesign:TimePicker
                                            Grid.Column="1"
                                            Margin="5,0,0,0"
                                            SelectedTime="{Binding SelectedStartTime}" />
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <DatePicker
                                            Grid.Column="0"
                                            materialDesign:HintAssist.Hint="結束時間"
                                            SelectedDate="{Binding SelectedEndTime}" />
                                        <materialDesign:TimePicker
                                            Grid.Column="1"
                                            Margin="5,0,0,0"
                                            SelectedTime="{Binding SelectedEndTime}" />
                                    </Grid>


                                    <TextBox
                                        Margin="4,0"
                                        materialDesign:HintAssist.Hint="確認人員"
                                        materialDesign:TextFieldAssist.HasClearButton="True"
                                        Text="{Binding SelectedAccountId}" />
                                    <ComboBox
                                        Margin="4,2"
                                        materialDesign:HintAssist.Hint="設備種類"
                                        materialDesign:TextFieldAssist.HasClearButton="True"
                                        ItemsSource="{x:Static datas:DesignTimeDatas.SystemTypes}"
                                        SelectedItem="{Binding SelectedSystemTypes}" />
                                    <TextBox
                                        Margin="4,2"
                                        materialDesign:HintAssist.Hint="設備代號"
                                        materialDesign:TextFieldAssist.HasClearButton="True"
                                        Text="{Binding SelectedSYSConsole.ConsoleName}" />
                                    <TextBox
                                        Margin="4,2"
                                        materialDesign:HintAssist.Hint="告警代碼"
                                        materialDesign:TextFieldAssist.HasClearButton="True"
                                        Text="{Binding SelectedAlarmCode}" />
                                    <TextBox
                                        Margin="4,2"
                                        materialDesign:HintAssist.Hint="告警內容"
                                        materialDesign:TextFieldAssist.HasClearButton="True"
                                        Text="{Binding SelectedContent}" />


                                </UniformGrid>



                            </ScrollViewer>
                            <UniformGrid Grid.Row="2" Columns="2">
                                <Button
                                    Command="{Binding SearchCommand}"
                                    Content="搜尋"
                                    Style="{StaticResource OperationButton}" />
                                <Button
                                    Background="{StaticResource CMFT.Brush.Green.Dark}"
                                    Command="{Binding RemitCommand}"
                                    Content="匯出"
                                    Style="{StaticResource OperationButton}" />
                            </UniformGrid>



                        </Grid>

                    </Grid>
                </Grid>



            </UniformGrid>
        </GroupBox>

    </Grid>
</UserControl>
