<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.Alarm.Views.AlarmSettingMainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Datas"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:AlarmSettingMainViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1080"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="8*" />
        </Grid.ColumnDefinitions>

        <!--#region 操作功能-->
        <GroupBox
            Grid.Column="0"
            Margin="5,5,0,5"
            Header="操作功能">
            <Grid>
                <Grid.Resources>
                    <Style BasedOn="{StaticResource StepRadioButton}" TargetType="{x:Type RadioButton}">
                        <Setter Property="Command" Value="{Binding NavigateCommand}" />
                    </Style>
                    <Style BasedOn="{StaticResource MainTitleTextBox}" TargetType="{x:Type TextBlock}" />
                </Grid.Resources>
                <UniformGrid VerticalAlignment="Top" Style="{StaticResource UniformGridMargin5}">
                    <RadioButton
                        CommandParameter="{x:Static datas:NavigatePath.AlarmLevelDefinitionSettings}"
                        Content="告警等級定義"
                        IsChecked="True" />
                    <RadioButton CommandParameter="{x:Static datas:NavigatePath.AlarmTypeDefinitionSettings}" Content="告警類型定義" />
                </UniformGrid>
                <TextBlock Text="通訊告警設定" />
            </Grid>
        </GroupBox>
        <!--#endregion-->

        <GroupBox
            Grid.Column="1"
            Margin="5"
            Header="設定">
            <UniformGrid Columns="1">
                <ContentControl prism:RegionManager.RegionName="{x:Static datas:RegionNames.AlarmSettingsRegion}" />
            </UniformGrid>
        </GroupBox>

    </Grid>
</UserControl>
