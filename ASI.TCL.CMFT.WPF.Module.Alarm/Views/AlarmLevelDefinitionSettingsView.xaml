<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.Alarm.Views.AlarmLevelDefinitionSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataTypes="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.DataTypes"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Dtos"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:AlarmLevelDefinitionSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1080"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ListView
            ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
            ItemsSource="{Binding AlarmLevelDefines}"
            SelectedIndex="0"
            SelectedItem="{Binding SelectedItem}"
            SelectionMode="Single">
            <b:Interaction.Behaviors>
                <!--  自訂Behavior來避免combobox的SelectionChanged事件bubble到ListViewItem  -->
                <behaviors:ListViewSelectionChangedBehavior Command="{Binding CancelEditOnSelectionChangedCommand}" />
            </b:Interaction.Behaviors>
            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">

                    <GridViewColumn Width="150" Header="嚴重程度">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:AlarmLevelDefineDto}">
                                <TextBlock Style="{StaticResource GridView.VerticalColumnHeader.Center}" Text="{Binding AlarmLevel}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="150" Header="確認需求">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:AlarmLevelDefineDto}">
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <ToggleButton
                                        x:Name="IsNeedConfirmToggleButton"
                                        HorizontalAlignment="Center"
                                        IsChecked="{Binding IsNeedConfirm}"
                                        Style="{StaticResource GridView.Column.ToggleButton.Switch.Center}"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="IsNeedConfirmTextBlock"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <!--  預設顯示 "關閉"  -->
                                                <Setter Property="Text" Value="關閉" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <!--  IsUseDU 為 true 時顯示 "啟用"  -->
                                                    <DataTrigger Binding="{Binding IsNeedConfirm}" Value="True">
                                                        <Setter Property="Text" Value="啟用" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsNeedConfirmToggleButton" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsNeedConfirmTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="150" Header="告警顏色">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:AlarmLevelDefineDto}">
                                <Grid>
                                    <!--  ComboBox 編輯  -->
                                    <ComboBox
                                        x:Name="ColorComboBox"
                                        ItemsSource="{Binding DataContext.ColorsOptions, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        SelectedItem="{Binding Color}"
                                        Style="{StaticResource GridView.Column.ComboBox.Center}"
                                        Visibility="Collapsed">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border
                                                        Width="100"
                                                        Height="30"
                                                        Background="{Binding .}"
                                                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                                                        BorderThickness="2" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <!--  TextBlock 檢視  -->
                                    <Border
                                        x:Name="ColorBorder"
                                        Width="100"
                                        Height="30"
                                        Background="{Binding Color}"
                                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                                        BorderThickness="2" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="ColorComboBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="ColorBorder" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="150" Header="告警聲音">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:AlarmLevelDefineDto}">
                                <Grid>
                                    <!--  ComboBox 編輯  -->
                                    <ComboBox
                                        x:Name="GroupComboBox"
                                        ItemsSource="{Binding DataContext.SoundsOptions, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        SelectedItem="{Binding AlarmSound}"
                                        Style="{StaticResource GridView.Column.ComboBox.Center}"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="GroupTextBlock"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Text="{Binding AlarmSound}"
                                        Visibility="Visible" />
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="GroupComboBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="GroupTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="150" Header="閃爍">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:AlarmLevelDefineDto}">
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <ToggleButton
                                        x:Name="IsFlashingToggleButton"
                                        HorizontalAlignment="Center"
                                        IsChecked="{Binding IsFlashing}"
                                        Style="{StaticResource GridView.Column.ToggleButton.Switch.Center}"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="IsFlashingTextBlock"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <!--  預設顯示 "關閉"  -->
                                                <Setter Property="Text" Value="關閉" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <!--  IsUseDU 為 true 時顯示 "啟用"  -->
                                                    <DataTrigger Binding="{Binding IsFlashing}" Value="True">
                                                        <Setter Property="Text" Value="啟用" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsFlashingToggleButton" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsFlashingTextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="150" Header="傳送自SCADA">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:AlarmLevelDefineDto}">
                                <Grid>
                                    <!--  TextBox 編輯  -->
                                    <ToggleButton
                                        x:Name="IsToSCADAToggleButton"
                                        HorizontalAlignment="Center"
                                        IsChecked="{Binding IsToSCADA}"
                                        Style="{StaticResource GridView.Column.ToggleButton.Switch.Center}"
                                        Visibility="Collapsed" />
                                    <!--  TextBlock 檢視  -->
                                    <TextBlock
                                        x:Name="IsToSCADATextBlock"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <!--  預設顯示 "關閉"  -->
                                                <Setter Property="Text" Value="關閉" />
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <!--  IsUseDU 為 true 時顯示 "啟用"  -->
                                                    <DataTrigger Binding="{Binding IsToSCADA}" Value="True">
                                                        <Setter Property="Text" Value="啟用" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="IsToSCADAToggleButton" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="IsToSCADATextBlock" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                </GridView>
            </ListView.View>
        </ListView>

        <UniformGrid
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Style="{StaticResource UniformGridMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}"
                Visibility="{Binding IsItemOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </UniformGrid>
    </Grid>

</UserControl>
