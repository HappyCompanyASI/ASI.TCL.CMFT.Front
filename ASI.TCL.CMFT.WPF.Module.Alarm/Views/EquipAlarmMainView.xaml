<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.Alarm.Views.EquipAlarmMainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:EquipAlarmMainViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="540"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <GroupBox Margin="5" Header="設定">
            <UniformGrid Columns="1">


                <Grid d:Visibility="Visible">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="7*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <ListView
                            x:Name="EventListView"
                            Grid.Column="0"
                            ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
                            ItemsSource="{Binding EquipAlarms}"
                            ScrollViewer.VerticalScrollBarVisibility="Visible"
                            SelectionMode="Single">
                            <ListView.View>
                                <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">

                                    <GridViewColumn Header="發生時間">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <StackPanel Orientation="Vertical">
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding AlarmTime, StringFormat='{}{0:yyyy/MM/dd}'}" />
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding AlarmTime, StringFormat='{}{0:HH:mm:ss}'}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="解除時間">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <StackPanel Orientation="Vertical">
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding ReleaseTime, StringFormat='{}{0:yyyy/MM/dd}'}" />
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding ReleaseTime, StringFormat='{}{0:HH:mm:ss}'}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="設備編號">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding Equip.EquipID}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!--<GridViewColumn Header="地點/樓層/位置">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <StackPanel Orientation="Vertical">
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding Equip.RegionName}" />
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding Equip.AreaName}" />
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding Equip.PlaceName}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>-->

                                    <GridViewColumn Header="子系統/設備類型">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <StackPanel Orientation="Vertical">
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding Equip.EquipTypes.SystemType}" />
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding Equip.EquipTypes.EquipType}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="告警等級">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="300" Header="說明/可能原因">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <StackPanel Orientation="Vertical">
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding AlarmDefine.Description}" />
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding AlarmDefine.PossibleReason}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="確認時間">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <StackPanel Orientation="Vertical">
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding ConfirmedTime, StringFormat='{}{0:yyyy/MM/dd}'}" />
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding ConfirmedTime, StringFormat='{}{0:HH:mm:ss}'}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EquipAlarmDto}">
                                                <CheckBox
                                                    Width="100"
                                                    Height="30"
                                                    IsChecked="{Binding IsConfirmed, Mode=OneTime}">
                                                    <CheckBox.Style>
                                                        <Style BasedOn="{StaticResource CMFT.ButtonBase.ButtonLike}" TargetType="{x:Type CheckBox}">
                                                            <Setter Property="IsThreeState" Value="True" />
                                                            <Setter Property="FontWeight" Value="Bold" />
                                                            <Setter Property="Foreground" Value="{DynamicResource AssitColor1}" />
                                                            <Setter Property="Background" Value="{StaticResource CMFT.Brush.Green.Mid}" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource CMFT.Brush.Green.Mid}" />
                                                            <Setter Property="Content" Value="確認警報" />
                                                            <Setter Property="IsEnabled" Value="False" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Mode=Self}}" Value="True">
                                                                    <Setter Property="Content" Value="已確認" />
                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource Mode=Self}}" Value="False">
                                                                    <Setter Property="Content" Value="確認警報" />
                                                                    <Setter Property="IsEnabled" Value="True" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                </GridView>
                            </ListView.View>

                        </ListView>
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Margin="10,0,10,10"
                                Style="{StaticResource CMFT.TextBlock.Left}"
                                Text="搜尋條件" />

                            <ScrollViewer Grid.Row="1" VerticalAlignment="Top">
                                <UniformGrid Style="{StaticResource UniformGridMargin10}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <DatePicker
                                            Grid.Column="0"
                                            materialDesign:HintAssist.Hint="開始時間"
                                            SelectedDate="{Binding SelectedStartTime}" />
                                        <materialDesign:TimePicker
                                            Grid.Column="1"
                                            Margin="5,0,0,0"
                                            SelectedTime="{Binding SelectedStartTime}" />
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <DatePicker
                                            Grid.Column="0"
                                            materialDesign:HintAssist.Hint="結束時間"
                                            SelectedDate="{Binding SelectedEndTime}" />
                                        <materialDesign:TimePicker
                                            Grid.Column="1"
                                            Margin="5,0,0,0"
                                            SelectedTime="{Binding SelectedEndTime}" />
                                    </Grid>


                                    <TextBox
                                        Margin="4,0"
                                        materialDesign:HintAssist.Hint="嚴重程度"
                                        materialDesign:TextFieldAssist.HasClearButton="True"
                                        Text="{Binding SelectedAccountId}" />
                                    <!--<TextBox
                                        Margin="4,2"
                                        materialDesign:HintAssist.Hint="設備地點"
                                        materialDesign:TextFieldAssist.HasClearButton="True" />-->
                                    <TextBox
                                        Margin="4,2"
                                        materialDesign:HintAssist.Hint="子系統"
                                        materialDesign:TextFieldAssist.HasClearButton="True"
                                        Text="{Binding SelectedSYSConsole.ConsoleName}" />
                                    <TextBox
                                        Margin="4,2"
                                        materialDesign:HintAssist.Hint="確認人員"
                                        materialDesign:TextFieldAssist.HasClearButton="True"
                                        Text="{Binding SelectedAlarmCode}" />
                                    <TextBox
                                        Margin="4,2"
                                        materialDesign:HintAssist.Hint="說明"
                                        materialDesign:TextFieldAssist.HasClearButton="True"
                                        Text="{Binding SelectedContent}" />
                                    <TextBox
                                        Margin="4,2"
                                        materialDesign:HintAssist.Hint="顯示筆數"
                                        materialDesign:TextFieldAssist.HasClearButton="True"
                                        Text="{Binding SelectedContent}" />
                                </UniformGrid>
                            </ScrollViewer>

                            <UniformGrid Grid.Row="2" Columns="2">
                                <Button
                                    Command="{Binding SearchCommand}"
                                    Content="搜尋"
                                    Style="{StaticResource OperationButton}" />
                                <Button
                                    Background="{StaticResource CMFT.Brush.Green.Dark}"
                                    Command="{Binding RemitCommand}"
                                    Content="匯出"
                                    Style="{StaticResource OperationButton}" />
                            </UniformGrid>

                        </Grid>
                    </Grid>
                </Grid>
            </UniformGrid>
        </GroupBox>
    </Grid>
</UserControl>

