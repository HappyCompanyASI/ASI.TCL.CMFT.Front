<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.Alarm.Views.AlarmMainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="1650"
    d:DesignHeight="541"
    Background="Transparent"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">
    <StackPanel Width="1650">
        <Border Background="{DynamicResource SecondaryHueDarkBrush}" CornerRadius="10, 10, 0, 0">
            <Grid
                Margin="5"
                HorizontalAlignment="Stretch"
                Panel.ZIndex="2">
                <StackPanel
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="10,0,0,0"
                        Foreground="{DynamicResource MaterialDesignDarkForeground}"
                        Style="{DynamicResource CMFT.TextBlock.Left}"
                        Text="通訊設備即時告警 (當前未確認數量：" />
                    <TextBlock
                        Margin="0,0,0,0"
                        Foreground="{DynamicResource MaterialDesignDarkForeground}"
                        Style="{DynamicResource CMFT.TextBlock.Left}"
                        Text="{Binding Path=vmpUnConfirmCount}" />
                    <TextBlock
                        Margin="10,0,0,0"
                        Foreground="{DynamicResource MaterialDesignDarkForeground}"
                        Style="{DynamicResource CMFT.TextBlock.Left}"
                        Text="筆)" />
                </StackPanel>

                <Button
                    Width="30"
                    Padding="0,4"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="{x:Null}"
                    BorderBrush="{x:Null}"
                    Command="{x:Static materialDesign:DrawerHost.CloseDrawerCommand}"
                    CommandParameter="{x:Static Dock.Bottom}"
                    Style="{StaticResource MaterialDesignFlatMidBgButton}">
                    <materialDesign:PackIcon
                        Width="20"
                        Height="20"
                        Foreground="{DynamicResource MaterialDesignDarkForeground}"
                        Kind="WindowMinimize" />
                </Button>

            </Grid>
        </Border>

        <Border Background="{DynamicResource MaterialDesignBackground}">
            <DataGrid
                x:Name="AlarmInfosDataGrid"
                Height="600"
                FontWeight="Bold"
                ItemsSource="{x:Static datas:DesignTimeDatas.EquipAlarmInfos}"
                ScrollViewer.CanContentScroll="False"
                Style="{StaticResource CMFT.DataGrid}">

                <!--#region 告警顏色Style-->
                <DataGrid.RowStyle>
                    <Style TargetType="{x:Type DataGridRow}">

                        <!--#region 異常已解除 && 已確認(白底/黑字/不閃爍)-->
                        <Setter Property="TextBlock.Background" Value="Transparent" />
                        <Setter Property="TextBlock.Foreground" Value="{StaticResource TextColor}" />
                        <!--#endregion-->

                        <Style.Triggers>

                            <!--#region 異常未解除 && 重大事件 && 未確認(紅底/黑字/閃爍)-->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.緊急}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="TextBlock.Foreground" Value="{StaticResource TextColor}" />
                                </MultiDataTrigger.Setters>
                                <MultiDataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames
                                                FillBehavior="HoldEnd"
                                                RepeatBehavior="Forever"
                                                Storyboard.TargetProperty="(DataGridRow.Background).(SolidColorBrush.Color)"
                                                Duration="0:0:1">
                                                <ColorAnimationUsingKeyFrames.KeyFrames>
                                                    <LinearColorKeyFrame KeyTime="0:0:0.0" Value="{StaticResource CMFT.Color.Alarm.High}" />
                                                    <LinearColorKeyFrame KeyTime="0:0:0.3" Value="{StaticResource CMFT.Color.Alarm.High}" />
                                                    <LinearColorKeyFrame KeyTime="0:0:0.5" Value="{StaticResource CMFT.Color.Alarm.GrayBG}" />
                                                    <LinearColorKeyFrame KeyTime="0:0:0.8" Value="{StaticResource CMFT.Color.Alarm.GrayBG}" />
                                                    <LinearColorKeyFrame KeyTime="0:0:1.0" Value="{StaticResource CMFT.Color.Alarm.High}" />
                                                </ColorAnimationUsingKeyFrames.KeyFrames>
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiDataTrigger.EnterActions>
                            </MultiDataTrigger>
                            <!--#endregion-->

                            <!--#region 異常未解除 && 中度事件 && 未確認(橘底/黑字/閃爍)-->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.中}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="TextBlock.Foreground" Value="{StaticResource TextColor}" />
                                </MultiDataTrigger.Setters>
                                <MultiDataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames
                                                FillBehavior="HoldEnd"
                                                RepeatBehavior="Forever"
                                                Storyboard.TargetProperty="(DataGridRow.Background).(SolidColorBrush.Color)"
                                                Duration="0:0:1">
                                                <ColorAnimationUsingKeyFrames.KeyFrames>
                                                    <LinearColorKeyFrame KeyTime="0:0:0.0" Value="{StaticResource CMFT.Color.Alarm.Middle}" />
                                                    <LinearColorKeyFrame KeyTime="0:0:0.3" Value="{StaticResource CMFT.Color.Alarm.Middle}" />
                                                    <LinearColorKeyFrame KeyTime="0:0:0.5" Value="{StaticResource CMFT.Color.Alarm.GrayBG}" />
                                                    <LinearColorKeyFrame KeyTime="0:0:0.8" Value="{StaticResource CMFT.Color.Alarm.GrayBG}" />
                                                    <LinearColorKeyFrame KeyTime="0:0:1.0" Value="{StaticResource CMFT.Color.Alarm.Middle}" />
                                                </ColorAnimationUsingKeyFrames.KeyFrames>
                                            </ColorAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiDataTrigger.EnterActions>
                            </MultiDataTrigger>
                            <!--#endregion-->

                            <!--#region 異常未解除 && 輕微事件 && 未確認(黃底/黑字/閃爍)-->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.低}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="TextBlock.Foreground" Value="{StaticResource TextColor}" />
                                </MultiDataTrigger.Setters>
                                <MultiDataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimationUsingKeyFrames
                                                FillBehavior="HoldEnd"
                                                RepeatBehavior="Forever"
                                                Storyboard.TargetProperty="(DataGridRow.Background).(SolidColorBrush.Color)"
                                                Duration="0:0:1">
                                                <ColorAnimationUsingKeyFrames.KeyFrames>
                                                    <LinearColorKeyFrame KeyTime="0:0:0.0" Value="{StaticResource CMFT.Color.Alarm.Low}" />
                                                    <LinearColorKeyFrame KeyTime="0:0:0.3" Value="{StaticResource CMFT.Color.Alarm.Low}" />
                                                    <LinearColorKeyFrame KeyTime="0:0:0.5" Value="{StaticResource CMFT.Color.Alarm.GrayBG}" />
                                                    <LinearColorKeyFrame KeyTime="0:0:0.8" Value="{StaticResource CMFT.Color.Alarm.GrayBG}" />
                                                    <LinearColorKeyFrame KeyTime="0:0:1.0" Value="{StaticResource CMFT.Color.Alarm.Low}" />
                                                </ColorAnimationUsingKeyFrames.KeyFrames>
                                            </ColorAnimationUsingKeyFrames>

                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiDataTrigger.EnterActions>
                            </MultiDataTrigger>
                            <!--#endregion-->

                            <!--  確認有兩種 確認時間已經押上去 or 確認按鈕以點擊  -->

                            <!--#region 異常未解除 && 重大事件 && 已確認(紅底/黑字/不閃爍)-->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.高}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="true" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="Background" Value="{StaticResource CMFT.Brush.Alarm.High}" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.高}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="true" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="Background" Value="{StaticResource CMFT.Brush.Alarm.High}" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <!--#endregion-->

                            <!--#region 異常未解除 && 中度事件 && 已確認(橘底/黑字/不閃爍)-->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.中}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="true" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="Background" Value="{StaticResource CMFT.Brush.Alarm.Middle}" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.中}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="true" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="Background" Value="{StaticResource CMFT.Brush.Alarm.Middle}" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <!--#endregion-->

                            <!--#region 異常未解除 && 輕微事件 && 已確認(黃底/黑字/不閃爍)-->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.低}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="true" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="Background" Value="{StaticResource CMFT.Brush.Alarm.Low}" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.低}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="true" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="Background" Value="{StaticResource CMFT.Brush.Alarm.Low}" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <!--#endregion-->

                            <!--#region 異常已解除 && 重大事件 && 未確認(灰底/紅字/不閃爍)-->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.高}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="true" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="Background" Value="{StaticResource CMFT.Brush.Gray.Dark}" />
                                    <Setter Property="TextBlock.Foreground" Value="{StaticResource CMFT.Brush.Alarm.High}" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.高}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="true" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="Background" Value="{StaticResource CMFT.Brush.Gray.Dark}" />
                                    <Setter Property="TextBlock.Foreground" Value="{StaticResource CMFT.Brush.Alarm.High}" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <!--#endregion-->

                            <!--#region 異常已解除 && 中度事件 && 未確認(灰底/橘字/不閃爍)-->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.中}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="true" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="Background" Value="{StaticResource CMFT.Brush.Gray.Dark}" />
                                    <Setter Property="TextBlock.Foreground" Value="{StaticResource CMFT.Brush.Alarm.Middle}" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.中}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="true" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="Background" Value="{StaticResource CMFT.Brush.Gray.Dark}" />
                                    <Setter Property="TextBlock.Foreground" Value="{StaticResource CMFT.Brush.Alarm.Middle}" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <!--#endregion-->

                            <!--#region 異常已解除 && 輕微事件 && 未確認(灰底/黃字/不閃爍)-->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.低}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="true" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="Background" Value="{StaticResource CMFT.Brush.Gray.Dark}" />
                                    <Setter Property="TextBlock.Foreground" Value="{StaticResource CMFT.Brush.Alarm.Low}" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding AlarmDefine.AlarmLevelDefine.AlarmLevel}" Value="{x:Static dtos:eAlarmLevel.低}" />
                                    <Condition Binding="{Binding Path=ReleaseTime, Converter={converters:IsNotNullConverter}}" Value="true" />
                                    <Condition Binding="{Binding Path=ConfirmedTime, Converter={converters:IsNotNullConverter}}" Value="false" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.Setters>
                                    <Setter Property="Background" Value="{StaticResource CMFT.Brush.Gray.Dark}" />
                                    <Setter Property="TextBlock.Foreground" Value="{StaticResource CMFT.Brush.Alarm.Low}" />
                                </MultiDataTrigger.Setters>
                            </MultiDataTrigger>
                            <!--#endregion-->

                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <!--#endregion-->

                <!--#region 取消MouseOver跟Selected時的顏色-->
                <DataGrid.CellStyle>
                    <Style
                        x:Name="NoOverSelectColor"
                        BasedOn="{StaticResource DataGridCellSmallPadding}"
                        TargetType="DataGridCell">
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True" />
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Background" Value="Transparent" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <!--#endregion-->

                <!--#region  Column設定-->
                <DataGrid.Columns>

                    <!--  地點  -->
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding Equip.RegionName}"
                        ElementStyle="{StaticResource CMFT.DataGrid.Element.TextBlock.Center}"
                        Header="地點" />
                    <!--  樓層  -->
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding Equip.PlaceName}"
                        ElementStyle="{StaticResource CMFT.DataGrid.Element.TextBlock.Center}"
                        Header="樓層" />
                    <!--  子系統  -->
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding Equip.SystemName}"
                        ElementStyle="{StaticResource CMFT.DataGrid.Element.TextBlock.Center}"
                        Header="子系統" />
                    <!--  設備類型  -->
                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding Equip.EquipType}"
                        ElementStyle="{StaticResource CMFT.DataGrid.Element.TextBlock.Center}"
                        Header="設備類型" />
                    <!--  發生時間  -->

                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding AlarmTime}"
                        ElementStyle="{StaticResource CMFT.DataGrid.Element.TextBlock.Center}"
                        Header="發生時間" />
                    <!--  說明  -->
                    <DataGridTemplateColumn Width="1*" Header="說明">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    FontSize="{DynamicResource DataGridContentSize}"
                                    Text="{Binding AlarmDefine.Description}"
                                    TextWrapping="Wrap" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!--  可能原因  -->
                    <DataGridTemplateColumn Width="1*" Header="可能原因">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="{DynamicResource DataGridContentSize}"
                                    Text="{Binding AlarmDefine.PossibleReason}"
                                    TextWrapping="Wrap" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>


                    <!--  確認時間  -->

                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding Path=ConfirmedTime}"
                        ElementStyle="{StaticResource CMFT.DataGrid.Element.TextBlock.Center}"
                        Header="確認時間" />

                    <!--  解除時間  -->

                    <DataGridTextColumn
                        Width="Auto"
                        Binding="{Binding Path=ReleaseTime}"
                        ElementStyle="{StaticResource CMFT.DataGrid.Element.TextBlock.Center}"
                        Header="解除時間" />

                    <!--  確認按鈕  -->
                    <DataGridTemplateColumn Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <!--
                                    Command="{Binding DataContext.ConfirmCommand, RelativeSource={RelativeSource AncestorLevel=1, AncestorType={x:Type DataGrid}, Mode=FindAncestor}}"
                                    CommandParameter="{Binding Path=SelectedItem, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGrid}}}"
                                -->
                                <Button
                                    Width="100"
                                    Height="30"
                                    IsEnabled="{Binding Path=IsConfirmed, Converter={converters:BoolNegationConverter}}">
                                    <Button.Style>
                                        <Style BasedOn="{StaticResource CMFT.Button}" TargetType="{x:Type Button}">
                                            <Setter Property="Content" Value="確認警報" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsConfirmed}" Value="{x:Null}">
                                                    <Setter Property="Content" Value="確認中" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsConfirmed}" Value="true">
                                                    <Setter Property="Content" Value="已確認" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                <!--#endregion-->

            </DataGrid>



            <!--  Style="{StaticResource CMFT.DataGrid}" 需要,避免切換Theme時 DataGridRowHeader.BorderBrush跟DataGridRowHeader.BorderThickness繫結失敗  -->
        </Border>
    </StackPanel>
</UserControl>
