<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.Alarm.Views.AlarmTypeDefinitionSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Behaviors"
    xmlns:converters="clr-namespace:ASI.TCL.CMFT.WPF.Converters;assembly=ASI.TCL.CMFT.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataTypes="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.DataTypes"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Dtos"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:AlarmTypeDefinitionSettingsViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="1080"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ListView
            ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
            ItemsSource="{Binding AlarmTypeDefines}"
            SelectedIndex="0"
            SelectedItem="{Binding SelectedItem}"
            SelectionMode="Single">
            <b:Interaction.Behaviors>
                <!--  自訂Behavior來避免combobox的SelectionChanged事件bubble到ListViewItem  -->
                <behaviors:ListViewSelectionChangedBehavior Command="{Binding CancelEditOnSelectionChangedCommand}" />
            </b:Interaction.Behaviors>
            <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">

                    <GridViewColumn Header="告警代碼">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:EquipAlarmTypeDefineDto}">
                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding EquipAlarmTypeID}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>


                    <GridViewColumn Header="所屬系統">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:EquipAlarmTypeDefineDto}">
                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding EquipType.SystemType}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn
                        Width="200"
                        Header="設備類型"
                        HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Left}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:EquipAlarmTypeDefineDto}">
                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Left}" Text="{Binding EquipType.EquipType}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn
                        Width="550"
                        Header="錯誤說明"
                        HeaderContainerStyle="{StaticResource GridView.ColumnHeader.Left}">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:EquipAlarmTypeDefineDto}">
                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Left}" Text="{Binding Description}" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Width="150" Header="告警等級">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type dtos:EquipAlarmTypeDefineDto}">
                                <!--<ComboBox
                                    FontSize="16"
                                    ItemContainerStyle="{StaticResource CMFT.ListBox.ListBoxItem}"
                                    ItemsSource="{x:Static datas:DesignTimeDatas.AlarmLevelDefines}"
                                    SelectedItem="{Binding AlarmLevelDefine}"
                                    Style="{StaticResource GridView.Column.ComboBox.Center}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type dtos:AlarmLevelDefineDto}">
                                            <StackPanel Orientation="Horizontal">
                                                <Border
                                                    Width="25"
                                                    Height="25"
                                                    Margin="10,0"
                                                    Background="{Binding Color}" />
                                                <TextBlock VerticalAlignment="Center" Text="{Binding AlarmLevel}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>-->
                                <Grid>
                                    <!--  ComboBox 編輯  -->
                                    <ComboBox
                                        x:Name="AlarmLevelComboBox"
                                        FontSize="16"
                                        ItemsSource="{Binding DataContext.AlarmLevelDefines, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        SelectedItem="{Binding AlarmLevelDefine}"
                                        Style="{StaticResource GridView.Column.ComboBox.Center}"
                                        Visibility="Collapsed">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate DataType="{x:Type dtos:AlarmLevelDefineDto}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border
                                                        Width="25"
                                                        Height="25"
                                                        Margin="10,0"
                                                        Background="{Binding Color}" />
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding AlarmLevel}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <!--  TextBlock 檢視  -->
                                    <StackPanel
                                        x:Name="AlarmLevelViewPanel"
                                        Orientation="Horizontal"
                                        Visibility="Visible">
                                        <!--  小色塊，顯示目前 AlarmLevelDefine.Color  -->
                                        <Border
                                            Width="25"
                                            Height="25"
                                            Margin="10,0"
                                            Background="{Binding AlarmLevelDefine.Color}" />
                                        <!--  文字，用來顯示目前 AlarmLevelDefine.AlarmLevel  -->
                                        <TextBlock VerticalAlignment="Center" Text="{Binding AlarmLevelDefine.AlarmLevel}" />
                                    </StackPanel>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=ListView}}" Value="True" />
                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="AlarmLevelComboBox" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="AlarmLevelViewPanel" Property="Visibility" Value="Collapsed" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>


                </GridView>
            </ListView.View>
        </ListView>
        <UniformGrid
            Grid.Column="1"
            VerticalAlignment="Bottom"
            Columns="1"
            Style="{StaticResource PanelMargin3}">
            <Button
                d:Visibility="Visible"
                Command="{Binding CancelCommand}"
                Style="{StaticResource CancelButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding ConfirmCommand}"
                Style="{StaticResource ConfirmButton}"
                Visibility="{Binding IsEditMode, Converter={converters:EqualityToVisibilityConverter}, ConverterParameter={StaticResource TrueValue}}" />
            <Button
                d:Visibility="Visible"
                Command="{Binding EditCommand}"
                ContentTemplate="{StaticResource EditItemData}"
                Style="{StaticResource EditButton}"
                Visibility="{Binding IsItemOperation, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </UniformGrid>
    </Grid>


</UserControl>
