<UserControl
    x:Class="ASI.TCL.CMFT.WPF.Module.Alarm.Views.EventAlarmMainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dataTypes="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.DataTypes"
    xmlns:datas="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Datas"
    xmlns:dtos="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.Dtos"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:EventAlarmMainViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="540"
    d:DesignWidth="1420"
    Style="{StaticResource CMFT.UserControl}"
    mc:Ignorable="d">

    <Grid>
        <GroupBox Margin="5" Header="設定">
            <UniformGrid Columns="1">


                <Grid d:Visibility="Visible">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="7*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <ListView
                            x:Name="EventListView"
                            Grid.Column="0"
                            ItemContainerStyle="{StaticResource ListView.GridViewItem.Stretch}"
                            ItemsSource="{Binding EventAlarms}"
                            ScrollViewer.VerticalScrollBarVisibility="Visible"
                            SelectionMode="Single">

                            <ListView.View>
                                <GridView ColumnHeaderContainerStyle="{StaticResource GridView.ColumnHeader.Center}">

                                    <GridViewColumn Header="發生時間">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EventAlarmDto}">
                                                <StackPanel Orientation="Vertical">
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding AlarmTime, StringFormat='{}{0:yyyy/MM/dd}'}" />
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding AlarmTime, StringFormat='{}{0:HH:mm:ss}'}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <!--<GridViewColumn Header="列車">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EventAlarmDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding Train.TrainNumber}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="車廂">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EventAlarmDto}">
                                                <TextBlock Style="{StaticResource GridView.Column.TextBlock.Center}" Text="{Binding CarNumber}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>-->

                                    <GridViewColumn Width="200" Header="監視器編號">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EventAlarmDto}">
                                                <ItemsControl
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    ItemsPanel="{StaticResource StackItemsPanelHorizontalMargin3}"
                                                    ItemsSource="{Binding CameraIDs}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding}" />
                                                                <TextBlock Text=";" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="500" Header="發生事件">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EventAlarmDto}">
                                                <StackPanel Orientation="Vertical">
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding AlarmDefine.Description}" />
                                                    <TextBlock Style="{StaticResource GridView.Column.TextBlock.AlarmColor}" Text="{Binding AlarmDefine.PossibleReason}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="200" Header="攝影機連動">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate DataType="{x:Type dtos:EventAlarmDto}">
                                                <Button
                                                    Height="30"
                                                    BorderBrush="{StaticResource CMFT.Brush.Green.Dark}"
                                                    Content="轉跳至攝影機&gt;"
                                                    Style="{StaticResource CMFT.Button}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="1*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Margin="10,0,10,10"
                                Style="{StaticResource CMFT.TextBlock.Left}"
                                Text="搜尋條件" />
                            <ScrollViewer Grid.Row="1" VerticalAlignment="Top">
                                <UniformGrid Style="{StaticResource UniformGridMargin10}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <DatePicker
                                            Grid.Column="0"
                                            materialDesign:HintAssist.Hint="開始時間"
                                            SelectedDate="{Binding SelectedStartTime}" />
                                        <materialDesign:TimePicker
                                            Grid.Column="1"
                                            Margin="5,0,0,0"
                                            SelectedTime="{Binding SelectedStartTime}" />
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <DatePicker
                                            Grid.Column="0"
                                            materialDesign:HintAssist.Hint="結束時間"
                                            SelectedDate="{Binding SelectedEndTime}" />
                                        <materialDesign:TimePicker
                                            Grid.Column="1"
                                            Margin="5,0,0,0"
                                            SelectedTime="{Binding SelectedEndTime}" />
                                    </Grid>


                                    <TextBox
                                        Margin="4,0"
                                        materialDesign:HintAssist.Hint="列車"
                                        materialDesign:TextFieldAssist.HasClearButton="True"
                                        Text="{Binding SelectedAccountId}" />
                                    <TextBox
                                        Margin="4,0"
                                        materialDesign:HintAssist.Hint="監視器編號"
                                        materialDesign:TextFieldAssist.HasClearButton="True" />
                                    <TextBox
                                        Margin="4,2"
                                        materialDesign:HintAssist.Hint="發生事件"
                                        materialDesign:TextFieldAssist.HasClearButton="True"
                                        Text="{Binding SelectedSYSConsole.ConsoleName}" />
                                    <TextBox
                                        Margin="4,2"
                                        materialDesign:HintAssist.Hint="顯示筆數"
                                        materialDesign:TextFieldAssist.HasClearButton="True"
                                        Text="{Binding SelectedAlarmCode}" />

                                </UniformGrid>
                            </ScrollViewer>

                            <UniformGrid Grid.Row="2" Columns="2">
                                <Button
                                    Command="{Binding SearchCommand}"
                                    Content="搜尋"
                                    Style="{StaticResource OperationButton}" />
                                <Button
                                    Background="{StaticResource CMFT.Brush.Green.Dark}"
                                    Command="{Binding RemitCommand}"
                                    Content="匯出"
                                    Style="{StaticResource OperationButton}" />
                            </UniformGrid>



                        </Grid>

                    </Grid>
                </Grid>



            </UniformGrid>
        </GroupBox>

    </Grid>
</UserControl>
