<UserControl x:Class="ASI.TCL.CMFT.WPF.Module.Alarm.Views.EventAlarmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:ASI.TCL.CMFT.WPF.Module.Alarm.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DataContext="{d:DesignInstance viewModels:EventAlarmViewModel,
                                              IsDesignTimeCreatable=True}"
             d:DesignHeight="540"
             d:DesignWidth="1420"
             Style="{StaticResource CMFT.UserControl}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ASI.TCL.CMFT.WPF.Module.Alarm;component/Datas/DesignTimeDatas.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <DataGrid Grid.Row="0"
                  d:ItemsSource="{DynamicResource MockEventAlarms}"
                  CellStyle="{StaticResource CMFT.DataGrid.DataGridRow.EventAlarmCell}"
                  Cursor="Hand"
                  FontSize="16"
                  FontWeight="Bold"
                  ItemsSource="{Binding EventAlarms}"
                  RowStyle="{StaticResource CMFT.DataGrid.DataGridRow.EventAlarmRow}"
                  ScrollViewer.CanContentScroll="False"
                  Style="{StaticResource CMFT.DataGrid}">

            <DataGrid.Columns>
                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding AlarmTime, StringFormat={}{0:yyyy/MM/dd HH:mm:ss}}"
                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                    Header="發生時間" />

                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding Train}"
                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                    Header="列車" />

                <DataGridTextColumn Width="Auto"
                                    Binding="{Binding CarNumber}"
                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                    Header="車廂" />

                <DataGridTextColumn Width="*"
                                    Binding="{Binding Description}"
                                    ElementStyle="{StaticResource CMFT.DataGrid.DataGridRow.EquipAlarmCell.Element.TextBlock.Left}"
                                    Header="警報描述" />

                <DataGridTemplateColumn Header="">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button BorderBrush="{StaticResource CMFT.Brush.Green.Dark}" Content="轉跳至攝影機&gt;" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

        </DataGrid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="1*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Margin="5"
                       Style="{StaticResource CMFT.TextBlock.Left}"
                       Text="搜尋條件" />
            <ScrollViewer Grid.Row="1" VerticalAlignment="Top">
                <UniformGrid Style="{StaticResource UniformGridMargin5}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <DatePicker Grid.Column="0"
                                    materialDesign:HintAssist.Hint="開始時間"
                                    SelectedDate="{Binding SelectedStartTime}" />
                        <materialDesign:TimePicker Grid.Column="1"
                                                   Margin="5,0,0,0"
                                                   SelectedTime="{Binding SelectedStartTime}" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <DatePicker Grid.Column="0"
                                    materialDesign:HintAssist.Hint="結束時間"
                                    SelectedDate="{Binding SelectedEndTime}" />
                        <materialDesign:TimePicker Grid.Column="1"
                                                   Margin="5,0,0,0"
                                                   SelectedTime="{Binding SelectedEndTime}" />
                    </Grid>
                    <TextBox Margin="4,0"
                             materialDesign:HintAssist.Hint="列車"
                             materialDesign:TextFieldAssist.HasClearButton="True"
                             Text="{Binding SelectedAccountId}" />
                    <TextBox Margin="4,0"
                             materialDesign:HintAssist.Hint="監視器編號"
                             materialDesign:TextFieldAssist.HasClearButton="True" />
                    <TextBox Margin="4,2"
                             materialDesign:HintAssist.Hint="發生事件"
                             materialDesign:TextFieldAssist.HasClearButton="True"
                             Text="{Binding SelectedSYSConsole.ConsoleName}" />
                    <TextBox Margin="4,2"
                             materialDesign:HintAssist.Hint="顯示筆數"
                             materialDesign:TextFieldAssist.HasClearButton="True"
                             Text="{Binding SelectedAlarmCode}" />
                </UniformGrid>
            </ScrollViewer>

            <UniformGrid Grid.Row="2"
                         Margin="5"
                         Columns="2">
                <Button Command="{Binding SearchCommand}"
                        Content="搜尋"
                        Style="{StaticResource OperationButton}" />
                <Button Background="{StaticResource CMFT.Brush.Green.Dark}"
                        Command="{Binding RemitCommand}"
                        Content="匯出"
                        Style="{StaticResource OperationButton}" />
            </UniformGrid>
        </Grid>
    </Grid>

</UserControl>